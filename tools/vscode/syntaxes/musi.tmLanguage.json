{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Musi",
    "scopeName": "source.musi",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#attributes" },
        { "include": "#keywords" },
        { "include": "#storage" },
        { "include": "#constants" },
        { "include": "#literals" },
        { "include": "#operators" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.documentation.musi",
                    "begin": "/\\*\\*(?!/)",
                    "end": "\\*/"
                },
                {
                    "name": "comment.block.musi",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.documentation.musi",
                    "match": "///.*$"
                },
                {
                    "name": "comment.line.double-slash.musi",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.interpolated.musi",
                    "begin": "\\$\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "meta.embedded.expression.musi",
                            "begin": "(?<!\\\\)\\{",
                            "end": "\\}",
                            "patterns": [ { "include": "$self" } ]
                        },
                        {
                            "name": "constant.character.escape.musi",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.musi",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.musi",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "attributes": {
            "name": "meta.attribute.musi",
            "begin": "#\\[",
            "end": "\\]",
            "patterns": [
                { "include": "#strings" },
                { "include": "#literals" },
                { "include": "#operators" },
                { "include": "#punctuation" }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.conditional.musi",
                    "match": "\\b(if|else|match)\\b"
                },
                {
                    "name": "keyword.control.loop.musi",
                    "match": "\\b(while|for|in)\\b"
                },
                {
                    "name": "keyword.control.flow.musi",
                    "match": "\\b(break|cycle|return|defer)\\b"
                },
                {
                    "name": "keyword.control.import.musi",
                    "match": "\\b(import|export|from|as)\\b"
                },
                {
                    "name": "keyword.operator.logical.musi",
                    "match": "\\b(and|or|xor|not)\\b"
                },
                {
                    "name": "keyword.operator.bitwise.musi",
                    "match": "\\b(shl|shr|rol|ror)\\b"
                },
                {
                    "name": "keyword.other.musi",
                    "match": "\\b(with)\\b"
                }
            ]
        },
        "storage": {
            "patterns": [
                {
                    "name": "storage.type.musi",
                    "match": "\\b(fn|val|var|record|choice)\\b"
                },
                {
                    "name": "storage.modifier.musi",
                    "match": "\\b(export|native|opaque|unsafe)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.musi",
                    "match": "\\b([tT]rue|[fF]alse)\\b"
                },
                {
                    "name": "constant.language.self.musi",
                    "match": "\\b([sS]elf)\\b"
                },
                {
                    "name": "constant.language.null.musi",
                    "match": "\\b_\\b"
                }
            ]
        },
        "literals": {
            "patterns": [
                {
                    "name": "constant.character.musi",
                    "match": "'(?:\\\\.|[^\\\\'])'"
                },
                {
                    "name": "constant.numeric.hex.musi",
                    "match": "\\b0[xX][0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.musi",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.musi",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.musi",
                    "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.musi",
                    "match": "\\b\\d[\\d_]*\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.musi",
                    "match": "->|=>"
                },
                {
                    "name": "keyword.operator.assignment.musi",
                    "match": ":=|<-"
                },
                {
                    "name": "keyword.operator.cons.musi",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.range.musi",
                    "match": "\\.\\.<|\\.\\."
                },
                {
                    "name": "keyword.operator.comparison.musi",
                    "match": "/=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.cast.musi",
                    "match": "\\bas\\b"
                },
                {
                    "name": "keyword.operator.arithmetic.musi",
                    "match": "[+\\-*/%]|\\b(mod|div)\\b"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.separator.musi",
                    "match": "[,;]"
                },
                {
                    "name": "punctuation.accessor.musi",
                    "match": "\\."
                },
                {
                    "name": "punctuation.definition.parameters.begin.musi",
                    "match": "\\("
                },
                {
                    "name": "punctuation.definition.parameters.end.musi",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.definition.array.begin.musi",
                    "match": "\\["
                },
                {
                    "name": "punctuation.definition.array.end.musi",
                    "match": "\\]"
                },
                {
                    "name": "punctuation.definition.block.begin.musi",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.definition.block.end.musi",
                    "match": "\\}"
                },
                {
                    "name": "punctuation.separator.type.musi",
                    "match": ":"
                }
            ]
        }
    }
}
