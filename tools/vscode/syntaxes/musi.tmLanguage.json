{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Musi",
    "scopeName": "source.musi",
    "patterns": [
        { "include": "#comments" },
        { "include": "#attributes" },
        { "include": "#labels" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#operators" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.musi",
                    "match": "\\b(break|case|cycle|defer|else|export|for|if|in|match|return|while|with|import|as|from)\\b"
                },
                {
                    "name": "storage.modifier.musi",
                    "match": "\\b(native|unsafe)\\b"
                },
                {
                    "name": "storage.type.musi",
                    "match": "\\b(choice|fn|record|alias|val|var|class|instance)\\b"
                },
                {
                    "name": "keyword.operator.logical.musi",
                    "match": "\\b(and|or|xor|not)\\b"
                },
                {
                    "name": "keyword.operator.relational.musi",
                    "match": "\\b(is|as|in)\\b"
                }
            ]
        },
        "labels": {
            "name": "entity.name.label.musi",
            "match": "#[a-zA-Z_][a-zA-Z0-9_]*"
        },
        "operators": {
            "patterns": [
                {
                    "match": ":=|<-|->|=>",
                    "name": "keyword.operator.musi"
                },
                {
                    "match": "::",
                    "name": "keyword.operator.cons.musi"
                },
                {
                    "match": "\\.\\.<|\\.\\.",
                    "name": "keyword.operator.range.musi"
                },
                {
                    "match": "(?<!=)=(?!=)",
                    "name": "keyword.operator.comparison.musi"
                },
                {
                    "match": "/=|<=|>=|<|>",
                    "name": "keyword.operator.comparison.musi"
                },
                {
                    "match": "\\+|-|\\*|/|%",
                    "name": "keyword.operator.arithmetic.musi"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.musi",
                    "match": "\\b0[xX][0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.musi",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.musi",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.musi",
                    "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.musi",
                    "match": "\\b\\d[\\d_]*\\b"
                },
                {
                    "name": "constant.language.boolean.musi",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "attributes": {
            "name": "entity.name.tag.less.musi",
            "begin": "@\\[",
            "beginCaptures": { "0": { "name": "punctuation.definition.attribute.musi" } },
            "end": "\\]",
            "endCaptures": { "0": { "name": "punctuation.definition.attribute.musi" } },
            "patterns": [
                { "include": "#strings" },
                { "include": "#constants" },
                {
                    "match": ":=",
                    "name": "keyword.operator.musi"
                },
                {
                    "match": "[,()]",
                    "name": "punctuation.separator.musi"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.template.musi",
                    "begin": "\\$\"",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
                    "end": "\"",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
                    "patterns": [
                        {
                            "name": "meta.embedded.expression.musi",
                            "begin": "(?<!\\\\)\\{",
                            "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
                            "end": "\\}",
                            "endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
                            "patterns": [
                                { "include": "#comments" },
                                { "include": "#keywords" },
                                { "include": "#constants" },
                                { "include": "#operators" },
                                { "include": "#punctuation" }
                            ]
                        },
                        { "include": "#escape-sequences" }
                    ]
                },
                {
                    "name": "string.quoted.double.musi",
                    "begin": "\"",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
                    "end": "\"",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
                    "patterns": [ { "include": "#escape-sequences" } ]
                },
                {
                    "name": "string.quoted.single.musi",
                    "begin": "'",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
                    "end": "'",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
                    "patterns": [ { "include": "#escape-sequences" } ]
                }
            ]
        },
        "escape-sequences": {
            "name": "constant.character.escape.musi",
            "match": "\\\\([\"'`\\\\nrtbfv]|u\\{[0-9a-fA-F]+\\}|x[0-9a-fA-F]{2})"
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.documentation.musi",
                    "begin": "/\\*\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.block.musi",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.documentation.musi",
                    "match": "///.*$"
                },
                {
                    "name": "comment.line.double-slash.musi",
                    "match": "//.*$"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "match": "[;,]",
                    "name": "punctuation.separator.musi"
                },
                {
                    "match": "\\.",
                    "name": "punctuation.accessor.musi"
                },
                {
                    "match": "[()\\[\\]{}]",
                    "name": "punctuation.bracket.musi"
                }
            ]
        }
    }
}
