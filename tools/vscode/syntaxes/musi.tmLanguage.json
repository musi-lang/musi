{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Musi",
    "scopeName": "source.musi",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#attributes" },
        { "include": "#declarations" },
        { "include": "#literals" },
        { "include": "#operators" },
        { "include": "#types" },
        { "include": "#expressions" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.documentation.musi",
                    "begin": "/\\*\\*(?!/)",
                    "end": "\\*/"
                },
                {
                    "name": "comment.block.musi",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.documentation.musi",
                    "match": "///.*$"
                },
                {
                    "name": "comment.line.double-slash.musi",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.template.musi",
                    "begin": "\\$\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "meta.embedded.expression.musi",
                            "begin": "(?<!\\\\)\\{",
                            "end": "\\}",
                            "patterns": [ { "include": "$self" } ]
                        },
                        {
                            "name": "constant.character.escape.musi",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.musi",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.musi",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.musi",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.musi",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "storage.type.musi",
                    "match": "\\b(fn|val|var|record|choice)\\b"
                },
                {
                    "name": "storage.modifier.musi",
                    "match": "\\b(export|native|opaque)\\b"
                },
                {
                    "name": "keyword.control.musi",
                    "match": "\\b(break|cycle|return|defer|if|else|match|for|while|import|export|from|as|in|with)\\b"
                },
                {
                    "name": "keyword.operator.logical.musi",
                    "match": "\\b(and|or|xor|not)\\b"
                },
                {
                    "name": "keyword.operator.bitwise.musi",
                    "match": "\\b(shl|shr|rol|ror)\\b"
                }
            ]
        },
        "attributes": {
            "name": "meta.attribute.musi",
            "begin": "#\\[",
            "end": "\\]",
            "patterns": [
                {
                    "name": "entity.name.attribute.musi",
                    "match": "(?i)[a-z_][a-z0-9_]*"
                },
                { "include": "#literals" },
                { "include": "#strings" }
            ]
        },
        "declarations": {
            "patterns": [
                {
                    "match": "\\b(native)\\s+(\"[^\"]+\")\\s+(fn|record)\\b",
                    "captures": {
                        "1": { "name": "storage.modifier.musi" },
                        "2": { "name": "string.quoted.double.musi" },
                        "3": { "name": "storage.type.musi" }
                    }
                },
                {
                    "name": "meta.import.musi",
                    "begin": "\\b(import)\\b",
                    "beginCaptures": { "1": { "name": "keyword.control.import.musi" } },
                    "end": ";",
                    "patterns": [
                        {
                            "name": "keyword.control.musi",
                            "match": "\\b(from|as)\\b"
                        },
                        {
                            "name": "variable.language.wildcard.musi",
                            "match": "\\*"
                        },
                        { "include": "#strings" },
                        {
                            "name": "variable.other.musi",
                            "match": "(?i)[a-z_][a-z0-9_]*|`[^`]+`"
                        }
                    ]
                },
                {
                    "name": "meta.export.musi",
                    "begin": "\\b(export)\\b",
                    "beginCaptures": { "1": { "name": "keyword.control.export.musi" } },
                    "end": ";",
                    "patterns": [
                        {
                            "name": "keyword.control.musi",
                            "match": "\\b(from|as)\\b"
                        },
                        {
                            "name": "variable.language.wildcard.musi",
                            "match": "\\*"
                        },
                        { "include": "#strings" },
                        {
                            "name": "variable.other.musi",
                            "match": "(?i)[a-z_][a-z0-9_]*|`[^`]+`"
                        }
                    ]
                }
            ]
        },
        "literals": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.musi",
                    "match": "\\b0[xX][0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.musi",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.musi",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.musi",
                    "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.musi",
                    "match": "\\b\\d[\\d_]*\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.musi",
                    "match": "->|=>"
                },
                {
                    "name": "keyword.operator.assignment.musi",
                    "match": ":=|<-"
                },
                {
                    "name": "keyword.operator.cons.musi",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.range.musi",
                    "match": "\\.\\.<|\\.\\."
                },
                {
                    "name": "keyword.operator.comparison.musi",
                    "match": "/=|<=|>=|=|<|>"
                },
                {
                    "name": "keyword.operator.arithmetic.musi",
                    "match": "[+\\-*/%]"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.self.musi",
                    "match": "\\bSelf\\b"
                },
                {
                    "name": "meta.type.generic.musi",
                    "begin": "((?i)[A-Z][a-z0-9_]*)\\s*(\\[)",
                    "beginCaptures": {
                        "1": { "name": "entity.name.type.musi" },
                        "2": { "name": "punctuation.bracket.musi" }
                    },
                    "end": "\\]",
                    "endCaptures": { "0": { "name": "punctuation.bracket.musi" } },
                    "patterns": [ { "include": "#types" } ]
                },
                {
                    "name": "entity.name.type.musi",
                    "match": "(?i)[A-Z][a-z0-9_]*"
                }
            ]
        },
        "expressions": {
            "patterns": [
                {
                    "name": "meta.label.musi",
                    "match": "([a-z_][a-z0-9_]*)\\s*(:)(?!=)",
                    "captures": {
                        "1": { "name": "entity.name.label.musi" },
                        "2": { "name": "punctuation.separator.musi" }
                    }
                },
                {
                    "name": "keyword.control.label.musi",
                    "match": ":[a-z_][a-z0-9_]*"
                },
                {
                    "name": "meta.function.declaration.musi",
                    "begin": "\\b(fn)\\s+((?i)[a-z_][a-z0-9_]*|`[^`]+`)",
                    "beginCaptures": {
                        "1": { "name": "storage.type.function.musi" },
                        "2": { "name": "entity.name.function.musi" }
                    },
                    "end": "(?==>|\\{|;)",
                    "patterns": [ { "include": "#type-params-and-signature" } ]
                },
                {
                    "name": "meta.variable.declaration.musi",
                    "match": "\\b(val|var)\\s+((?i)[a-z_][a-z0-9_]*|`[^`]+`)\\s*(:)?",
                    "captures": {
                        "1": { "name": "storage.type.musi" },
                        "2": { "name": "variable.other.musi" },
                        "3": { "name": "punctuation.separator.musi" }
                    }
                },
                {
                    "name": "meta.type.declaration.musi",
                    "match": "\\b(record|choice)\\s+((?i)[A-Z][a-z0-9_]*)",
                    "captures": {
                        "1": { "name": "storage.type.musi" },
                        "2": { "name": "entity.name.type.musi" }
                    }
                },
                {
                    "name": "meta.constructor.musi",
                    "begin": "((?i)[A-Z][a-z0-9_]*)\\s*(\\()",
                    "beginCaptures": {
                        "1": { "name": "entity.name.type.variant.musi" },
                        "2": { "name": "punctuation.paren.musi" }
                    },
                    "end": "\\)",
                    "endCaptures": { "0": { "name": "punctuation.paren.musi" } },
                    "patterns": [ { "include": "$self" } ]
                },
                {
                    "name": "meta.function.call.musi",
                    "begin": "((?i)[a-z_][a-z0-9_]*|`[^`]+`)\\s*(\\()",
                    "beginCaptures": {
                        "1": { "name": "entity.name.function.musi" },
                        "2": { "name": "punctuation.paren.musi" }
                    },
                    "end": "\\)",
                    "endCaptures": { "0": { "name": "punctuation.paren.musi" } },
                    "patterns": [ { "include": "$self" } ]
                },
                {
                    "name": "meta.field.access.musi",
                    "match": "((?i)[a-z_][a-z0-9_]*|`[^`]+`)\\s*(\\.)\\s*((?i)[a-z_][a-z0-9_]*)",
                    "captures": {
                        "1": { "name": "variable.other.object.musi" },
                        "2": { "name": "punctuation.accessor.musi" },
                        "3": { "name": "variable.other.member.musi" }
                    }
                },
                {
                    "name": "meta.block.musi",
                    "begin": "\\{",
                    "end": "\\}",
                    "patterns": [ { "include": "$self" } ]
                },
                {
                    "name": "meta.group.musi",
                    "begin": "\\(",
                    "end": "\\)",
                    "patterns": [ { "include": "$self" } ]
                },
                {
                    "name": "meta.array.musi",
                    "begin": "\\[",
                    "end": "\\]",
                    "patterns": [ { "include": "$self" } ]
                },
                {
                    "name": "meta.record.literal.musi",
                    "begin": "\\.\\{",
                    "end": "\\}",
                    "patterns": [
                        {
                            "name": "entity.name.field.musi",
                            "match": "(?i)[a-z_][a-z0-9_]*(?=\\s*:)"
                        },
                        { "include": "$self" }
                    ]
                }
            ]
        },
        "type-params-and-signature": {
            "patterns": [
                {
                    "name": "meta.type.parameters.musi",
                    "begin": "\\[",
                    "end": "\\]",
                    "patterns": [
                        {
                            "name": "entity.name.type.parameter.musi",
                            "match": "(?i)[a-z_][a-z0-9_]*"
                        },
                        { "include": "#types" }
                    ]
                },
                {
                    "name": "meta.function.parameters.musi",
                    "begin": "\\(",
                    "end": "\\)",
                    "patterns": [
                        { "include": "#attributes" },
                        {
                            "name": "storage.modifier.musi",
                            "match": "\\bvar\\b"
                        },
                        {
                            "match": "((?i)[a-z_][a-z0-9_]*|`[^`]+`)\\s*(:)",
                            "captures": {
                                "1": { "name": "variable.parameter.musi" },
                                "2": { "name": "punctuation.separator.musi" }
                            }
                        },
                        { "include": "#types" }
                    ]
                },
                {
                    "name": "meta.return.type.musi",
                    "begin": ":",
                    "end": "(?==>|\\{|;)",
                    "patterns": [ { "include": "#types" } ]
                }
            ]
        }
    }
}
