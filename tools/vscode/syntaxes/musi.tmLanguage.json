{
    "name": "Musi",
    "scopeName": "source.musi",
    "patterns": [
        { "include": "#comments" },
        { "include": "#attributes" },
        { "include": "#keywords" },
        { "include": "#literals" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.musi",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.musi",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [ { "include": "#comments" } ]
                }
            ]
        },
        "attributes": {
            "name": "meta.attribute.musi",
            "begin": "#\\[",
            "end": "\\]",
            "patterns": [
                {
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`)(?=\\s*[,\\]\\(])",
                    "name": "entity.name.attribute.musi"
                },
                {
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`)\\s*(:=)",
                    "captures": {
                        "1": { "name": "variable.parameter.attribute.musi" },
                        "2": { "name": "keyword.operator.assignment.musi" }
                    }
                },
                { "include": "#literals" },
                { "include": "#comments" }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "match": "\\b(break|cycle)\\s+(:[a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.control.musi" },
                        "2": { "name": "entity.name.label.musi" }
                    }
                },
                {
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)(?=\\s*(while|for))",
                    "captures": {
                        "1": { "name": "entity.name.label.musi" },
                        "2": { "name": "punctuation.separator.musi" }
                    }
                },
                {
                    "name": "keyword.control.musi",
                    "match": "\\b(if|else|while|for|in|match|case|return|break|cycle|defer)\\b"
                },
                {
                    "name": "keyword.control.import.musi",
                    "match": "\\b(import|export|from|as)\\b"
                },
                {
                    "name": "storage.type.musi",
                    "match": "\\b(fn|val|var|record|choice)\\b"
                },
                {
                    "name": "storage.modifier.musi",
                    "match": "\\b(export|opaque|native)\\b"
                },
                {
                    "name": "keyword.other.musi",
                    "match": "\\b(with)\\b"
                }
            ]
        },
        "literals": {
            "patterns": [
                { "include": "#template-string" },
                { "include": "#string" },
                { "include": "#rune" },
                { "include": "#numeric" },
                {
                    "name": "constant.language.musi",
                    "match": "\\b([sS]elf)\\b"
                }
            ]
        },
        "template-string": {
            "name": "string.template.musi",
            "begin": "\\$\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "meta.embedded.musi",
                    "begin": "\\{",
                    "end": "\\}",
                    "patterns": [ { "include": "$self" } ]
                },
                {
                    "name": "constant.character.escape.musi",
                    "match": "\\\\."
                }
            ]
        },
        "string": {
            "name": "string.quoted.double.musi",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.musi",
                    "match": "\\\\."
                }
            ]
        },
        "rune": {
            "name": "string.quoted.single.musi",
            "begin": "'",
            "end": "'",
            "patterns": [
                {
                    "name": "constant.character.escape.musi",
                    "match": "\\\\."
                }
            ]
        },
        "numeric": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.musi",
                    "match": "\\b0[xX][0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.musi",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.musi",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.float.musi",
                    "match": "\\b[0-9_]+\\.[0-9_]+([eE][+-]?[0-9_]+)?\\b"
                },
                {
                    "name": "constant.numeric.decimal.musi",
                    "match": "\\b[0-9_]+\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "match": "'[a-zA-Z_][a-zA-Z0-9_]*",
                    "name": "constant.language.type.variable.musi"
                },
                {
                    "begin": ":",
                    "end": "(?=[,\\)\\}=;]|->|=>|\\{)",
                    "patterns": [
                        {
                            "match": "->",
                            "name": "storage.type.function.arrow.musi"
                        },
                        {
                            "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
                            "name": "entity.name.type.musi"
                        },
                        { "include": "#type-params" }
                    ]
                },
                {
                    "match": "\\b[A-Z][a-zA-Z0-9_]*(?=\\[)",
                    "name": "entity.name.type.musi"
                },
                { "include": "#type-params" }
            ]
        },
        "type-params": {
            "begin": "\\[(?=\\s*[a-zA-Z0-9_'\\[\\]])",
            "end": "\\]",
            "patterns": [
                {
                    "match": "[0-9]+",
                    "name": "constant.numeric.musi"
                },
                {
                    "match": "[a-zA-Z_][a-zA-Z0-9_]*",
                    "name": "entity.name.type.parameter.musi"
                },
                { "include": "#types" }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.musi",
                    "match": ":=|<-"
                },
                {
                    "name": "keyword.operator.comparison.musi",
                    "match": "<=|>=|<|>|=|/="
                },
                {
                    "name": "keyword.operator.arrow.musi",
                    "match": "->|=>"
                },
                {
                    "name": "keyword.operator.range.musi",
                    "match": "\\.\\.|\\.\\.<?"
                },
                {
                    "name": "keyword.operator.cons.musi",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.logical.musi",
                    "match": "\\b(and|or|xor|not|in)\\b"
                },
                {
                    "name": "keyword.operator.bitwise.musi",
                    "match": "\\b(shl|shr)\\b"
                },
                {
                    "name": "keyword.operator.arithmetic.musi",
                    "match": "[+\\-*/%]"
                },
                {
                    "name": "keyword.operator.access.musi",
                    "match": "\\.(?!\\.)"
                },
                {
                    "name": "keyword.operator.other.musi",
                    "match": "[@!|]"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.musi",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.musi",
                    "match": "[,:]"
                },
                {
                    "name": "punctuation.brackets.musi",
                    "match": "[\\[\\]\\{\\}\\(\\)]"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "match": "\\b_\\b",
                    "name": "constant.language.wildcard.musi"
                },
                {
                    "match": "`[^`]+`",
                    "name": "variable.other.escaped.musi"
                },
                {
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "name": "entity.name.function.musi"
                },
                {
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
                    "name": "entity.name.type.musi"
                },
                {
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b",
                    "name": "variable.other.musi"
                }
            ]
        }
    }
}
