{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Musi",
    "scopeName": "source.musi",
    "fileTypes": [ "musi" ],
    "patterns": [
        { "include": "#comments" },
        { "include": "#attributes" },
        { "include": "#labels" },
        { "include": "#keywords" },
        { "include": "#functions" },
        { "include": "#types" },
        { "include": "#strings" },
        { "include": "#constants" },
        { "include": "#operators" },
        { "include": "#identifiers" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flow.musi",
                    "match": "\\b(break|cycle|return|defer)\\b"
                },
                {
                    "name": "keyword.control.conditional.musi",
                    "match": "\\b(if|else|match|case)\\b"
                },
                {
                    "name": "keyword.control.loop.musi",
                    "match": "\\b(for|while|in)\\b"
                },
                {
                    "name": "keyword.control.import.musi",
                    "match": "\\b(import|export|from)\\b"
                },
                {
                    "name": "keyword.other.musi",
                    "match": "\\b(as|with)\\b"
                },
                {
                    "name": "storage.modifier.musi",
                    "match": "\\b(native|unsafe)\\b"
                },
                {
                    "name": "storage.type.declaration.musi",
                    "match": "\\b(choice|record|alias|class|instance)\\b"
                },
                {
                    "name": "storage.type.function.musi",
                    "match": "\\b(fn)\\b"
                },
                {
                    "name": "storage.type.variable.musi",
                    "match": "\\b(val|var)\\b"
                },
                {
                    "name": "keyword.operator.logical.musi",
                    "match": "\\b(and|or|xor|not)\\b"
                },
                {
                    "name": "keyword.operator.wordlike.musi",
                    "match": "\\b(is|as|in)\\b"
                },
                {
                    "name": "constant.language.boolean.musi",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "meta.function.musi",
                    "begin": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`)",
                    "beginCaptures": {
                        "1": { "name": "storage.type.function.musi" },
                        "2": { "name": "entity.name.function.musi" }
                    },
                    "end": "(?=[{;=>])",
                    "patterns": [
                        { "include": "#type-parameters" },
                        { "include": "#parameters" },
                        { "include": "#type-annotation" },
                        { "include": "#comments" }
                    ]
                },
                {
                    "name": "meta.function-call.musi",
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`)\\s*(?=\\()",
                    "captures": { "1": { "name": "entity.name.function.call.musi" } }
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "meta.type.declaration.musi",
                    "begin": "\\b(record|choice|alias|class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "beginCaptures": {
                        "1": { "name": "storage.type.declaration.musi" },
                        "2": { "name": "entity.name.type.musi" }
                    },
                    "end": "(?=[{;])",
                    "patterns": [
                        { "include": "#type-parameters" },
                        { "include": "#comments" }
                    ]
                },
                {
                    "name": "entity.name.type.musi",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "type-parameters": {
            "name": "meta.type.parameters.musi",
            "begin": "(?<![a-zA-Z0-9_])\\[",
            "end": "\\]",
            "patterns": [
                {
                    "name": "entity.name.type.parameter.musi",
                    "match": "[a-zA-Z_][a-zA-Z0-9_]*"
                },
                { "include": "#comments" },
                { "include": "#punctuation" }
            ]
        },
        "parameters": {
            "name": "meta.parameters.musi",
            "begin": "\\(",
            "end": "\\)",
            "patterns": [
                { "include": "#comments" },
                { "include": "#type-annotation" },
                { "include": "#operators" },
                { "include": "#constants" },
                { "include": "#strings" },
                {
                    "name": "variable.parameter.musi",
                    "match": "\\b(var\\s+)?([a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`)\\b",
                    "captures": {
                        "1": { "name": "storage.type.variable.musi" },
                        "2": { "name": "variable.parameter.musi" }
                    }
                },
                { "include": "#punctuation" }
            ]
        },
        "type-annotation": {
            "name": "meta.type.annotation.musi",
            "begin": ":",
            "end": "(?=[,){}=;]|:=|<-)",
            "patterns": [
                { "include": "#comments" },
                {
                    "name": "storage.type.function.arrow.musi",
                    "match": "->"
                },
                {
                    "name": "entity.name.type.musi",
                    "match": "[A-Z][a-zA-Z0-9_]*"
                },
                {
                    "name": "meta.type.parameters.musi",
                    "begin": "\\[",
                    "end": "\\]",
                    "patterns": [
                        { "include": "#type-annotation" },
                        { "include": "#constants" }
                    ]
                },
                { "include": "#punctuation" }
            ]
        },
        "labels": {
            "patterns": [
                {
                    "name": "entity.name.label.musi",
                    "match": "#[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.constant.musi",
                    "match": "\\b[A-Z][A-Z0-9_]*\\b"
                },
                {
                    "name": "variable.other.musi",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                },
                {
                    "name": "variable.other.escaped.musi",
                    "match": "`[^`]+`"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.musi",
                    "match": ":=|<-"
                },
                {
                    "name": "keyword.operator.arrow.musi",
                    "match": "->|=>"
                },
                {
                    "name": "keyword.operator.cons.musi",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.range.musi",
                    "match": "\\.\\.<|\\.\\."
                },
                {
                    "name": "keyword.operator.comparison.musi",
                    "match": "/=|<=|>=|(?<!=)=(?!=)|<|>"
                },
                {
                    "name": "keyword.operator.arithmetic.musi",
                    "match": "\\+|-|\\*|/|%"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.musi",
                    "match": "\\b0[xX][0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.musi",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.musi",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.musi",
                    "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.musi",
                    "match": "\\b\\d[\\d_]*\\b"
                }
            ]
        },
        "attributes": {
            "name": "meta.attribute.musi",
            "begin": "@\\[",
            "beginCaptures": { "0": { "name": "punctuation.definition.attribute.begin.musi" } },
            "end": "\\]",
            "endCaptures": { "0": { "name": "punctuation.definition.attribute.end.musi" } },
            "patterns": [
                {
                    "name": "entity.name.attribute.musi",
                    "match": "[a-zA-Z_][a-zA-Z0-9_]*"
                },
                { "include": "#strings" },
                { "include": "#constants" },
                {
                    "name": "keyword.operator.assignment.musi",
                    "match": ":="
                },
                {
                    "name": "punctuation.separator.musi",
                    "match": "[,()]"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.template.musi",
                    "begin": "\\$\"",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
                    "end": "\"",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
                    "patterns": [
                        {
                            "name": "meta.embedded.expression.musi",
                            "begin": "(?<!\\\\)\\{",
                            "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
                            "end": "\\}",
                            "endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
                            "patterns": [ { "include": "$self" } ]
                        },
                        { "include": "#escape-sequences" },
                        {
                            "name": "string.quoted.template.musi",
                            "match": "[^\"\\\\{]+"
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.musi",
                    "begin": "\"",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
                    "end": "\"",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
                    "patterns": [
                        { "include": "#escape-sequences" },
                        {
                            "name": "string.quoted.double.musi",
                            "match": "[^\"\\\\]+"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.musi",
                    "begin": "'",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
                    "end": "'",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
                    "patterns": [
                        { "include": "#escape-sequences" },
                        {
                            "name": "string.quoted.single.musi",
                            "match": "[^'\\\\]+"
                        }
                    ]
                }
            ]
        },
        "escape-sequences": {
            "name": "constant.character.escape.musi",
            "match": "\\\\([\"'`\\\\nrtbfv0]|u\\{[0-9a-fA-F]+\\}|x[0-9a-fA-F]{2})"
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.documentation.musi",
                    "begin": "/\\*\\*(?!/)",
                    "end": "\\*/",
                    "captures": { "0": { "name": "punctuation.definition.comment.musi" } }
                },
                {
                    "name": "comment.block.musi",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "captures": { "0": { "name": "punctuation.definition.comment.musi" } }
                },
                {
                    "name": "comment.line.documentation.musi",
                    "match": "(///).*$",
                    "captures": { "1": { "name": "punctuation.definition.comment.musi" } }
                },
                {
                    "name": "comment.line.double-slash.musi",
                    "match": "(//).*$",
                    "captures": { "1": { "name": "punctuation.definition.comment.musi" } }
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.statement.musi",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.comma.musi",
                    "match": ","
                },
                {
                    "name": "punctuation.accessor.musi",
                    "match": "\\."
                },
                {
                    "name": "punctuation.section.braces.begin.musi",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.section.braces.end.musi",
                    "match": "\\}"
                },
                {
                    "name": "punctuation.section.brackets.begin.musi",
                    "match": "\\["
                },
                {
                    "name": "punctuation.section.brackets.end.musi",
                    "match": "\\]"
                },
                {
                    "name": "punctuation.section.parens.begin.musi",
                    "match": "\\("
                },
                {
                    "name": "punctuation.section.parens.end.musi",
                    "match": "\\)"
                }
            ]
        }
    }
}
