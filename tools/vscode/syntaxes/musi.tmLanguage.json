{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Musi",
    "scopeName": "source.musi",
    "patterns": [
        { "include": "#comments" },
        { "include": "#attributes" },
        { "include": "#let-definition" },
        { "include": "#class-definition" },
        { "include": "#instance-definition" },
        { "include": "#record-definition" },
        { "include": "#effect-definition" },
        { "include": "#choice-body" },
        { "include": "#record-literal" },
        { "include": "#keywords" },
        { "include": "#literals" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "let-definition": {
            "patterns": [
                {
                    "comment": "let mut name -- mutable binding",
                    "match": "(\\bexport\\b\\s+)?\\b(let)\\b\\s+(mut)\\s+([a-z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.control.export.musi" },
                        "2": { "name": "storage.type.musi" },
                        "3": { "name": "storage.modifier.musi" },
                        "4": { "name": "variable.other.musi" }
                    }
                },
                {
                    "comment": "let SCREAMING_SNAKE -- constant definition (2+ all-uppercase chars)",
                    "match": "(\\bexport\\b\\s+)?\\b(let)\\b\\s+([A-Z][A-Z0-9_]+)\\b",
                    "captures": {
                        "1": { "name": "keyword.control.export.musi" },
                        "2": { "name": "storage.type.musi" },
                        "3": { "name": "variable.other.constant.musi" }
                    }
                },
                {
                    "comment": "let PascalCase -- type definition",
                    "match": "(\\bexport\\b\\s+)?\\b(let)\\b\\s+([A-Z][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.control.export.musi" },
                        "2": { "name": "storage.type.musi" },
                        "3": { "name": "entity.name.type.musi" }
                    }
                },
                {
                    "comment": "let (op) -- operator definition",
                    "match": "(\\bexport\\b\\s+)?\\b(let)\\b\\s+(\\()([^)]+)(\\))",
                    "captures": {
                        "1": { "name": "keyword.control.export.musi" },
                        "2": { "name": "storage.type.musi" },
                        "3": { "name": "entity.name.function.operator.musi" },
                        "4": { "name": "entity.name.function.operator.musi" },
                        "5": { "name": "entity.name.function.operator.musi" }
                    }
                },
                {
                    "comment": "let lowercase -- function/value definition",
                    "match": "(\\bexport\\b\\s+)?\\b(let)\\b\\s+([a-z_`][a-zA-Z0-9_]*`?)",
                    "captures": {
                        "1": { "name": "keyword.control.export.musi" },
                        "2": { "name": "storage.type.musi" },
                        "3": { "name": "entity.name.function.musi" }
                    }
                }
            ]
        },
        "class-definition": {
            "comment": "class Name -- type class definition",
            "match": "(\\bexport\\b\\s+)?\\b(class)\\b\\s+([A-Z][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.control.export.musi" },
                "2": { "name": "storage.type.musi" },
                "3": { "name": "entity.name.type.musi" }
            }
        },
        "instance-definition": {
            "comment": "instance Name -- type class instance",
            "match": "(\\bexport\\b\\s+)?\\b(instance)\\b\\s+([A-Z][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.control.export.musi" },
                "2": { "name": "storage.type.musi" },
                "3": { "name": "entity.name.type.musi" }
            }
        },
        "record-definition": {
            "comment": "record Name -- record type definition",
            "match": "(\\bexport\\b\\s+)?\\b(record)\\b\\s+([A-Z][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.control.export.musi" },
                "2": { "name": "storage.type.musi" },
                "3": { "name": "entity.name.type.musi" }
            }
        },
        "effect-definition": {
            "comment": "effect Name -- effect definition",
            "match": "(\\bexport\\b\\s+)?\\b(effect)\\b\\s+([A-Z][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.control.export.musi" },
                "2": { "name": "storage.type.musi" },
                "3": { "name": "entity.name.type.musi" }
            }
        },
        "choice-body": {
            "comment": "choice { Variant + Variant of 'T } -- inline choice type",
            "name": "meta.type.choice.musi",
            "begin": "\\b(choice)\\b\\s*(\\{)",
            "end": "\\}",
            "beginCaptures": {
                "1": { "name": "storage.type.musi" },
                "2": { "name": "punctuation.section.block.begin.musi" }
            },
            "endCaptures": { "0": { "name": "punctuation.section.block.end.musi" } },
            "patterns": [
                { "include": "#comments" },
                { "include": "#attributes" },
                {
                    "comment": "variant payload type: Failed of String — must precede #keywords so 'of' isn't consumed alone",
                    "match": "\\b(of)\\s+([A-Z][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.other.musi" },
                        "2": { "name": "entity.name.type.musi" }
                    }
                },
                { "include": "#keywords" },
                {
                    "match": "\\+",
                    "name": "keyword.operator.choice-separator.musi"
                },
                {
                    "comment": "variant constructor: None, Some, Cons, ...",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
                    "name": "variable.other.enummember.musi"
                },
                { "include": "#literals" },
                { "include": "#types" },
                { "include": "#operators" },
                { "include": "#punctuation" }
            ]
        },
        "record-literal": {
            "comment": "record literal .{ x := 1, y := 2 }",
            "name": "meta.record-literal.musi",
            "begin": "\\.\\{",
            "end": "\\}",
            "beginCaptures": { "0": { "name": "punctuation.section.record.begin.musi" } },
            "endCaptures": { "0": { "name": "punctuation.section.record.end.musi" } },
            "patterns": [
                { "include": "#comments" },
                { "include": "#record-literal" },
                { "include": "#let-definition" },
                { "include": "#keywords" },
                { "include": "#literals" },
                { "include": "#types" },
                { "include": "#operators" },
                { "include": "#punctuation" },
                { "include": "#identifiers" }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.documentation.module.musi",
                    "match": "//!.*$"
                },
                {
                    "name": "comment.line.documentation.musi",
                    "match": "///.*$"
                },
                {
                    "name": "comment.line.double-slash.musi",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.musi",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [ { "include": "#comments" } ]
                }
            ]
        },
        "attributes": {
            "name": "meta.attribute.musi",
            "begin": "#\\[",
            "end": "\\]",
            "beginCaptures": { "0": { "name": "punctuation.definition.attribute.begin.musi" } },
            "endCaptures": { "0": { "name": "punctuation.definition.attribute.end.musi" } },
            "patterns": [
                { "include": "#comments" },
                { "include": "#literals" },
                {
                    "comment": "well-known attribute names",
                    "match": "\\b(test|lang|inline|link)\\b",
                    "name": "support.function.attribute.musi"
                },
                {
                    "comment": "named attribute arg: key := value",
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`)\\s*(:=)",
                    "captures": {
                        "1": { "name": "variable.parameter.attribute.musi" },
                        "2": { "name": "keyword.operator.assignment.musi" }
                    }
                },
                {
                    "comment": "attribute name before (, , or ]",
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`)(?=\\s*[,\\]\\(])",
                    "name": "entity.name.attribute.musi"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.musi",
                    "match": "\\b(if|match|in|return|defer|where|try|need|handle|resume|fatal)\\b"
                },
                {
                    "name": "keyword.control.import.musi",
                    "match": "\\b(import|as)\\b"
                },
                {
                    "name": "keyword.control.export.musi",
                    "match": "\\b(export)\\b"
                },
                {
                    "name": "storage.type.musi",
                    "match": "\\b(let|class|instance|record|effect|choice|foreign|law)\\b"
                },
                {
                    "name": "keyword.other.musi",
                    "match": "\\b(of|with|via)\\b"
                },
                {
                    "name": "storage.modifier.musi",
                    "match": "\\bmut\\b"
                },
                {
                    "name": "keyword.operator.logical.musi",
                    "match": "\\b(and|or|xor|not)\\b"
                }
            ]
        },
        "literals": {
            "patterns": [
                { "include": "#template-string" },
                { "include": "#string" },
                { "include": "#rune" },
                { "include": "#numeric" },
                {
                    "name": "constant.language.musi",
                    "match": "\\b([sS]elf)\\b"
                }
            ]
        },
        "template-string": {
            "comment": "f\"hello {name}!\" -- interpolated string with scoped { } delimiters",
            "name": "string.template.musi",
            "begin": "(f)(\")",
            "end": "\"",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.string.template.musi" },
                "2": { "name": "punctuation.definition.string.begin.musi" }
            },
            "endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
            "patterns": [
                {
                    "comment": "interpolation hole: { expr }",
                    "name": "meta.embedded.expression.musi",
                    "begin": "\\{",
                    "end": "\\}",
                    "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
                    "endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
                    "patterns": [ { "include": "$self" } ]
                },
                {
                    "name": "constant.character.escape.musi",
                    "match": "\\\\."
                }
            ]
        },
        "string": {
            "name": "string.quoted.double.musi",
            "begin": "\"",
            "end": "\"",
            "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
            "endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
            "patterns": [
                {
                    "name": "constant.character.escape.musi",
                    "match": "\\\\."
                }
            ]
        },
        "rune": {
            "patterns": [
                {
                    "comment": "rune literal: 'a', '\\n' -- closing ' required so 'T type vars are not consumed",
                    "name": "string.quoted.single.musi",
                    "match": "'(?:[^'\\\\\\n]|\\\\.)'",
                    "captures": { "0": { "name": "string.quoted.single.musi" } }
                }
            ]
        },
        "numeric": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.musi",
                    "match": "\\b0[xX][0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.musi",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.musi",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.float.musi",
                    "match": "\\b[0-9_]+\\.[0-9_]+([eE][+-]?[0-9_]+)?\\b"
                },
                {
                    "name": "constant.numeric.decimal.musi",
                    "match": "\\b[0-9_]+\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "comment": "type variable 'T, 'E -- must precede other type rules to avoid being eaten as rune",
                    "match": "'[a-zA-Z_][a-zA-Z0-9_]*",
                    "name": "entity.name.type.parameter.musi"
                },
                {
                    "comment": "type name directly followed by [ -- e.g. Option[Int] outside annotation context",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*(?=\\[)",
                    "name": "entity.name.type.musi"
                },
                {
                    "comment": "plain type name (no type params): Int, String, Bool, etc.",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
                    "name": "entity.name.type.musi"
                },
                { "include": "#type-params" }
            ]
        },
        "type-params": {
            "comment": "type parameter list: ['T, 'E] or [Int, String] -- [ followed by letter or ' avoids matching array subscripts with numbers",
            "name": "meta.type.parameters.musi",
            "begin": "\\[(?=\\s*[a-zA-Z'])",
            "end": "\\]",
            "beginCaptures": { "0": { "name": "punctuation.definition.type-params.begin.musi" } },
            "endCaptures": { "0": { "name": "punctuation.definition.type-params.end.musi" } },
            "patterns": [
                {
                    "match": "'[a-zA-Z_][a-zA-Z0-9_]*",
                    "name": "entity.name.type.parameter.musi"
                },
                {
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
                    "name": "entity.name.type.musi"
                },
                { "include": "#type-params" },
                { "include": "#numeric" },
                { "include": "#punctuation" }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.musi",
                    "match": ":=|<-"
                },
                {
                    "name": "keyword.operator.subtype.musi",
                    "match": "<:|:>"
                },
                {
                    "name": "keyword.operator.comparison.musi",
                    "match": "<=|>=|/=|<|>|="
                },
                {
                    "comment": "effectful arrow ~> must precede -> for maximal munch",
                    "name": "keyword.operator.arrow.effectful.musi",
                    "match": "~>"
                },
                {
                    "name": "keyword.operator.arrow.musi",
                    "match": "->|=>"
                },
                {
                    "comment": "spread/splat: ...expr",
                    "name": "keyword.operator.spread.musi",
                    "match": "\\.\\.\\."
                },
                {
                    "comment": "range operators: .. and ..<",
                    "name": "keyword.operator.range.musi",
                    "match": "\\.\\.<|\\.\\.(?=[^\\.])"
                },
                {
                    "comment": "force unwrap !! and forced unwrap field access !.",
                    "name": "keyword.operator.force.musi",
                    "match": "\\!\\!|\\!\\."
                },
                {
                    "comment": "optional chaining ?. and nil coalescing ??",
                    "name": "keyword.operator.optional.musi",
                    "match": "\\?\\.|\\?\\?"
                },
                {
                    "comment": "type cast :?> must precede type test :?",
                    "name": "keyword.operator.typecheck.musi",
                    "match": ":\\?>|:\\?"
                },
                {
                    "name": "keyword.operator.cons.musi",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.bitwise.musi",
                    "match": "<<|>>"
                },
                {
                    "name": "keyword.operator.arithmetic.musi",
                    "match": "[+\\-*/%]"
                },
                {
                    "comment": "array index compound token: .[ as in arr.[0]",
                    "name": "meta.index.musi",
                    "begin": "\\.\\[",
                    "end": "\\]",
                    "beginCaptures": { "0": { "name": "punctuation.section.index.begin.musi" } },
                    "endCaptures": { "0": { "name": "punctuation.section.index.end.musi" } },
                    "patterns": [
                        { "include": "#comments" },
                        { "include": "#record-literal" },
                        { "include": "#keywords" },
                        { "include": "#literals" },
                        { "include": "#types" },
                        { "include": "#operators" },
                        { "include": "#punctuation" },
                        { "include": "#identifiers" }
                    ]
                },
                {
                    "comment": "field access dot -- must not match .. range, .[ index, or .{ record",
                    "name": "keyword.operator.access.musi",
                    "match": "\\.(?![.\\[{])"
                },
                {
                    "comment": "pipe operator |>",
                    "name": "keyword.operator.pipe.musi",
                    "match": "\\|>"
                },
                {
                    "comment": "bang ! (not !! or !.) and bar |",
                    "name": "keyword.operator.other.musi",
                    "match": "!(?![!.])|\\|"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.statement.musi",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.comma.musi",
                    "match": ","
                },
                {
                    "name": "punctuation.separator.colon.musi",
                    "match": ":"
                },
                {
                    "name": "punctuation.section.brackets.begin.musi",
                    "match": "\\["
                },
                {
                    "name": "punctuation.section.brackets.end.musi",
                    "match": "\\]"
                },
                {
                    "name": "punctuation.section.block.begin.musi",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.section.block.end.musi",
                    "match": "\\}"
                },
                {
                    "name": "punctuation.section.parens.begin.musi",
                    "match": "\\("
                },
                {
                    "name": "punctuation.section.parens.end.musi",
                    "match": "\\)"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "match": "\\b_\\b",
                    "name": "constant.language.wildcard.musi"
                },
                {
                    "match": "`[^`]+`",
                    "name": "variable.other.escaped.musi"
                },
                {
                    "comment": "function/method call site -- lowercase identifier directly before ( (no space); UpperCamelCase before ( is a variant constructor or type application",
                    "match": "([a-z_][a-zA-Z0-9_]*)(?=\\()",
                    "name": "entity.name.function.call.musi"
                },
                {
                    "comment": "UpperCamelCase -- type name or variant constructor at use site",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
                    "name": "entity.name.type.musi"
                },
                {
                    "comment": "lowercase identifier -- value binding, parameter, or local variable",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b",
                    "name": "variable.other.musi"
                }
            ]
        }
    }
}
