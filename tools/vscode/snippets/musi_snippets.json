{
	"Function Definition": {
		"prefix": "fn",
		"body": [
			"fn ${1:name}(${2:param}: ${3:Int}): ${4:Unit} {",
			"\t$0",
			"}"
		],
		"description": "Named function definition"
	},
	"Generic Function": {
		"prefix": "fn-generic",
		"body": [
			"fn ${1:name}['${2:T}](${3:x}: '${2:T}): ${4:'${2:T}} {",
			"\t$0",
			"}"
		],
		"description": "Generic function with type parameters"
	},
	"Lambda": {
		"prefix": "lambda",
		"body": [
			"fn(${1:x}: ${2:Int}): ${3:Int} => ${0:body}"
		],
		"description": "Anonymous lambda expression"
	},
	"Const Binding": {
		"prefix": "const",
		"body": [
			"const ${1:name} := ${0:value};"
		],
		"description": "Immutable binding"
	},
	"Var Binding": {
		"prefix": "var",
		"body": [
			"var ${1:name} := ${0:value};"
		],
		"description": "Mutable binding"
	},
	"Record": {
		"prefix": "record",
		"body": [
			"record ${1:Name} {",
			"\t${2:field}: ${3:Int},",
			"\t$0",
			"}"
		],
		"description": "Record type definition"
	},
	"Record (generic)": {
		"prefix": "record-generic",
		"body": [
			"record ${1:Name}['${2:T}] {",
			"\t${3:field}: '${2:T},",
			"\t$0",
			"}"
		],
		"description": "Generic record type definition"
	},
	"Choice": {
		"prefix": "choice",
		"body": [
			"choice ${1:Name} {",
			"\t${2:VariantA}(${3:Int})",
			"\t| ${4:VariantB}",
			"}"
		],
		"description": "Choice (sum) type definition"
	},
	"Choice (generic)": {
		"prefix": "choice-generic",
		"body": [
			"choice ${1:Name}['${2:T}] {",
			"\t${3:Left}('${2:T})",
			"\t| ${4:Right}",
			"}"
		],
		"description": "Generic choice type definition"
	},
	"If Then Else": {
		"prefix": "if",
		"body": [
			"if ${1:condition} then",
			"\t${2:value}",
			"else",
			"\t${0:other}"
		],
		"description": "If/then/else expression"
	},
	"If Then Else (block)": {
		"prefix": "if-block",
		"body": [
			"if ${1:condition} then (",
			"\t${2:body}",
			") else (",
			"\t${0:other}",
			")"
		],
		"description": "If/then/else with block bodies"
	},
	"If Case": {
		"prefix": "if-case",
		"body": [
			"if case .${1:Some}(${2:v}) := ${3:expr} then",
			"\t${0:body}",
			"else",
			"\t${4:fallback}"
		],
		"description": "If-case destructuring pattern match"
	},
	"Match": {
		"prefix": "match",
		"body": [
			"match ${1:expr} with",
			"| .${2:Some}(${3:v}) => ${4:v}",
			"| .${5:None} => ${0:default}"
		],
		"description": "Match expression with two arms"
	},
	"Match (multi-arm)": {
		"prefix": "match-multi",
		"body": [
			"match ${1:expr} with",
			"| .${2:First}(${3:v}) => ${4:body}",
			"| .${5:Second}(${6:v}) => ${7:body}",
			"| .${8:Third} => ${0:body}"
		],
		"description": "Match expression with three arms"
	},
	"For Loop": {
		"prefix": "for",
		"body": [
			"for ${1:x} in ${2:collection} loop",
			"\t$0"
		],
		"description": "For-in loop"
	},
	"While Loop": {
		"prefix": "while",
		"body": [
			"while ${1:condition} loop",
			"\t$0"
		],
		"description": "While loop"
	},
	"While Case": {
		"prefix": "while-case",
		"body": [
			"while case .${1:Some}(${2:v}) := ${3:expr} loop",
			"\t$0"
		],
		"description": "While-case destructuring loop"
	},
	"Import": {
		"prefix": "import",
		"body": [
			"import { ${1:name} } from \"${2:std/${3:module}}\";"
		],
		"description": "Import statement"
	},
	"Export Function": {
		"prefix": "export-fn",
		"body": [
			"export fn ${1:name}(${2:param}: ${3:Int}): ${4:Unit} {",
			"\t$0",
			"}"
		],
		"description": "Exported function definition"
	},
	"Type Class": {
		"prefix": "class",
		"body": [
			"class ${1:Name}['${2:T}] {",
			"\tfn ${3:method}(${4:a}: '${2:T}): ${5:Bool};",
			"}"
		],
		"description": "Type class definition"
	},
	"Given (type class instance)": {
		"prefix": "given",
		"body": [
			"given ${1:ClassName}[${2:Type}] {",
			"\tfn ${3:method}(${4:a}: ${2:Type}): ${5:Bool} {",
			"\t\t$0",
			"\t}",
			"}"
		],
		"description": "Type class instance"
	},
	"Option Some": {
		"prefix": "option-some",
		"body": [
			".Some(${0:value})"
		],
		"description": ".Some(value) constructor"
	},
	"Option None": {
		"prefix": "option-none",
		"body": [
			".None"
		],
		"description": ".None constructor"
	},
	"Expect Pass": {
		"prefix": "expect-pass",
		"body": [
			".Pass(${0:value})"
		],
		"description": ".Pass(value) constructor"
	},
	"Expect Fail": {
		"prefix": "expect-fail",
		"body": [
			".Fail(${0:error})"
		],
		"description": ".Fail(error) constructor"
	},
	"Array Literal": {
		"prefix": "array",
		"body": [
			"[${1:1}, ${2:2}, ${3:3}]"
		],
		"description": "Array literal"
	},
	"Record Literal": {
		"prefix": "rec-lit",
		"body": [
			"${1:Type}.{ ${2:field} := ${3:value} }"
		],
		"description": "Record literal with named fields"
	},
	"Record Update (spread)": {
		"prefix": "rec-update",
		"body": [
			"${1:Type}.{ <..${2:base}, ${3:field} := ${0:value} }"
		],
		"description": "Functional record update using spread"
	},
	"Test Function": {
		"prefix": "test",
		"body": [
			"#[test]",
			"fn ${1:test_name}(): Unit {",
			"\t$0",
			"}"
		],
		"description": "Test function with #[test] attribute"
	},
	"Doc Comment": {
		"prefix": "doc",
		"body": [
			"/// ${0:Description}"
		],
		"description": "Documentation comment"
	},
	"Writeln": {
		"prefix": "writeln",
		"body": [
			"writeln(${0:\"hello\"});"
		],
		"description": "Write string with newline to stdout"
	},
	"Nil Coalesce": {
		"prefix": "nil-coalesce",
		"body": [
			"${1:expr} ?? ${0:default}"
		],
		"description": "Nil-coalesce operator (??) for Option"
	},
	"Optional Chaining": {
		"prefix": "opt-chain",
		"body": [
			"${1:expr}?.${0:field}"
		],
		"description": "Optional chaining (?.) for Option"
	},
	"Extrin Function": {
		"prefix": "extrin-fn",
		"body": [
			"#[intrinsic(\"${1:name}\")]",
			"extrin fn ${2:name}(${3:param}: ${4:Int}): ${5:Int};"
		],
		"description": "Extrinsic (intrinsic-linked) function"
	}
}
