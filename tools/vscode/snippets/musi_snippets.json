{
	"Function Definition": {
		"prefix": "fn",
		"body": [
			"let ${1:name} := (${2:param}: ${3:Int}) => (",
			"\t$0",
			");"
		],
		"description": "Named function definition"
	},
	"Generic Function": {
		"prefix": "fn-generic",
		"body": [
			"let ${1:name} ['${2:T}] : ('${2:T}) -> '${2:T} := (${3:x}) => ${0:x};"
		],
		"description": "Generic function with type parameters"
	},
	"Lambda": {
		"prefix": "lambda",
		"body": [
			"(${1:x}: ${2:Int}) => ${0:body}"
		],
		"description": "Anonymous lambda expression"
	},
	"Let Binding": {
		"prefix": "let",
		"body": [
			"let ${1:name} := ${0:value};"
		],
		"description": "Immutable binding"
	},
	"Mutable Binding": {
		"prefix": "letm",
		"body": [
			"let mut ${1:name} := ${0:value};"
		],
		"description": "Mutable binding with let mut"
	},
	"Choice": {
		"prefix": "choice",
		"body": [
			"let ${1:Name} := choice { ${2:VariantA} + ${3:VariantB} };"
		],
		"description": "Choice (sum) type definition"
	},
	"Choice (generic)": {
		"prefix": "choice-generic",
		"body": [
			"let ${1:Name} ['${2:T}] := choice { ${3:Some} of '${2:T} + ${4:None} };"
		],
		"description": "Generic choice type definition"
	},
	"Piecewise (if)": {
		"prefix": "if",
		"body": [
			"(${1:value} if ${2:condition}",
			"| ${0:other} if _)"
		],
		"description": "Piecewise expression (conditional)"
	},
	"Piecewise (block)": {
		"prefix": "if-block",
		"body": [
			"(",
			"\t${1:value} if ${2:condition}",
			"\t| ${0:other} if _",
			")"
		],
		"description": "Piecewise expression with block layout"
	},
	"Match": {
		"prefix": "match",
		"body": [
			"match ${1:expr} (",
			"\t.${2:Some}(${3:v}) => ${4:v}",
			"\t| .${5:None} => ${0:default}",
			")"
		],
		"description": "Match expression with two arms"
	},
	"Match (multi-arm)": {
		"prefix": "match-multi",
		"body": [
			"match ${1:expr} (",
			"\t.${2:First}(${3:v}) => ${4:body}",
			"\t| .${5:Second}(${6:v}) => ${7:body}",
			"\t| .${8:Third} => ${0:body}",
			")"
		],
		"description": "Match expression with three arms"
	},
	"Import": {
		"prefix": "import",
		"body": [
			"import \"${1:@std/module}\" as ${0:name};"
		],
		"description": "Import statement"
	},
	"Export Function": {
		"prefix": "export-fn",
		"body": [
			"export let ${1:name} := (${2:param}: ${3:Int}) => (",
			"\t$0",
			");"
		],
		"description": "Exported function definition"
	},
	"Type Class": {
		"prefix": "class",
		"body": [
			"class ${1:Name} over '${2:T} {",
			"\tlet ${3:method}(a: '${2:T}) : ${4:Bool};",
			"};"
		],
		"description": "Type class definition"
	},
	"Instance (type class instance)": {
		"prefix": "instance",
		"body": [
			"instance ${1:ClassName} of ${2:Type} {",
			"\tlet ${3:method}(a: ${2:Type}) : ${4:Bool} := (",
			"\t\t$0",
			"\t);",
			"};"
		],
		"description": "Type class instance"
	},
	"Option Some": {
		"prefix": "option-some",
		"body": [
			".Some(${0:value})"
		],
		"description": ".Some(value) constructor"
	},
	"Option None": {
		"prefix": "option-none",
		"body": [
			".None"
		],
		"description": ".None constructor"
	},
	"Expect Pass": {
		"prefix": "expect-pass",
		"body": [
			".Pass(${0:value})"
		],
		"description": ".Pass(value) constructor"
	},
	"Expect Fail": {
		"prefix": "expect-fail",
		"body": [
			".Fail(${0:error})"
		],
		"description": ".Fail(error) constructor"
	},
	"Array Literal": {
		"prefix": "array",
		"body": [
			"[${1:1}, ${2:2}, ${3:3}]"
		],
		"description": "Array literal"
	},
	"Record Literal": {
		"prefix": "rec-lit",
		"body": [
			"${1:Type}.{ ${2:field} := ${3:value} }"
		],
		"description": "Record literal with named fields"
	},
	"Record Update (spread)": {
		"prefix": "rec-update",
		"body": [
			"${1:Type}.{ <..${2:base}, ${3:field} := ${0:value} }"
		],
		"description": "Functional record update using spread"
	},
	"Test Function": {
		"prefix": "test",
		"body": [
			"#[test]",
			"let ${1:test_name} := () => (",
			"\t$0",
			");"
		],
		"description": "Test function with #[test] attribute"
	},
	"Doc Comment": {
		"prefix": "doc",
		"body": [
			"/// ${0:Description}"
		],
		"description": "Documentation comment"
	},
	"Writeln": {
		"prefix": "writeln",
		"body": [
			"writeln(${0:\"hello\"});"
		],
		"description": "Write string with newline to stdout"
	},
	"Nil Coalesce": {
		"prefix": "nil-coalesce",
		"body": [
			"${1:expr} ?? ${0:default}"
		],
		"description": "Nil-coalesce operator (??) for Option"
	},
	"Optional Chaining": {
		"prefix": "opt-chain",
		"body": [
			"${1:expr}?.${0:field}"
		],
		"description": "Optional chaining (?.) for Option"
	},
	"Record Definition": {
		"prefix": "record",
		"body": [
			"let ${1:Name} := record {",
			"\t${2:field}: ${0:Type},",
			"};"
		],
		"description": "Record type definition"
	},
	"Effect Definition": {
		"prefix": "effect",
		"body": [
			"let ${1:Name} := effect {",
			"\tlet ${2:op}(${3:param}: ${4:Type}) : ${0:ReturnType};",
			"};"
		],
		"description": "Effect type definition"
	},
	"Describe Block": {
		"prefix": "describe",
		"body": [
			"describe(\"${1:module}\", () => (",
			"\tit(\"${2:should do something}\", () => ${0:pass})",
			"));"
		],
		"description": "Test describe block"
	},
	"It Block": {
		"prefix": "it",
		"body": [
			"it(\"${1:should do something}\", () => ${0:pass});"
		],
		"description": "Test it block"
	},
	"Expect": {
		"prefix": "expect",
		"body": [
			"to_be(${1:actual}, ${0:expected});"
		],
		"description": "Integer equality matcher"
	},
	"Handle Effect": {
		"prefix": "handle",
		"body": [
			"handle ${1:expr} with ${2:Effect} {",
			"\tlet ${3:op}(${4:arg}) := resume ${0:result};",
			"}"
		],
		"description": "Effect handler with resume"
	}
}
