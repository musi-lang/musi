{
    "Function": {
        "prefix": "fn",
        "body": [
            "${1:name}(${2:params}): ${3:Type} => ${4:expr}"
        ],
        "description": "Function declaration"
    },
    "Anonymous Function": {
        "prefix": "lambda",
        "body": [
            "(${1:params}) => ${2:expr}"
        ],
        "description": "Anonymous function"
    },
    "Val Binding": {
        "prefix": "val",
        "body": [
            "val ${1:name}: ${2:Type} := ${3:value}"
        ],
        "description": "Immutable value binding"
    },
    "Var Binding": {
        "prefix": "var",
        "body": [
            "var ${1:name}: ${2:Type} := ${3:value}"
        ],
        "description": "Mutable variable binding"
    },
    "Record": {
        "prefix": "record",
        "body": [
            "record ${1:Name} {",
            "\t${2:field}: ${3:Type}",
            "};"
        ],
        "description": "Record type declaration"
    },
    "Record with Type Parameters": {
        "prefix": "recordt",
        "body": [
            "record ${1:Name}[${2:T}] {",
            "\t${3:field}: ${4:Type}",
            "};"
        ],
        "description": "Generic record type"
    },
    "Choice": {
        "prefix": "choice",
        "body": [
            "choice ${1:Name} {",
            "\t${2:Variant}(${3:Type}),",
            "\t${4:Variant}",
            "};"
        ],
        "description": "Choice type declaration"
    },
    "Choice with Type Parameters": {
        "prefix": "choicet",
        "body": [
            "choice ${1:Name}[${2:T}] {",
            "\t${3:Variant}(${4:Type}),",
            "\t${5:Variant}",
            "};"
        ],
        "description": "Generic choice type"
    },
    "Interface": {
        "prefix": "interface",
        "body": [
            "interface ${1:Name} {",
            "\t${2:method}: ${3:Type}",
            "};"
        ],
        "description": "Interface declaration"
    },
    "If Expression": {
        "prefix": "if",
        "body": [
            "if ${1:condition} {",
            "\t${2:expr}",
            "};"
        ],
        "description": "If expression"
    },
    "If-Else Expression": {
        "prefix": "ife",
        "body": [
            "if ${1:condition} {",
            "\t${2:expr}",
            "} else {",
            "\t${3:expr}",
            "};"
        ],
        "description": "If-else expression"
    },
    "If Pattern Match": {
        "prefix": "ifp",
        "body": [
            "if ${1:pattern} := ${2:expr} {",
            "\t${3:body}",
            "};"
        ],
        "description": "If with pattern matching"
    },
    "Match Expression": {
        "prefix": "match",
        "body": [
            "match ${1:expr} {",
            "\t${2:pattern} => ${3:expr},",
            "\t_ => ${4:expr}",
            "};"
        ],
        "description": "Match expression"
    },
    "For Loop": {
        "prefix": "for",
        "body": [
            "for ${1:item} in ${2:iterable} {",
            "\t${3:body}",
            "};"
        ],
        "description": "For loop"
    },
    "For Loop with Guard": {
        "prefix": "forg",
        "body": [
            "for ${1:item} in ${2:iterable} if ${3:condition} {",
            "\t${4:body}",
            "};"
        ],
        "description": "For loop with guard"
    },
    "For Loop with Label": {
        "prefix": "forl",
        "body": [
            "#${1:label} for ${2:item} in ${3:iterable} {",
            "\t${4:body}",
            "};"
        ],
        "description": "Labeled for loop"
    },
    "While Loop": {
        "prefix": "while",
        "body": [
            "while ${1:condition} {",
            "\t${2:body}",
            "};"
        ],
        "description": "While loop"
    },
    "While Loop with Label": {
        "prefix": "whilel",
        "body": [
            "#${1:label} while ${2:condition} {",
            "\t${3:body}",
            "};"
        ],
        "description": "Labeled while loop"
    },
    "Import": {
        "prefix": "import",
        "body": [
            "import {${1:items}} from \"${2:module}\";"
        ],
        "description": "Import statement"
    },
    "Import Native": {
        "prefix": "importn",
        "body": [
            "import native {${1:items}} from \"${2:module}\";"
        ],
        "description": "Native import statement"
    },
    "Export": {
        "prefix": "export",
        "body": [
            "export {${1:items}};"
        ],
        "description": "Export statement"
    },
    "Export From": {
        "prefix": "exportf",
        "body": [
            "export {${1:items}} from \"${2:module}\";"
        ],
        "description": "Re-export statement"
    },
    "Attribute": {
        "prefix": "attr",
        "body": [
            "@[${1:name}]"
        ],
        "description": "Attribute"
    },
    "Attribute with Arguments": {
        "prefix": "attra",
        "body": [
            "@[${1:name}(${2:args})]"
        ],
        "description": "Attribute with arguments"
    },
    "Record Literal": {
        "prefix": "rec",
        "body": [
            ".{${1:field} := ${2:value}}"
        ],
        "description": "Record literal"
    },
    "Record Literal with Spread": {
        "prefix": "recw",
        "body": [
            ".{${1:expr} with ${2:field} := ${3:value}}"
        ],
        "description": "Record literal with 'with'"
    },
    "Array Literal": {
        "prefix": "arr",
        "body": [
            "[${1:items}]"
        ],
        "description": "Array literal"
    },
    "Template String": {
        "prefix": "tpl",
        "body": [
            "$\"${1:text} \\{${2:expr}}${3:text}\""
        ],
        "description": "Template string"
    },
    "Unsafe Block": {
        "prefix": "unsafe",
        "body": [
            "unsafe {",
            "\t${1:expr}",
            "};"
        ],
        "description": "Unsafe block"
    },
    "Defer": {
        "prefix": "defer",
        "body": [
            "defer ${1:expr};"
        ],
        "description": "Defer statement"
    },
    "Return": {
        "prefix": "ret",
        "body": [
            "return ${1:expr};"
        ],
        "description": "Return statement"
    },
    "Break": {
        "prefix": "break",
        "body": [
            "break ${1:#label};"
        ],
        "description": "Break statement"
    },
    "Cycle": {
        "prefix": "cycle",
        "body": [
            "cycle ${1:#label};"
        ],
        "description": "Cycle (continue) statement"
    },
    "Pattern Match Case": {
        "prefix": "case",
        "body": [
            "${1:pattern} => ${2:expr},"
        ],
        "description": "Match case arm"
    },
    "Pattern Match Case with Guard": {
        "prefix": "caseg",
        "body": [
            "${1:pattern} if ${2:condition} => ${3:expr},"
        ],
        "description": "Match case with guard"
    },
    "Comment Block": {
        "prefix": "/*",
        "body": [
            "/*",
            " * ${1:comment}",
            " */"
        ],
        "description": "Block comment"
    },
    "Doc Comment": {
        "prefix": "/**",
        "body": [
            "/**",
            " * ${1:documentation}",
            " */"
        ],
        "description": "Documentation comment"
    }
}
