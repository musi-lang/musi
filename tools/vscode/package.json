{
	"name": "vscode-musi",
	"type": "module",
	"displayName": "Musi",
	"description": "Musi language support",
	"version": "0.1.0",
	"author": {
		"name": "xsyetopz"
	},
	"license": "MIT",
	"private": true,
	"publisher": "xsyetopz",
	"homepage": "https://github.com/musi-lang/musi",
	"repository": {
		"type": "git",
		"url": "https://github.com/musi-lang/musi.git"
	},
	"bugs": {
		"url": "https://github.com/musi-lang/musi/issues"
	},
	"keywords": [
		"Musi"
	],
	"categories": [
		"Formatters",
		"Linters",
		"Programming Languages"
	],
	"icon": "logo.png",
	"galleryBanner": {
		"color": "#cc0000",
		"theme": "dark"
	},
	"readme": "README.md",
	"main": "./dist/extension.js",
	"engines": {
		"vscode": "^1.75.0"
	},
	"contributes": {
		"languages": [
			{
				"id": "musi",
				"aliases": [
					"Musi",
					"musi"
				],
				"extensions": [
					".ms"
				],
				"configuration": "language-configuration.json",
				"icon": {
					"light": "logo.png",
					"dark": "logo.png"
				}
			},
			{
				"id": "musi-injection",
				"aliases": [
					"musi-inj"
				]
			}
		],
		"grammars": [
			{
				"language": "musi",
				"scopeName": "source.musi",
				"path": "syntaxes/musi.tmLanguage.json"
			},
			{
				"language": "musi-injection",
				"path": "syntaxes/musi_codeblock.tmLanguage.json",
				"scopeName": "markdown.musi.codeblock",
				"injectTo": [
					"text.html.markdown"
				],
				"embeddedLanguages": {
					"meta.embedded.block.musi": "musi"
				}
			}
		],
		"snippets": [
			{
				"language": "musi",
				"path": "snippets/musi_snippets.json"
			}
		],
		"semanticTokenScopes": [
			{
				"language": "musi",
				"scopes": {
					"variable.readonly": ["variable.other.constant.musi"],
					"variable.declaration.readonly": ["variable.other.constant.musi"],
					"variable.mutable": ["variable.other.musi"],
					"variable.declaration.mutable": ["variable.other.musi"],
					"parameter.readonly": ["variable.other.constant.musi"],
					"parameter.declaration.readonly": ["variable.other.constant.musi"],
					"parameter.mutable": ["variable.parameter.musi"],
					"parameter.declaration.mutable": ["variable.parameter.musi"],
					"property.readonly": ["variable.other.constant.property.musi"],
					"property.declaration.readonly": ["variable.other.constant.property.musi"],
					"property.mutable": ["variable.other.property.musi"],
					"property.declaration.mutable": ["variable.other.property.musi"],
					"property": ["variable.other.property.musi"],
					"property.declaration": ["variable.other.property.musi"],
					"function": ["entity.name.function.musi"],
					"function.declaration": ["entity.name.function.musi"],
					"type": ["entity.name.type.musi"],
					"type.declaration": ["entity.name.type.musi"],
					"enumMember": ["variable.other.enummember.musi"],
					"enumMember.declaration": ["variable.other.enummember.musi"]
				}
			}
		],
		"commands": [
			{
				"command": "musi.restartServer",
				"title": "Restart Language Server",
				"category": "Musi",
				"icon": "$(refresh)"
			},
			{
				"command": "musi.stopServer",
				"title": "Stop Language Server",
				"category": "Musi",
				"icon": "$(stop)"
			},
			{
				"command": "musi.showLogs",
				"title": "Show Language Server Output",
				"category": "Musi",
				"icon": "$(output)"
			}
		],
		"keybindings": [
			{
				"command": "musi.restartServer",
				"key": "ctrl+shift+R",
				"mac": "cmd+shift+R",
				"when": "editorLangId == musi"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "musi.restartServer",
					"when": "true"
				}
			],
			"view/item/context": [
				{
					"command": "musi.restartServer",
					"when": "view == workbench.explorer.fileView",
					"group": "musi@1"
				}
			]
		},
		"configuration": {
			"title": "Musi",
			"properties": {
				"musi.server.path": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"markdownDescription": "Path to `musi_lsp` binary. If not set, searches in `target/debug`, `target/release`, and `PATH`."
				},
				"musi.runtime.path": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"markdownDescription": "Path to Musi runtime environment. Required for code execution and some diagnostics."
				},
				"musi.trace.server": {
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "Traces communication between VS Code and language server."
				},
				"musi.diagnostics.enable": {
					"type": "boolean",
					"default": true,
					"description": "Enable/disable diagnostics from language server."
				},
				"musi.inlayHints.enable": {
					"type": "boolean",
					"default": true,
					"description": "Enable/disable inlay hints."
				},
				"musi.completion.enable": {
					"type": "boolean",
					"default": true,
					"description": "Enable/disable code completion."
				},
				"musi.formatting.enable": {
					"type": "boolean",
					"default": true,
					"description": "Enable/disable code formatting."
				},
				"musi.formatting.indentSize": {
					"type": "number",
					"default": 2,
					"description": "Number of spaces for indentation."
				}
			}
		}
	},
	"scripts": {
		"build": "bun build ./client/src/main.ts --outfile=./dist/extension.js --external vscode --target=node",
		"package": "bun run build && vsce package",
		"vscode:prepublish": "bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@types/bun": "^1.3.5",
		"@types/node": "^25.0.3",
		"@types/vscode": "^1.75.0",
		"@vscode/vsce": "^3.7.1",
		"npm": "^11.7.0",
		"typescript": "^5.9.3",
		"vscode-languageclient": "^9.0.1"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"@vscode/vsce-sign",
		"keytar"
	]
}
