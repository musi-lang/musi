{
	"name": "vscode-musi",
	"type": "module",
	"displayName": "Musi",
	"description": "Musi language support",
	"version": "0.1.0",
	"author": {
		"name": "xsyetopz"
	},
	"license": "MIT",
	"private": true,
	"publisher": "xsyetopz",
	"homepage": "https://github.com/musi-lang/musi",
	"repository": {
		"type": "git",
		"url": "https://github.com/musi-lang/musi.git"
	},
	"bugs": {
		"url": "https://github.com/musi-lang/musi/issues"
	},
	"keywords": [
		"Musi"
	],
	"categories": [
		"Formatters",
		"Linters",
		"Programming Languages"
	],
	"icon": "logo.png",
	"galleryBanner": {
		"color": "#cc0000",
		"theme": "dark"
	},
	"readme": "README.md",
	"main": "./dist/extension.js",
	"engines": {
		"vscode": "^1.75.0"
	},
	"contributes": {
		"languages": [
			{
				"id": "musi",
				"aliases": [
					"Musi",
					"musi"
				],
				"extensions": [
					".ms"
				],
				"configuration": "language-configuration.json",
				"icon": {
					"light": "logo.png",
					"dark": "logo.png"
				}
			},
			{
				"id": "musi-injection",
				"aliases": [
					"musi-inj"
				]
			}
		],
		"grammars": [
			{
				"language": "musi",
				"scopeName": "source.musi",
				"path": "syntaxes/musi.tmLanguage.json"
			},
			{
				"language": "musi-injection",
				"path": "syntaxes/musi_codeblock.tmLanguage.json",
				"scopeName": "markdown.musi.codeblock",
				"injectTo": [
					"text.html.markdown"
				],
				"embeddedLanguages": {
					"meta.embedded.block.musi": "musi"
				}
			}
		],
		"snippets": [
			{
				"language": "musi",
				"path": "snippets/musi_snippets.json"
			}
		]
	},
	"scripts": {
		"build": "bun build ./src/extension.ts --outfile=./dist/extension.js --external vscode --target=node",
		"package": "bun run build && vsce package",
		"vscode:prepublish": "bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@types/bun": "^1.3.5",
		"@types/node": "^25.0.3",
		"@types/vscode": "^1.75.0",
		"@vscode/vsce": "^3.7.1",
		"npm": "^11.7.0",
		"typescript": "^5.9.3",
		"vscode-languageclient": "^9.0.1"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"@vscode/vsce-sign",
		"keytar"
	]
}
