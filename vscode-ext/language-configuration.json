{
	"comments": {
		"lineComment": "//",
		"blockComment": ["/*", "*/"]
	},
	"brackets": [
		["{", "}"],
		["[", "]"],
		["(", ")"],
		[".{", "}"],
		[".[", "]"]
	],
	"autoClosingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "[", "close": "]" },
		{ "open": "(", "close": ")" },
		{ "open": ".{", "close": "}" },
		{ "open": ".[", "close": "]" },
		{ "open": "\"", "close": "\"", "notIn": ["string"] },
		{ "open": "'", "close": "'", "notIn": ["string"] }
	],
	"surroundingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "[", "close": "]" },
		{ "open": "(", "close": ")" },
		{ "open": "\"", "close": "\"" },
		{ "open": "'", "close": "'" }
	],
	"wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
	"folding": {
		"markers": {
			"start": "^\\s*\\{\\s*$",
			"end": "^\\s*\\}\\s*$"
		}
	}
}
