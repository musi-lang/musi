				},
				{
					"line": 1,
					"lexeme": "U",
					"scope": "entity.name.type.parameter.musi"
				}
			]
		},
		{
			"name": "nested generic type annotation",
			"source": "let run : Result[T] -> Option[U] := next;",
			"checks": [
				{
					"line": 0,
					"lexeme": "Result",
					"scope": "entity.name.type.musi"
				},
				{
					"line": 0,
					"lexeme": "T",
					"scope": "entity.name.type.parameter.musi"
				},
				{
					"line": 0,
					"lexeme": "Option",
					"scope": "entity.name.type.musi"
				},
				{
					"line": 0,
					"lexeme": "U",
					"occurrence": 1,
					"scope": "entity.name.type.parameter.musi"
				}
			]
		},
		{
			"name": "partial modifier declaration",
			"source": "partial let parsePort(text : String) : Int := 0;",
			"checks": [
				{
					"line": 0,
					"lexeme": "partial",
					"scope": "keyword.modifier.musi"
				},
				{
					"line": 0,
					"lexeme": "let",
					"scope": "keyword.declaration.musi"
				},
				{
					"line": 0,
					"lexeme": "parsePort",
					"scope": "entity.name.function.musi"
				}
			]
		},
		{
			"name": "dependent equivalence operator",
			"source": "let proof := left ~= right;",
			"checks": [
