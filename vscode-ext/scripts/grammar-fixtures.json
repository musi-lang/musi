				},
				{
					"line": 0,
					"lexeme": "U",
					"scope": "entity.name.type.parameter.musi"
				},
				{
					"line": 1,
					"lexeme": "T",
					"scope": "entity.name.type.parameter.musi"
				},
				{
					"line": 1,
					"lexeme": "~>",
