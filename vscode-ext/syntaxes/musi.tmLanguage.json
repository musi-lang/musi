					"begin": "/\\*",
					"end": "\\*/",
					"patterns": [
						{
							"include": "#comments"
						}
					]
				}
			]
		},
		"documentation-comments": {
			"patterns": [
				{
					"name": "meta.documentation.param.musi",
					"begin": "@(param(?:eter)?|arg(?:ument)?|property|var)\\b",
					"end": "(?=\\s*(?:@|\\*/|$))",
					"beginCaptures": {
