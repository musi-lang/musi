					"end": "$",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.documentation.musi"
						}
					},
					"patterns": [
						{
							"include": "#documentation-comments"
						}
					]
				},
				{
					"name": "comment.line.documentation.musi",
					"begin": "///",
					"end": "$",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.documentation.musi"
						}
					},
					"patterns": [
						{
							"include": "#documentation-comments"
						}
					]
				},
				{
					"name": "comment.block.documentation.musi",
					"begin": "/\\*\\*",
					"end": "\\*/",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.documentation.musi"
						}
					},
					"endCaptures": {
