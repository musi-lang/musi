							"name": "keyword.other.documentation.tag.musi"
						},
						"1": {
							"name": "keyword.other.documentation.tag.musi"
						}
					},
					"patterns": [
						{
							"name": "storage.type.documentation.musi",
							"match": "\\{[^}]+\\}"
						},
						{
							"name": "punctuation.separator.definition.documentation.musi",
							"match": ":="
						},
						{
							"name": "variable.parameter.documentation.musi",
							"match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?::=|$))"
