{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Musi",
	"scopeName": "source.musi",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#attributes" },
		{ "include": "#template-string" },
		{ "include": "#string" },
		{ "include": "#rune" },
		{ "include": "#numeric" },
		{ "include": "#fixity-declaration" },
		{ "include": "#quote" },
		{ "include": "#splices" },
		{ "include": "#type-annotation" },
		{ "include": "#where-clause" },
		{ "include": "#using-clause" },
		{ "include": "#declaration-heads" },
		{ "include": "#method-access" },
		{ "include": "#constructor-literals" },
		{ "include": "#type-names" },
		{ "include": "#keywords" },
		{ "include": "#function-calls" },
		{ "include": "#operators" },
		{ "include": "#identifiers" },
		{ "include": "#punctuation" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.documentation.module.musi",
					"begin": "//!",
					"end": "$",
					"beginCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
					"patterns": [ { "include": "#documentation-comments" } ]
				},
				{
					"name": "comment.line.documentation.musi",
					"begin": "///",
					"end": "$",
					"beginCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
					"patterns": [ { "include": "#documentation-comments" } ]
				},
				{
					"name": "comment.block.documentation.musi",
					"begin": "/\\*\\*",
					"end": "\\*/",
					"beginCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
					"endCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
					"patterns": [ { "include": "#documentation-comments" } ]
				},
				{
					"name": "comment.line.double-slash.musi",
					"match": "//.*$"
				},
				{
					"name": "comment.block.musi",
					"begin": "/\\*",
					"end": "\\*/",
					"patterns": [ { "include": "#comments" } ]
				}
			]
		},
		"documentation-comments": {
			"patterns": [
				{
					"name": "meta.documentation.param.musi",
					"begin": "@(param(?:eter)?|arg(?:ument)?|property|var)\\b",
					"end": "(?=\\s*(?:@|\\*/|$))",
					"beginCaptures": {
						"0": { "name": "keyword.other.documentation.tag.musi" },
						"1": { "name": "keyword.other.documentation.tag.musi" }
					},
					"patterns": [
						{
							"name": "punctuation.section.brackets.begin.documentation.musi",
							"match": "\\["
						},
						{
							"name": "punctuation.section.brackets.end.documentation.musi",
							"match": "\\]"
						},
						{
							"name": "storage.type.documentation.musi",
							"match": "\\{[^}]+\\}"
						},
						{
							"name": "variable.parameter.optional.documentation.musi",
							"match": "\\[[A-Za-z_][A-Za-z0-9_]*(?:\\s*:=\\s*[^\\]]+)?\\]"
						},
						{
							"name": "variable.parameter.documentation.musi",
							"match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?::=|\\{|\\[|$))"
						},
						{
							"name": "punctuation.separator.definition.documentation.musi",
							"match": ":="
						}
					]
				},
				{
					"name": "meta.documentation.type.musi",
					"begin": "@(type|template)\\b",
					"end": "(?=\\s*(?:@|\\*/|$))",
					"beginCaptures": {
						"0": { "name": "keyword.other.documentation.tag.musi" },
						"1": { "name": "keyword.other.documentation.tag.musi" }
					},
					"patterns": [
						{
							"name": "storage.type.documentation.musi",
							"match": "\\{[^}]+\\}"
						},
						{
							"name": "punctuation.separator.definition.documentation.musi",
							"match": ":="
						},
						{
							"name": "variable.parameter.documentation.musi",
							"match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?::=|$))"
						}
					]
				},
				{
					"name": "meta.documentation.option.musi",
					"begin": "@(default|optional)\\b",
					"end": "(?=\\s*(?:@|\\*/|$))",
					"beginCaptures": {
						"0": { "name": "keyword.other.documentation.tag.musi" },
						"1": { "name": "keyword.other.documentation.tag.musi" }
					},
					"patterns": [
						{
							"name": "variable.parameter.optional.documentation.musi",
							"match": "\\[[A-Za-z_][A-Za-z0-9_]*(?:\\s*:=\\s*[^\\]]+)?\\]"
						},
						{
							"name": "punctuation.separator.definition.documentation.musi",
							"match": ":="
						},
						{
							"name": "variable.parameter.documentation.musi",
							"match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?::=|$))"
						}
					]
				},
				{
					"name": "meta.documentation.reference.musi",
					"begin": "@(see)\\b",
					"end": "(?=\\s*(?:@|\\*/|$))",
					"beginCaptures": {
						"0": { "name": "keyword.other.documentation.tag.musi" },
						"1": { "name": "keyword.other.documentation.tag.musi" }
					},
					"patterns": [
						{
							"name": "markup.underline.link.documentation.musi",
							"match": "[A-Za-z_][A-Za-z0-9_]*(?:#[A-Za-z_][A-Za-z0-9_]*)?(?:\\.[A-Za-z_][A-Za-z0-9_]*)*"
						},
						{
							"name": "punctuation.separator.pipe.documentation.musi",
							"match": "\\|"
						},
						{
							"name": "string.unquoted.label.documentation.musi",
							"match": "[^|}\\s][^|}]*"
						}
					]
				},
				{
					"name": "meta.documentation.reference.musi",
					"begin": "\\{@(?:link(?:plain)?|linkplain|see)\\b",
					"end": "\\}",
					"beginCaptures": { "0": { "name": "keyword.other.documentation.tag.musi" } },
					"patterns": [
						{
							"name": "markup.underline.link.documentation.musi",
							"match": "[A-Za-z_][A-Za-z0-9_]*(?:#[A-Za-z_][A-Za-z0-9_]*)?(?:\\.[A-Za-z_][A-Za-z0-9_]*)*"
						},
						{
							"name": "punctuation.separator.pipe.documentation.musi",
							"match": "\\|"
						},
						{
							"name": "string.unquoted.label.documentation.musi",
							"match": "[^|}\\s][^|}]*"
						}
					]
				},
				{
					"name": "meta.documentation.formatting.musi",
					"begin": "@(code|literal)\\b",
					"end": "(?=\\s*(?:@|\\*/|$))",
					"beginCaptures": {
						"0": { "name": "keyword.other.documentation.tag.musi" },
						"1": { "name": "keyword.other.documentation.tag.musi" }
					},
					"patterns": [
						{
							"name": "markup.inline.raw.documentation.musi",
							"match": "[^@]+"
						}
					]
				},
				{
					"name": "meta.documentation.formatting.musi",
					"begin": "\\{@(?:code|literal)\\b",
					"end": "\\}",
					"beginCaptures": { "0": { "name": "keyword.other.documentation.tag.musi" } },
					"patterns": [
						{
							"name": "markup.inline.raw.documentation.musi",
							"match": "[^}]+"
						}
					]
				},
				{
					"name": "keyword.other.documentation.tag.musi",
					"match": "@(returns?|deprecated|example|remarks?|summary|since|version)\\b"
				},
				{
					"name": "keyword.other.documentation.tag.musi",
					"match": "@[A-Za-z_][A-Za-z0-9_]*\\b"
				},
				{
					"name": "markup.underline.link.documentation.musi",
					"match": "https?://[^\\s)]+"
				},
				{
					"name": "punctuation.separator.definition.documentation.musi",
					"match": ":="
				}
			]
		},
		"attributes": {
			"name": "meta.attribute.musi",
			"begin": "@(?=[A-Za-z_])",
			"end": "(?=\\s|$|[;,\\]}\\)])",
			"beginCaptures": { "0": { "name": "punctuation.definition.attribute.musi" } },
			"patterns": [
				{
					"name": "entity.other.attribute-name.musi",
					"match": "[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*"
				},
				{
					"name": "meta.attribute.arguments.musi",
					"begin": "\\(",
					"end": "\\)",
					"beginCaptures": { "0": { "name": "punctuation.section.parens.begin.musi" } },
					"endCaptures": { "0": { "name": "punctuation.section.parens.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				}
			]
		},
		"template-string": {
			"name": "string.template.musi",
			"begin": "`",
			"end": "`",
			"beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
			"patterns": [
				{
					"name": "meta.embedded.expression.musi",
					"begin": "\\$\\{",
					"end": "\\}",
					"beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
					"endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				},
				{
					"name": "constant.character.escape.musi",
					"match": "\\\\."
				}
			]
		},
		"string": {
			"name": "string.quoted.double.musi",
			"begin": "\"",
			"end": "\"",
			"beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
			"patterns": [
				{
					"name": "constant.character.escape.musi",
					"match": "\\\\."
				}
			]
		},
		"rune": {
			"name": "string.quoted.single.musi",
			"match": "'(?:[^'\\\\\\n]|\\\\.)*'"
		},
		"numeric": {
			"patterns": [
				{
					"name": "constant.numeric.hex.musi",
					"match": "\\b0[xX][0-9a-fA-F](?:[0-9a-fA-F_]*[0-9a-fA-F])?\\b"
				},
				{
					"name": "constant.numeric.octal.musi",
					"match": "\\b0[oO][0-7](?:[0-7_]*[0-7])?\\b"
				},
				{
					"name": "constant.numeric.binary.musi",
					"match": "\\b0[bB][01](?:[01_]*[01])?\\b"
				},
				{
					"name": "constant.numeric.float.musi",
					"match": "\\b[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?\\b|\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?\\b|\\b[0-9][0-9_]*(?:[eE][+-]?[0-9_]+)\\b"
				},
				{
					"name": "constant.numeric.decimal.musi",
					"match": "\\b[0-9][0-9_]*\\b"
				}
			]
		},
		"fixity-declaration": {
			"name": "meta.fixity.declaration.musi",
			"match": "\\b(infixl|infixr|infix)\\b\\s+([0-9][0-9_]*)\\s*(\\((?:[*/+\\-%=<>]{1,})\\))",
			"captures": {
				"1": { "name": "keyword.declaration.fixity.musi" },
				"2": { "name": "constant.numeric.decimal.musi" },
				"3": { "name": "entity.name.function.operator.fixity.musi" }
			}
		},
		"quote": {
			"name": "meta.quote.musi",
			"begin": "\\bquote\\b\\s*(?=\\(|\\{)",
			"end": "(?=\\s|$|[;,\\]}\\)])",
			"beginCaptures": { "0": { "name": "keyword.other.quote.musi" } },
			"patterns": [ { "include": "$self" } ]
		},
		"splices": {
			"patterns": [
				{
					"name": "meta.splice.name.musi",
					"match": "#[A-Za-z_][A-Za-z0-9_]*"
				},
				{
					"name": "meta.splice.expr.musi",
					"begin": "#\\(",
					"end": "\\)",
					"beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
					"endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				},
				{
					"name": "meta.splice.list.musi",
					"begin": "#\\[",
					"end": "\\]",
					"beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
					"endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				}
			]
		},
		"type-annotation": {
			"name": "meta.type.annotation.musi",
			"begin": "(:)(?![=?])\\s*",
			"end": "(?=\\s*(?:,|;|\\)|\\}|\\]|:=|=>|\\||if\\b|using\\b|where\\b))",
			"beginCaptures": { "1": { "name": "punctuation.separator.colon.musi" } },
			"patterns": [
				{ "include": "#keywords" },
				{ "include": "#operators" },
				{ "include": "#punctuation" },
				{ "include": "#identifiers" }
			]
		},
		"where-clause": {
			"name": "meta.where-clause.musi",
			"begin": "\\bwhere\\b",
			"beginCaptures": { "0": { "name": "keyword.control.constraint.where.musi" } },
			"end": "(?=\\s*(?:\\{|:=|;|\\)|\\]|$))",
			"patterns": [ { "include": "$self" } ]
		},
		"declaration-heads": {
			"patterns": [
				{
					"name": "meta.declaration.method.musi",
					"match": "\\b(let)\\b(?:\\s+(rec)\\b)?(?:\\s+(\\[[^\\]\\\\n]*\\]))?\\s*(\\()\\s*(mut\\b\\s+)?([a-z_][A-Za-z0-9_]*)\\s*(:)[^)]*(\\))(\\.)([a-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": { "name": "keyword.declaration.musi" },
						"2": { "name": "keyword.modifier.musi" },
						"4": { "name": "punctuation.section.parens.begin.musi" },
						"5": { "name": "keyword.modifier.musi" },
						"6": { "name": "variable.parameter.receiver.musi" },
						"7": { "name": "punctuation.separator.colon.musi" },
						"8": { "name": "punctuation.section.parens.end.musi" },
						"9": { "name": "punctuation.accessor.musi" },
						"10": { "name": "entity.name.function.method.musi" }
					}
				},
				{
					"name": "meta.declaration.function.musi",
					"match": "\\b(let)\\b(?:\\s+(rec)\\b)?(?:\\s+(\\[[^\\]\\\\n]*\\]))?\\s+([a-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\[[^\\]\\\\n]*\\]\\s*)?\\()",
					"captures": {
						"1": { "name": "keyword.declaration.musi" },
						"2": { "name": "keyword.modifier.musi" },
						"4": { "name": "entity.name.function.musi" }
					}
				},
				{
					"name": "meta.declaration.value.musi",
					"match": "\\b(let)\\b(?:\\s+(rec)\\b)?(?:\\s+(\\[[^\\]\\\\n]*\\]))?\\s+([a-z_][A-Za-z0-9_]*)\\b(?=\\s*(?::|:=))",
					"captures": {
						"1": { "name": "keyword.declaration.musi" },
						"2": { "name": "keyword.modifier.musi" },
						"4": { "name": "variable.other.definition.musi" }
					}
				},
				{
					"name": "meta.declaration.type.musi",
					"match": "\\b(let)\\b(?:\\s+(rec)\\b)?(?:\\s+(\\[[^\\]\\\\n]*\\]))?\\s+([A-Z][A-Za-z0-9_]*)\\b(?=\\s*:=\\s*(?:class|data|effect|instance)\\b)",
					"captures": {
						"1": { "name": "keyword.declaration.musi" },
						"2": { "name": "keyword.modifier.musi" },
						"4": { "name": "entity.name.type.musi" }
					}
				},
				{
					"name": "meta.declaration.type.musi",
					"match": "\\b(class|data|effect|instance)\\s+([A-Z][A-Za-z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.declaration.musi" },
						"2": { "name": "entity.name.type.musi" }
					}
				},
				{
					"name": "meta.declaration.member.musi",
					"match": "\\b(law)\\b\\s+([a-z_][A-Za-z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.declaration.musi" },
						"2": { "name": "entity.name.function.musi" }
					}
				},
				{
					"name": "meta.declaration.member.musi",
					"match": "(^|[;{]\\s*)([a-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\[[^\\]\\\\n]*\\]\\s*)?\\([^)]*\\)\\s*(?::|:=|where\\b|using\\b))",
					"captures": { "2": { "name": "entity.name.function.musi" } }
				},
				{
					"name": "meta.declaration.foreign.musi",
					"match": "\\b(foreign)\\b(?:\\s+\"[^\"]+\")?\\s+(let)\\s+([a-z_][A-Za-z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.modifier.musi" },
						"2": { "name": "keyword.declaration.musi" },
						"3": { "name": "entity.name.function.musi" }
					}
				}
			]
		},
		"constructor-literals": {
			"patterns": [
				{
					"name": "meta.constructor.access.musi",
					"match": "(\\.)([A-Z][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": { "name": "punctuation.accessor.musi" },
						"2": { "name": "entity.name.type.constructor.musi" }
					}
				}
			]
		},
		"type-names": {
			"patterns": [
				{
					"name": "entity.name.type.musi",
					"match": "\\b[A-Z][A-Za-z0-9_]*\\b"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.declaration.musi",
					"match": "\\b(class|data|effect|infix|infixl|infixr|instance|law|let)\\b"
				},
				{
					"name": "keyword.modifier.musi",
					"match": "\\b(foreign|mut|opaque|rec)\\b"
				},
				{
					"name": "keyword.control.effects.using.musi",
					"match": "\\busing\\b"
				},
				{
					"name": "keyword.control.musi",
					"match": "\\b(as|export|forall|handle|if|import|match|quote|request|resume|where)\\b"
				},
				{
					"name": "keyword.operator.wordlike.musi",
					"match": "\\b(and|in|not|or|shl|shr|xor)\\b"
				}
			]
		},
		"function-calls": {
			"patterns": [
				{
					"name": "meta.method.call.musi",
					"match": "(\\.)(\\s*[a-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\[[^\\]\\n]*\\]\\s*)?\\()",
					"captures": {
						"1": { "name": "punctuation.accessor.musi" },
						"2": { "name": "entity.name.function.method.call.musi" }
					}
				},
				{
					"name": "entity.name.function.call.musi",
					"match": "(?<!\\.)\\b(?!and\\b|as\\b|class\\b|data\\b|effect\\b|export\\b|foreign\\b|forall\\b|handle\\b|if\\b|import\\b|in\\b|infix\\b|infixl\\b|infixr\\b|instance\\b|law\\b|let\\b|match\\b|mut\\b|not\\b|opaque\\b|or\\b|quote\\b|rec\\b|request\\b|resume\\b|shl\\b|shr\\b|using\\b|where\\b|xor\\b)[a-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.assignment.musi",
					"match": ":="
				},
				{
					"name": "keyword.operator.typecheck.musi",
					"match": ":\\?>|:\\?"
				},
				{
					"name": "keyword.operator.arrow.musi",
					"match": "=>|~>|->|\\|>"
				},
				{
					"name": "keyword.operator.comparison.musi",
					"match": "/=|<=|>=|=|<|>"
				},
				{
					"name": "keyword.operator.constraint.musi",
					"match": "<:"
				},
				{
					"name": "keyword.operator.spread.musi",
					"match": "\\.\\.\\."
				},
				{
					"name": "keyword.operator.range.musi",
					"match": "\\.\\.<|\\.\\.(?!\\.)"
				},
				{
					"name": "punctuation.accessor.musi",
					"match": "\\."
				},
				{
					"name": "keyword.operator.arithmetic.musi",
					"match": "\\+|-|\\*|/|%"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.separator.comma.musi",
					"match": ","
				},
				{
					"name": "punctuation.terminator.statement.musi",
					"match": ";"
				},
				{
					"name": "punctuation.separator.pipe.musi",
					"match": "\\|"
				},
				{
					"name": "punctuation.section.block.begin.musi",
					"match": "\\{"
				},
				{
					"name": "punctuation.section.block.end.musi",
					"match": "\\}"
				},
				{
					"name": "punctuation.section.brackets.begin.musi",
					"match": "\\["
				},
				{
					"name": "punctuation.section.brackets.end.musi",
					"match": "\\]"
				},
				{
					"name": "punctuation.section.parens.begin.musi",
					"match": "\\("
				},
				{
					"name": "punctuation.section.parens.end.musi",
					"match": "\\)"
				}
			]
		},
		"identifiers": {
			"patterns": [
				{
					"name": "constant.language.wildcard.musi",
					"match": "\\b_\\b"
				},
				{
					"name": "variable.other.identifier.musi",
					"match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
				},
				{
					"name": "entity.name.function.operator.musi",
					"match": "\\((?:[*/+\\-%=<>]{1,})\\)"
				}
			]
		},
		"using-clause": {
			"patterns": [
				{
					"name": "meta.effects.using-set.musi",
					"begin": "\\b(using)\\b\\s*(\\{)",
					"beginCaptures": {
						"1": { "name": "keyword.control.effects.using.musi" },
						"2": { "name": "punctuation.section.block.begin.musi" }
					},
					"end": "\\}",
					"endCaptures": { "0": { "name": "punctuation.section.block.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				},
				{
					"name": "meta.effects.using-handler.musi",
					"match": "\\b(using)\\b\\s+([A-Z][A-Za-z0-9_]*)(?=\\s*\\{)",
					"captures": {
						"1": { "name": "keyword.control.effects.using.musi" },
						"2": { "name": "entity.name.type.musi" }
					}
				},
				{
					"name": "meta.effects.using-handler.musi",
					"match": "\\b(using)\\b\\s+([a-z_][A-Za-z0-9_]*)(?=\\s*\\{)",
					"captures": {
						"1": { "name": "keyword.control.effects.using.musi" },
						"2": { "name": "variable.other.identifier.musi" }
					}
				}
			]
		},
		"method-access": {
			"patterns": [
				{
					"name": "meta.method.call.musi",
					"match": "(\\.)([a-z_][A-Za-z0-9_]*)(?=\\s*(?:\\[[^\\]\\\\n]*\\]\\s*)?\\()",
					"captures": {
						"1": { "name": "punctuation.accessor.musi" },
						"2": { "name": "entity.name.function.method.call.musi" }
					}
				},
				{
					"name": "meta.member.access.musi",
					"match": "(\\.)([a-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": { "name": "punctuation.accessor.musi" },
						"2": { "name": "entity.name.function.musi" }
					}
				}
			]
		}
	}
