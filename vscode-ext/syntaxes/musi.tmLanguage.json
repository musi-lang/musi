{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Musi",
	"scopeName": "source.musi",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#attributes" },
		{ "include": "#template-string" },
		{ "include": "#string" },
		{ "include": "#rune" },
		{ "include": "#numeric" },
		{ "include": "#fixity-declaration" },
		{ "include": "#quote" },
		{ "include": "#splices" },
		{ "include": "#type-annotation" },
		{ "include": "#where-clause" },
		{ "include": "#effect-set" },
		{ "include": "#keywords" },
		{ "include": "#operators" },
		{ "include": "#punctuation" },
		{ "include": "#identifiers" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.documentation.module.musi",
					"match": "//!.*$"
				},
				{
					"name": "comment.line.documentation.musi",
					"match": "///.*$"
				},
				{
					"name": "comment.line.double-slash.musi",
					"match": "//.*$"
				},
				{
					"name": "comment.block.musi",
					"begin": "/\\*",
					"end": "\\*/",
					"patterns": [ { "include": "#comments" } ]
				}
			]
		},
		"attributes": {
			"name": "meta.attribute.musi",
			"begin": "@(?=[A-Za-z_])",
			"end": "(?=\\s|$|[;,\\]}\\)])",
			"beginCaptures": { "0": { "name": "punctuation.definition.attribute.musi" } },
			"patterns": [
				{
					"name": "entity.name.attribute.musi",
					"match": "[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*"
				},
				{
					"name": "meta.attribute.arguments.musi",
					"begin": "\\(",
					"end": "\\)",
					"beginCaptures": { "0": { "name": "punctuation.section.parens.begin.musi" } },
					"endCaptures": { "0": { "name": "punctuation.section.parens.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				}
			]
		},
		"template-string": {
			"name": "string.template.musi",
			"begin": "`",
			"end": "`",
			"beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
			"patterns": [
				{
					"name": "meta.embedded.expression.musi",
					"begin": "\\$\\{",
					"end": "\\}",
					"beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
					"endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				},
				{
					"name": "constant.character.escape.musi",
					"match": "\\\\."
				}
			]
		},
		"string": {
			"name": "string.quoted.double.musi",
			"begin": "\"",
			"end": "\"",
			"beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
			"patterns": [
				{
					"name": "constant.character.escape.musi",
					"match": "\\\\."
				}
			]
		},
		"rune": {
			"name": "string.quoted.single.musi",
			"match": "'(?:[^'\\\\\\n]|\\\\.)*'"
		},
		"numeric": {
			"patterns": [
				{
					"name": "constant.numeric.hex.musi",
					"match": "\\b0[xX][0-9a-fA-F](?:[0-9a-fA-F_]*[0-9a-fA-F])?\\b"
				},
				{
					"name": "constant.numeric.octal.musi",
					"match": "\\b0[oO][0-7](?:[0-7_]*[0-7])?\\b"
				},
				{
					"name": "constant.numeric.binary.musi",
					"match": "\\b0[bB][01](?:[01_]*[01])?\\b"
				},
				{
					"name": "constant.numeric.float.musi",
					"match": "\\b[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?\\b|\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?\\b|\\b[0-9][0-9_]*(?:[eE][+-]?[0-9_]+)\\b"
				},
				{
					"name": "constant.numeric.decimal.musi",
					"match": "\\b[0-9][0-9_]*\\b"
				}
			]
		},
		"fixity-declaration": {
			"name": "meta.fixity.declaration.musi",
			"match": "\\b(infixl|infixr|infix)\\b\\s+([0-9][0-9_]*)\\s*(\\((?:[*/+\\-%=<>]{1,})\\))",
			"captures": {
				"1": { "name": "keyword.declaration.fixity.musi" },
				"2": { "name": "constant.numeric.decimal.musi" },
				"3": { "name": "entity.name.operator.fixity.musi" }
			}
		},
		"quote": {
			"name": "meta.quote.musi",
			"begin": "\\bquote\\b\\s*(?=\\(|\\{)",
			"end": "(?=\\s|$|[;,\\]}\\)])",
			"beginCaptures": { "0": { "name": "keyword.other.quote.musi" } },
			"patterns": [ { "include": "$self" } ]
		},
		"splices": {
			"patterns": [
				{
					"name": "meta.splice.name.musi",
					"match": "#[A-Za-z_][A-Za-z0-9_]*"
				},
				{
					"name": "meta.splice.expr.musi",
					"begin": "#\\(",
					"end": "\\)",
					"beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
					"endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				},
				{
					"name": "meta.splice.list.musi",
					"begin": "#\\[",
					"end": "\\]",
					"beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
					"endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				}
			]
		},
		"type-annotation": {
			"name": "meta.type.annotation.musi",
			"begin": "(:)(?![=?])\\s*",
			"end": "(?=\\s*(?:,|;|\\)|\\}|\\]|:=|=>|\\||if\\b|with\\b|where\\b))",
			"beginCaptures": { "1": { "name": "punctuation.separator.colon.musi" } },
			"patterns": [
				{ "include": "#keywords" },
				{ "include": "#operators" },
				{ "include": "#punctuation" },
				{ "include": "#identifiers" }
			]
		},
		"where-clause": {
			"name": "meta.where-clause.musi",
			"begin": "\\bwhere\\b",
			"beginCaptures": { "0": { "name": "keyword.control.constraint.where.musi" } },
			"end": "(?=\\s*(?:\\{|:=|;|\\)|\\]|$))",
			"patterns": [ { "include": "$self" } ]
		},
		"effect-set": {
			"name": "meta.effect.set.musi",
			"begin": "\\bwith\\b\\s*(\\{)",
			"beginCaptures": {
				"0": { "name": "keyword.control.effects.with.musi" },
				"1": { "name": "punctuation.section.block.begin.musi" }
			},
			"end": "\\}",
			"endCaptures": { "0": { "name": "punctuation.section.block.end.musi" } },
			"patterns": [ { "include": "$self" } ]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.declaration.musi",
					"match": "\\b(class|data|effect|infix|infixl|infixr|instance|law|let)\\b"
				},
				{
					"name": "keyword.modifier.musi",
					"match": "\\b(foreign|mut|opaque|rec)\\b"
				},
				{
					"name": "keyword.control.musi",
					"match": "\\b(as|case|export|forall|handle|if|import|of|perform|quote|resume|where|with)\\b"
				},
				{
					"name": "keyword.operator.wordlike.musi",
					"match": "\\b(and|in|not|or|shl|shr|xor)\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.assignment.musi",
					"match": ":="
				},
				{
					"name": "keyword.operator.typecheck.musi",
					"match": ":\\?>|:\\?"
				},
				{
					"name": "keyword.operator.arrow.musi",
					"match": "=>|~>|->|\\|>"
				},
				{
					"name": "keyword.operator.comparison.musi",
					"match": "/=|<=|>=|=|<|>"
				},
				{
					"name": "keyword.operator.constraint.musi",
					"match": "<:"
				},
				{
					"name": "keyword.operator.spread.musi",
					"match": "\\.\\.\\."
				},
				{
					"name": "punctuation.accessor.musi",
					"match": "\\."
				},
				{
					"name": "keyword.operator.arithmetic.musi",
					"match": "\\+|-|\\*|/|%"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.separator.comma.musi",
					"match": ","
				},
				{
					"name": "punctuation.terminator.statement.musi",
					"match": ";"
				},
				{
					"name": "punctuation.separator.pipe.musi",
					"match": "\\|"
				},
				{
					"name": "punctuation.section.block.begin.musi",
					"match": "\\{"
				},
				{
					"name": "punctuation.section.block.end.musi",
					"match": "\\}"
				},
				{
					"name": "punctuation.section.brackets.begin.musi",
					"match": "\\["
				},
				{
					"name": "punctuation.section.brackets.end.musi",
					"match": "\\]"
				},
				{
					"name": "punctuation.section.parens.begin.musi",
					"match": "\\("
				},
				{
					"name": "punctuation.section.parens.end.musi",
					"match": "\\)"
				}
			]
		},
		"identifiers": {
			"patterns": [
				{
					"name": "constant.language.wildcard.musi",
					"match": "\\b_\\b"
				},
				{
					"name": "variable.other.identifier.musi",
					"match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
				},
				{
					"name": "entity.name.operator.identifier.musi",
					"match": "\\((?:[*/+\\-%=<>]{1,})\\)"
				}
			]
		}
	}
}
