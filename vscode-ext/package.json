{
	"name": "vscode-musi",
	"displayName": "Musi",
	"description": "Musi language support",
	"version": "0.1.0-alpha.1",
	"author": {
		"name": "xsyetopz"
	},
	"license": "MIT",
	"private": true,
	"publisher": "musi-lang",
	"homepage": "https://github.com/musi-lang/musi",
	"repository": {
		"type": "git",
		"url": "https://github.com/musi-lang/musi.git"
	},
	"bugs": {
		"url": "https://github.com/musi-lang/musi/issues"
	},
	"keywords": [
		"Musi"
	],
	"categories": [
		"Formatters",
		"Linters",
		"Programming Languages"
	],
	"icon": "logo.png",
	"galleryBanner": {
		"color": "#cc0000",
		"theme": "dark"
	},
	"readme": "README.md",
	"main": "./dist/extension.js",
	"engines": {
		"vscode": "^1.75.0"
	},
	"activationEvents": [
		"workspaceContains:**/musi.json"
	],
	"contributes": {
		"languages": [
			{
				"id": "musi",
				"aliases": [
					"Musi",
					"musi"
				],
				"extensions": [
					".ms"
				],
				"configuration": "language-configuration.json",
				"icon": {
					"light": "logo.png",
					"dark": "logo.png"
				}
			},
			{
				"id": "musi-injection",
				"aliases": [
					"musi-inj"
				]
			}
		],
		"grammars": [
			{
				"language": "musi",
				"scopeName": "source.musi",
				"path": "syntaxes/musi.tmLanguage.json",
				"balancedBracketScopes": [
					"punctuation.section",
					"punctuation.definition.type-params"
				],
				"unbalancedBracketScopes": [
					"entity.name.function.operator.musi"
				]
			},
			{
				"language": "musi-injection",
				"path": "syntaxes/musi_codeblock.tmLanguage.json",
				"scopeName": "text.musi.codeblock",
				"injectTo": [
					"text.html.markdown"
				],
				"embeddedLanguages": {
					"meta.embedded.block.musi": "musi"
				}
			}
		],
		"snippets": [
			{
				"language": "musi",
				"path": "snippets/musi_snippets.json"
			}
		],
		"semanticTokenScopes": [
			{
				"language": "musi",
				"scopes": {
					"variable": [
						"variable.other.musi"
					],
					"variable.declaration": [
						"variable.other.musi"
					],
					"variable.readonly": [
						"variable.other.constant.musi"
					],
					"variable.declaration.readonly": [
						"variable.other.constant.musi"
					],
					"variable.mutable": [
						"variable.other.musi"
					],
					"variable.declaration.mutable": [
						"variable.other.musi"
					],
					"parameter.readonly": [
						"variable.other.constant.musi"
					],
					"parameter.declaration.readonly": [
						"variable.other.constant.musi"
					],
					"parameter.mutable": [
						"variable.parameter.musi"
					],
					"parameter.declaration.mutable": [
						"variable.parameter.musi"
					],
					"property.readonly": [
						"variable.other.constant.property.musi"
					],
					"property.declaration.readonly": [
						"variable.other.constant.property.musi"
					],
					"property.mutable": [
						"variable.other.property.musi"
					],
					"property.declaration.mutable": [
						"variable.other.property.musi"
					],
					"property": [
						"variable.other.property.musi"
					],
					"property.declaration": [
						"variable.other.property.musi"
					],
					"function": [
						"entity.name.function.musi"
					],
					"function.declaration": [
						"entity.name.function.musi"
					],
					"type": [
						"entity.name.type.musi"
					],
					"type.declaration": [
						"entity.name.type.musi"
					],
					"enumMember": [
						"variable.other.enummember.musi"
					],
					"enumMember.declaration": [
						"variable.other.enummember.musi"
					],
					"typeParameter": [
						"storage.type.parameter.musi"
					],
					"typeParameter.declaration": [
						"storage.type.parameter.musi"
					],
					"operator": [
						"entity.name.function.operator.musi"
					],
					"operator.declaration": [
						"entity.name.function.operator.musi"
					]
				}
			}
		],
		"configurationDefaults": {
			"[musi]": {
				"editor.semanticHighlighting.enabled": true
			},
			"editor.semanticTokenColorCustomizations": {
				"rules": {
					"*.mutable": {
						"underline": true
					}
				}
			}
		},
		"commands": [
			{
				"command": "musi.runFile",
				"title": "Run File",
				"category": "Musi",
				"description": "Run the current .ms file using the Musi runtime."
			},
			{
				"command": "musi.checkFile",
				"title": "Check File",
				"category": "Musi",
				"description": "Check the current .ms file for errors using musi check."
			},
			{
				"command": "musi.runTask",
				"title": "Run Task",
				"category": "Musi",
				"description": "Pick and run a task from musi.json."
			},
			{
				"command": "musi.runTest",
				"title": "▷ Run test",
				"category": "Musi"
			},
			{
				"command": "musi.debugTest",
				"title": "Debug Test",
				"category": "Musi"
			},
			{
				"command": "musi.selectRunConfiguration",
				"title": "Select Run Configuration",
				"category": "Musi"
			},
			{
				"command": "musi.runWithArgs",
				"title": "Run with Arguments",
				"category": "Musi",
				"description": "Prompt for runtime arguments, then run current file."
			},
			{
				"command": "musi.buildFile",
				"title": "Build File",
				"category": "Musi",
				"description": "Compile current .ms file to .msbc bytecode."
			},
			{
				"command": "musi.editRunConfigurations",
				"title": "Edit Run Configurations",
				"category": "Musi"
			},
			{
				"command": "musi.runTaskCommand",
				"title": "Run Task Command",
				"category": "Musi"
			}
		],
		"keybindings": [],
		"menus": {
			"commandPalette": [],
			"view/item/context": []
		},
		"configuration": {
			"title": "Musi",
			"properties": {
				"musi.cliPath": {
					"type": "string",
					"default": "musi",
					"markdownDescription": "Path to `musi` CLI binary. If not set, searches in `target/debug`, `target/release`, `~/.cargo/bin`, and system PATH."
				},
				"musi.checkOnSave": {
					"type": "boolean",
					"default": true,
					"description": "Run musi check when saving a .ms file."
				},
				"musi.runtime.args": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Extra arguments passed to the musi runtime binary."
				},
				"musi.runtime.env": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					},
					"default": {},
					"description": "Environment variables for program execution."
				},
				"musi.runtime.inheritEnv": {
					"type": "boolean",
					"default": true,
					"description": "Inherit system environment variables when running programs."
				},
				"musi.runtime.envFile": {
					"type": "string",
					"default": "",
					"markdownDescription": "Path to `.env` file for runtime environment variables."
				},
				"musi.runtime.cwd": {
					"type": "string",
					"default": "",
					"description": "Working directory for program execution."
				},
				"musi.compiler.path": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"markdownDescription": "Path to `musi` compiler binary. If not set, searches in `target/debug`, `target/release`, `~/.cargo/bin`, and system PATH."
				},
				"musi.compiler.args": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Extra arguments passed to the musi compiler."
				},
				"musi.compiler.target": {
					"type": "string",
					"enum": [
						"MS2025",
						"native",
						"wasm",
						"embedded"
					],
					"default": "MS2025",
					"description": "Compilation target."
				},
				"musi.compiler.strict": {
					"type": "boolean",
					"default": false,
					"description": "Enable strict mode compilation."
				},
				"musi.compiler.noEmitOnError": {
					"type": "boolean",
					"default": true,
					"description": "Do not emit output files if there are compilation errors."
				},
				"musi.compiler.buildBeforeRun": {
					"type": "boolean",
					"default": true,
					"description": "Automatically build before running a file."
				},
				"musi.terminal.clearBeforeRun": {
					"type": "boolean",
					"default": false,
					"description": "Clear the terminal before running a command."
				},
				"musi.terminal.focusOnRun": {
					"type": "boolean",
					"default": true,
					"description": "Focus the terminal panel when running a command."
				},
				"musi.terminal.reuseTerminal": {
					"type": "boolean",
					"default": true,
					"description": "Reuse existing terminal instead of creating a new one."
				},
				"musi.runConfigurations": {
					"type": "array",
					"default": [],
					"items": {
						"type": "object",
						"required": [
							"name"
						],
						"properties": {
							"name": {
								"type": "string",
								"description": "Configuration name."
							},
							"file": {
								"type": "string",
								"description": "Source file to run."
							},
							"compilerArgs": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"description": "Extra compiler arguments."
							},
							"runtimeArgs": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"description": "Extra runtime arguments."
							},
							"env": {
								"type": "object",
								"additionalProperties": {
									"type": "string"
								},
								"description": "Environment variables."
							},
							"envFile": {
								"type": "string",
								"description": "Path to .env file."
							},
							"cwd": {
								"type": "string",
								"description": "Working directory."
							},
							"preLaunchTask": {
								"type": "string",
								"description": "Task to run before launch."
							}
						}
					},
					"markdownDescription": "Named run configurations for quick switching."
				},
				"musi.inlayHints.bindingTypes": {
					"type": "boolean",
					"default": true,
					"description": "Show type hints for let/var bindings"
				},
				"musi.inlayHints.returnTypes": {
					"type": "boolean",
					"default": true,
					"description": "Show return type hints for functions"
				},
				"musi.inlayHints.parameterTypes": {
					"type": "boolean",
					"default": true,
					"description": "Show type hints for unannotated parameters"
				}
			}
		},
		"debuggers": [
			{
				"type": "musi",
				"label": "Musi",
				"configurationAttributes": {
					"launch": {
						"properties": {
							"file": {
								"type": "string",
								"description": "Source file to run."
							},
							"compilerArgs": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"default": []
							},
							"runtimeArgs": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"default": []
							},
							"env": {
								"type": "object",
								"additionalProperties": {
									"type": "string"
								},
								"default": {}
							},
							"envFile": {
								"type": "string",
								"default": ""
							},
							"cwd": {
								"type": "string",
								"default": ""
							},
							"preLaunchTask": {
								"type": "string",
								"default": ""
							},
							"buildBeforeRun": {
								"type": "boolean",
								"default": true
							},
							"console": {
								"type": "string",
								"enum": [
									"integratedTerminal",
									"externalTerminal"
								],
								"default": "integratedTerminal"
							}
						}
					}
				},
				"configurationSnippets": [
					{
						"label": "Musi: Run File",
						"description": "Run a Musi source file",
						"body": {
							"type": "musi",
							"request": "launch",
							"name": "Run ${1:file}",
							"file": "${2:${workspaceFolder}/index.ms}",
							"buildBeforeRun": true
						}
					},
					{
						"label": "Musi: Run with Env",
						"description": "Run a Musi source file with environment variables",
						"body": {
							"type": "musi",
							"request": "launch",
							"name": "Run with Env",
							"file": "${1:${workspaceFolder}/index.ms}",
							"env": {
								"${2:KEY}": "${3:value}"
							},
							"buildBeforeRun": true
						}
					}
				]
			}
		],
		"iconThemes": [
			{
				"id": "musi-icons",
				"label": "Musi File Icons",
				"path": "./icons/musi-icon-theme.json"
			}
		],
		"jsonValidation": [
			{
				"fileMatch": "musi.json",
				"url": "https://raw.githubusercontent.com/musi-lang/musi/refs/heads/main/schemas/musi.schema.v1.json"
			}
		]
	},
	"scripts": {
		"build": "bun build ./client/src/main.ts --outfile=./dist/extension.js --external vscode --target=node --format=cjs --minify",
		"grammar:check": "node ./scripts/verify-grammars.mjs",
		"package": "bun run build && vsce package --no-dependencies",
		"typecheck": "tsc --noEmit",
		"biome:check": "bunx biome check . --write --unsafe --max-diagnostics 16384",
		"biome:format": "bunx biome format . --write --max-diagnostics 16384",
		"biome:lint": "bunx biome lint . --write --max-diagnostics 16384",
		"vscode:prepublish": "bun run build"
	},
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/bun": "1.3.11",
		"@types/node": "25.5.2",
		"@types/vscode": "^1.75.0",
		"@vscode/vsce": "3.7.1",
		"typescript": "6.0.2"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"@vscode/vsce-sign",
		"keytar"
	]
}
