project Musi is
   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("musi.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnaty", "-gnatwa", "-gnatwe", "-gnateE");
   end Compiler;

   package Binder is
      for Default_Switches ("Ada") use ("-Es");
   end Binder;

end Musi;
