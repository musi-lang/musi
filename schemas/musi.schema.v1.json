{
    "$id": "https://raw.githubusercontent.com/musi-lang/musi/refs/heads/main/schemas/musi.schema.v1.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Musi configuration file schema",
    "description": "A JSON representation of a Musi configuration file.",
    "type": "object",
    "required": [],
    "properties": {
        "name": {
            "type": "string",
            "description": "The name of this package."
        },
        "version": {
            "type": "string",
            "description": "The version of this package."
        },
        "description": {
            "type": "string",
            "description": "A short description of the package."
        },
        "main": {
            "type": "string",
            "description": "The main entry point of the package. Defaults to 'index.ms'.",
            "default": "index.ms",
            "examples": [
                "index.ms",
                "src/app.ms"
            ]
        },
        "exports": {
            "oneOf": [
                {
                    "type": "string",
                    "description": "The path to the main module of this package.",
                    "examples": [
                        "./index.ms"
                    ],
                    "pattern": "^\\./.*$"
                },
                {
                    "type": "object",
                    "description": "A map of package exports to files in this package.",
                    "propertyNames": {
                        "description": "Package export name.",
                        "examples": [
                            ".",
                            "./utils",
                            "./math"
                        ],
                        "pattern": "^\\.(/.*)?$"
                    },
                    "patternProperties": {
                        "^\\.(/.*)?$": {
                            "type": "string",
                            "pattern": "^\\./.*$"
                        }
                    },
                    "examples": [
                        {
                            ".": "./index.ms",
                            "./utils": "./src/utils/index.ms"
                        }
                    ]
                }
            ]
        },
        "license": {
            "type": "string",
            "description": "SPDX license identifier.",
            "examples": [
                "MIT",
                "Apache-2.0",
                "GPL-3.0-only"
            ]
        },
        "author": {
            "description": "The package author.",
            "oneOf": [
                {
                    "type": "string"
                },
                {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "email": {
                            "type": "string",
                            "format": "email"
                        },
                        "url": {
                            "type": "string",
                            "format": "uri"
                        }
                    },
                    "required": [
                        "name"
                    ],
                    "additionalProperties": false
                }
            ]
        },
        "contributors": {
            "type": "array",
            "description": "Additional contributors.",
            "items": {
                "oneOf": [
                    {
                        "type": "string"
                    },
                    {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "email": {
                                "type": "string",
                                "format": "email"
                            },
                            "url": {
                                "type": "string",
                                "format": "uri"
                            }
                        },
                        "required": [
                            "name"
                        ],
                        "additionalProperties": false
                    }
                ]
            }
        },
        "private": {
            "type": "boolean",
            "description": "If true, prevents the package from being published.",
            "default": false
        },
        "repository": {
            "description": "Source repository location.",
            "oneOf": [
                {
                    "type": "string",
                    "format": "uri"
                },
                {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": [
                                "git",
                                "hg",
                                "svn"
                            ]
                        },
                        "url": {
                            "type": "string",
                            "format": "uri"
                        },
                        "directory": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "type",
                        "url"
                    ],
                    "additionalProperties": false
                }
            ]
        },
        "homepage": {
            "type": "string",
            "format": "uri"
        },
        "bugs": {
            "oneOf": [
                {
                    "type": "string",
                    "format": "uri"
                },
                {
                    "type": "object",
                    "properties": {
                        "url": {
                            "type": "string",
                            "format": "uri"
                        },
                        "email": {
                            "type": "string",
                            "format": "email"
                        }
                    },
                    "additionalProperties": false
                }
            ]
        },
        "keywords": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "uniqueItems": true
        },
        "imports": {
            "description": "A map of specifiers to their remapped specifiers.",
            "type": "object",
            "additionalProperties": {
                "description": "The key is the specifier or partial specifier to match, with a value that represents the target specifier.",
                "type": "string"
            }
        },
        "scopes": {
            "description": "Define a scope which remaps a specifier in only a specified scope.",
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                    "type": "string"
                }
            }
        },
        "dependencies": {
            "type": "object",
            "description": "Runtime dependencies. Keys are package names, values are semver ranges.",
            "additionalProperties": {
                "type": "string"
            }
        },
        "devDependencies": {
            "type": "object",
            "description": "Development-only dependencies.",
            "additionalProperties": {
                "type": "string"
            }
        },
        "peerDependencies": {
            "type": "object",
            "description": "Peer dependencies the consumer must provide.",
            "additionalProperties": {
                "type": "string"
            }
        },
        "optionalDependencies": {
            "type": "object",
            "description": "Dependencies that are not required. Installation failure does not abort.",
            "additionalProperties": {
                "type": "string"
            }
        },
        "overrides": {
            "type": "object",
            "description": "Dependency version overrides for transitive dependencies.",
            "additionalProperties": {
                "type": "string"
            }
        },
        "compilerOptions": {
            "type": "object",
            "description": "Instructs the Musi compiler how to compile .ms files.",
            "additionalProperties": false,
            "properties": {
                "strict": {
                    "description": "Enable all strict type checking options.",
                    "type": "boolean",
                    "default": true
                },
                "noImplicitAny": {
                    "description": "Enable error reporting for bindings with an implied Any type.",
                    "type": "boolean",
                    "default": true
                },
                "noUnusedLocals": {
                    "description": "Enable error reporting when local bindings aren't read.",
                    "type": "boolean",
                    "default": false
                },
                "noUnusedParameters": {
                    "description": "Raise an error when a function parameter isn't read.",
                    "type": "boolean",
                    "default": false
                },
                "noImplicitReturns": {
                    "description": "Enable error reporting for code paths that do not explicitly return in a function.",
                    "type": "boolean",
                    "default": false
                },
                "allowUnreachableCode": {
                    "description": "Disable error reporting for unreachable code.",
                    "type": "boolean",
                    "default": false
                },
                "noErrorTruncation": {
                    "description": "Do not truncate error messages.",
                    "type": "boolean",
                    "default": false
                },
                "baseUrl": {
                    "description": "Specify the base directory to resolve non-relative module names.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "paths": {
                    "description": "Specify a set of entries that re-map imports to additional lookup locations.",
                    "type": [
                        "object",
                        "null"
                    ],
                    "additionalProperties": {
                        "type": [
                            "array",
                            "null"
                        ],
                        "uniqueItems": true,
                        "items": {
                            "type": [
                                "string",
                                "null"
                            ]
                        }
                    }
                }
            }
        },
        "tasks": {
            "description": "Configuration for musi tasks. Run via 'musi run <task>'.",
            "type": "object",
            "patternProperties": {
                "^[A-Za-z][A-Za-z0-9_\\-:]*$": {
                    "oneOf": [
                        {
                            "type": "string",
                            "description": "Command to execute for this task name."
                        },
                        {
                            "type": "object",
                            "description": "A definition of a task to execute.",
                            "properties": {
                                "description": {
                                    "type": "string",
                                    "description": "Description of the task shown when running 'musi run' without a task name."
                                },
                                "command": {
                                    "type": "string",
                                    "description": "The command to execute."
                                },
                                "dependencies": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    },
                                    "description": "Tasks that should be executed before this task."
                                }
                            }
                        }
                    ]
                }
            },
            "additionalProperties": false
        },
        "fmt": {
            "description": "Configuration for 'musi fmt'.",
            "type": "object",
            "properties": {
                "include": {
                    "type": "array",
                    "description": "List of files, directories, or globs that will be formatted.",
                    "items": {
                        "type": "string"
                    }
                },
                "exclude": {
                    "type": "array",
                    "description": "List of files, directories, or globs that will not be formatted.",
                    "items": {
                        "type": "string"
                    }
                },
                "useTabs": {
                    "description": "Whether to use tabs (true) or spaces (false) for indentation.",
                    "type": "boolean",
                    "default": false
                },
                "lineWidth": {
                    "description": "The width of a line the printer will try to stay under.",
                    "type": "number",
                    "default": 100
                },
                "indentWidth": {
                    "description": "The number of characters for an indent.",
                    "type": "number",
                    "default": 4
                },
                "semiColons": {
                    "description": "Whether to enforce semicolons.",
                    "type": "boolean",
                    "default": true
                },
                "trailingCommas": {
                    "description": "Whether to add trailing commas.",
                    "default": "multiLine",
                    "enum": [
                        "never",
                        "always",
                        "multiLine"
                    ]
                },
                "bracePosition": {
                    "description": "The position of opening braces for blocks.",
                    "default": "sameLine",
                    "enum": [
                        "sameLine",
                        "nextLine"
                    ]
                }
            }
        },
        "lint": {
            "description": "Configuration for 'musi lint'.",
            "type": "object",
            "properties": {
                "include": {
                    "type": "array",
                    "description": "List of files, directories, or globs that will be linted.",
                    "items": {
                        "type": "string"
                    }
                },
                "exclude": {
                    "type": "array",
                    "description": "List of files, directories, or globs that will not be linted.",
                    "items": {
                        "type": "string"
                    }
                },
                "rules": {
                    "type": "object",
                    "properties": {
                        "tags": {
                            "type": "array",
                            "description": "List of tag names that will be run. Empty list disables all tags and will only use rules from 'include'.",
                            "items": {
                                "type": "string"
                            },
                            "minItems": 0,
                            "uniqueItems": true
                        },
                        "exclude": {
                            "type": "array",
                            "description": "List of rule names that will be excluded from configured tag sets.",
                            "items": {
                                "type": "string"
                            },
                            "minItems": 0,
                            "uniqueItems": true
                        },
                        "include": {
                            "type": "array",
                            "description": "List of rule names that will be run. Even if the same rule is in 'exclude' it will be run.",
                            "items": {
                                "type": "string"
                            },
                            "minItems": 0,
                            "uniqueItems": true
                        }
                    }
                },
                "report": {
                    "default": "pretty",
                    "enum": [
                        "pretty",
                        "json",
                        "compact"
                    ],
                    "description": "The default report format."
                }
            }
        },
        "test": {
            "description": "Configuration for 'musi test'.",
            "type": "object",
            "properties": {
                "include": {
                    "type": "array",
                    "description": "List of files, directories, or globs that will be searched for tests. Defaults to '**/*.test.ms'.",
                    "items": {
                        "type": "string"
                    }
                },
                "exclude": {
                    "type": "array",
                    "description": "List of files, directories, or globs that will not be searched for tests.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "bench": {
            "description": "Configuration for 'musi bench'.",
            "type": "object",
            "properties": {
                "include": {
                    "type": "array",
                    "description": "List of files, directories, or globs that will be searched for benchmarks.",
                    "items": {
                        "type": "string"
                    }
                },
                "exclude": {
                    "type": "array",
                    "description": "List of files, directories, or globs that will not be searched for benchmarks.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "compile": {
            "type": "object",
            "description": "Configuration for 'musi compile' (AOT native compilation).",
            "additionalProperties": false,
            "properties": {
                "target": {
                    "type": "string",
                    "description": "Target triple for AOT compilation. Defaults to the host platform.",
                    "examples": [
                        "x86_64-linux-gnu",
                        "aarch64-apple-darwin",
                        "x86_64-windows-msvc"
                    ]
                },
                "output": {
                    "type": "string",
                    "description": "Output path for the compiled binary."
                }
            }
        },
        "publish": {
            "oneOf": [
                {
                    "description": "Configuration for 'musi publish'.",
                    "type": "object",
                    "properties": {
                        "include": {
                            "type": "array",
                            "description": "List of files, directories, or globs that will be included in the published package.",
                            "items": {
                                "type": "string"
                            }
                        },
                        "exclude": {
                            "type": "array",
                            "description": "List of files, directories, or globs that will be excluded from the published package.",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "description": "Disable publishing this package.",
                    "type": "boolean",
                    "const": false
                }
            ]
        },
        "lock": {
            "description": "Whether to use a lock file or the path to use for the lock file.",
            "type": [
                "string",
                "boolean",
                "object"
            ],
            "default": true,
            "properties": {
                "path": {
                    "type": "string",
                    "description": "The path to use for the lock file.",
                    "default": "musi.lock"
                },
                "frozen": {
                    "type": "boolean",
                    "description": "Whether to exit with an error if the lock file is out of date.",
                    "default": false
                }
            }
        },
        "workspace": {
            "oneOf": [
                {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "The members of this workspace."
                },
                {
                    "type": "object",
                    "properties": {
                        "members": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "The members of this workspace."
                        }
                    }
                }
            ]
        },
        "exclude": {
            "type": "array",
            "description": "List of files, directories, or globs that will be ignored by all other configurations.",
            "items": {
                "type": "string"
            }
        }
    }
}
