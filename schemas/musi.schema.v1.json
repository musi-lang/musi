{
  "$id": "https://raw.githubusercontent.com/musi-lang/musi/refs/heads/main/schemas/musi.schema.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Musi manifest schema",
  "description": "Schema for musi.json package, workspace, and tool configuration files.",
  "type": "object",
  "additionalProperties": false,
  "anyOf": [
    {
      "required": [
        "name",
        "version"
      ]
    },
    {
      "required": [
        "workspace"
      ]
    }
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema URI used by editors."
    },
    "name": {
      "$ref": "#/$defs/packageName"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "description": {
      "type": "string",
      "description": "Short package description."
    },
    "docs": {
      "type": "string",
      "format": "uri",
      "description": "Package documentation URL."
    },
    "readme": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "boolean"
        }
      ],
      "description": "README path, or false to disable README discovery."
    },
    "entry": {
      "$ref": "#/$defs/path",
      "default": "index.ms",
      "description": "Default package entry module."
    },
    "exports": {
      "$ref": "#/$defs/exports"
    },
    "license": {
      "$ref": "#/$defs/license"
    },
    "author": {
      "$ref": "#/$defs/person"
    },
    "contributors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/person"
      },
      "description": "Package contributors."
    },
    "repository": {
      "$ref": "#/$defs/repository"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "bugs": {
      "$ref": "#/$defs/bugs"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "description": "Tool-specific extension data.",
      "additionalProperties": true
    },
    "imports": {
      "$ref": "#/$defs/importMap"
    },
    "scopes": {
      "$ref": "#/$defs/scopes"
    },
    "dependencies": {
      "$ref": "#/$defs/dependencyMap"
    },
    "devDependencies": {
      "$ref": "#/$defs/dependencyMap"
    },
    "peerDependencies": {
      "$ref": "#/$defs/dependencyMap"
    },
    "optionalDependencies": {
      "$ref": "#/$defs/dependencyMap"
    },
    "overrides": {
      "$ref": "#/$defs/dependencyMap"
    },
    "compilerOptions": {
      "$ref": "#/$defs/compilerOptions"
    },
    "tasks": {
      "$ref": "#/$defs/tasks"
    },
    "fmt": {
      "$ref": "#/$defs/fmt"
    },
    "lint": {
      "$ref": "#/$defs/lint"
    },
    "test": {
      "$ref": "#/$defs/test"
    },
    "bench": {
      "$ref": "#/$defs/bench"
    },
    "compile": {
      "$ref": "#/$defs/compile"
    },
    "publish": {
      "$ref": "#/$defs/publish"
    },
    "lock": {
      "$ref": "#/$defs/lock"
    },
    "workspace": {
      "$ref": "#/$defs/workspace"
    },
    "exclude": {
      "type": "array",
      "description": "Files, directories, or globs ignored by package tooling.",
      "items": {
        "type": "string"
      }
    },
    "lints": {
      "$ref": "#/$defs/lints"
    }
  },
  "$defs": {
    "packageName": {
      "type": "string",
      "description": "Package name.",
      "minLength": 1,
      "pattern": "^(?:@[a-z0-9][a-z0-9_-]*(?:/[a-z0-9][a-z0-9_-]*)?|[a-z0-9][a-z0-9_-]*)$"
    },
    "semver": {
      "type": "string",
      "description": "Semantic version.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "path": {
      "type": "string",
      "description": "Filesystem path."
    },
    "relativePath": {
      "type": "string",
      "pattern": "^\\./.*$"
    },
    "person": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "name"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      ]
    },
    "repository": {
      "oneOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "object",
          "required": [
            "type",
            "url"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "enum": [
                "git",
                "hg",
                "svn"
              ]
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "directory": {
              "type": "string"
            }
          }
        }
      ]
    },
    "bugs": {
      "oneOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "email": {
              "type": "string",
              "format": "email"
            }
          }
        }
      ]
    },
    "license": {
      "oneOf": [
        {
          "type": "string",
          "description": "SPDX license expression."
        },
        {
          "type": "object",
          "required": [
            "file"
          ],
          "additionalProperties": false,
          "properties": {
            "file": {
              "type": "string",
              "description": "Path to license text."
            }
          }
        }
      ]
    },
    "exports": {
      "oneOf": [
        {
          "$ref": "#/$defs/relativePath"
        },
        {
          "type": "object",
          "propertyNames": {
            "pattern": "^\\.(?:/.*)?$"
          },
          "patternProperties": {
            "^\\.(?:/.*)?$": {
              "$ref": "#/$defs/relativePath"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "importMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "scopes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "dependencyMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "compilerOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strict": {
          "type": "boolean",
          "default": true
        },
        "noUnusedLocals": {
          "type": "boolean",
          "default": false
        },
        "noUnusedParameters": {
          "type": "boolean",
          "default": false
        },
        "noErrorTruncation": {
          "type": "boolean",
          "default": false
        },
        "baseUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "paths": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "tasks": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_\\-:]*$": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "required": [
                "command"
              ],
              "additionalProperties": false,
              "properties": {
                "description": {
                  "type": "string"
                },
                "command": {
                  "type": "string"
                },
                "dependencies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "uniqueItems": true
                }
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "fileSet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "fmt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "useTabs": {
          "type": "boolean",
          "default": false
        },
        "lineWidth": {
          "type": "integer",
          "minimum": 1,
          "default": 100
        },
        "indentWidth": {
          "type": "integer",
          "minimum": 1,
          "default": 4
        },
        "semiColons": {
          "type": "boolean",
          "default": true
        },
        "trailingCommas": {
          "enum": [
            "never",
            "always",
            "multiLine"
          ],
          "default": "multiLine"
        },
        "bracePosition": {
          "enum": [
            "sameLine",
            "nextLine"
          ],
          "default": "sameLine"
        }
      }
    },
    "lint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "rules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "include": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          }
        },
        "report": {
          "enum": [
            "pretty",
            "json",
            "compact"
          ],
          "default": "pretty"
        }
      }
    },
    "test": {
      "$ref": "#/$defs/fileSet"
    },
    "bench": {
      "$ref": "#/$defs/fileSet"
    },
    "compile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string"
        },
        "output": {
          "type": "string"
        }
      }
    },
    "publish": {
      "oneOf": [
        {
          "type": "boolean",
          "const": false
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "registry": {
              "type": "string"
            },
            "include": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          }
        }
      ]
    },
    "lock": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string",
              "default": "musi.lock"
            },
            "frozen": {
              "type": "boolean",
              "default": false
            }
          }
        }
      ]
    },
    "workspace": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "members": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          },
          "required": [
            "members"
          ]
        }
      ]
    },
    "lints": {
      "type": "object",
      "description": "Code policy levels by lint name.",
      "additionalProperties": {
        "enum": [
          "allow",
          "warn",
          "deny",
          "forbid"
        ]
      }
    }
  }
}
