{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "$id": "https://musi-lang.org/schemas/msconfig-schema.v1.json",
  "title": "JSON schema for Musi compiler configuration file",
  "description": "Configuration file for the Musi compiler (msconfig.json)",
  "type": "object",
  "allowTrailingCommas": true,
  "allOf": [
    {
      "$ref": "#/definitions/compilerOptionsDefinition"
    },
    {
      "$ref": "#/definitions/compileOnSaveDefinition"
    },
    {
      "$ref": "#/definitions/extendsDefinition"
    },
    {
      "$ref": "#/definitions/watchOptionsDefinition"
    },
    {
      "anyOf": [
        {
          "$ref": "#/definitions/filesDefinition"
        },
        {
          "$ref": "#/definitions/excludeDefinition"
        },
        {
          "$ref": "#/definitions/includeDefinition"
        },
        {
          "$ref": "#/definitions/referencesDefinition"
        }
      ]
    }
  ],
  "definitions": {
    "filesDefinition": {
      "properties": {
        "files": {
          "description": "List of files to be included in compilation. When specified, only these files and those specified by 'include' are included.",
          "type": [
            "array",
            "null"
          ],
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "excludeDefinition": {
      "properties": {
        "exclude": {
          "description": "List of files to be excluded from compilation. Only affects files included via 'include' property.",
          "type": [
            "array",
            "null"
          ],
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "includeDefinition": {
      "properties": {
        "include": {
          "description": "List of glob patterns that match files to be included in compilation.",
          "type": [
            "array",
            "null"
          ],
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "compileOnSaveDefinition": {
      "properties": {
        "compileOnSave": {
          "description": "Enable Compile-on-Save for this project.",
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "extendsDefinition": {
      "properties": {
        "extends": {
          "description": "Path to base configuration file to inherit from, or array of base files.",
          "oneOf": [
            {
              "type": "string",
              "default": ""
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          ]
        }
      }
    },
    "watchOptionsDefinition": {
      "properties": {
        "watchOptions": {
          "type": [
            "object",
            "null"
          ],
          "description": "Settings for watch mode in Musi compiler.",
          "properties": {
            "watchFile": {
              "description": "Strategy for watching individual files.",
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "fixedPollingInterval",
                "priorityPollingInterval",
                "dynamicPriorityPolling",
                "useFsEvents"
              ]
            },
            "watchDirectory": {
              "description": "Strategy for watching directories.",
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "useFsEvents",
                "fixedPollingInterval",
                "dynamicPriorityPolling"
              ]
            },
            "excludeFiles": {
              "description": "List of files to exclude from watch mode.",
              "type": [
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              }
            },
            "excludeDirectories": {
              "description": "List of directories to exclude from watch mode.",
              "type": [
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "compilerOptionsDefinition": {
      "properties": {
        "compilerOptions": {
          "type": [
            "object",
            "null"
          ],
          "description": "Instructs the Musi compiler how to compile .ms files.",
          "properties": {
            "target": {
              "description": "Set the compilation target.",
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "MS2025",
                "native",
                "wasm",
                "embedded"
              ],
              "default": "MS2025"
            },
            "lib": {
              "description": "Specify library files to be included in the compilation.",
              "type": [
                "array",
                "null"
              ],
              "uniqueItems": true,
              "items": {
                "type": "string",
                "examples": [
                  "MS2025"
                ]
              },
              "default": [
                "MS2025"
              ]
            },
            "outDir": {
              "description": "Specify an output folder for all emitted files.",
              "type": [
                "string",
                "null"
              ],
              "default": "./dist"
            },
            "rootDir": {
              "description": "Specify the root folder within your source files.",
              "type": [
                "string",
                "null"
              ],
              "default": "./src"
            },
            "baseUrl": {
              "description": "Specify the base directory to resolve non-relative module names.",
              "type": [
                "string",
                "null"
              ],
              "default": "./"
            },
            "paths": {
              "description": "Specify a set of entries that re-map imports to additional lookup locations.",
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": {
                "type": [
                  "array",
                  "null"
                ],
                "uniqueItems": true,
                "items": {
                  "type": "string"
                }
              }
            },
            "strict": {
              "description": "Enable all strict type-checking options.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "noImplicitAny": {
              "description": "Enable error reporting for expressions with an implied Any type.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "noImplicitUnit": {
              "description": "Enable error reporting for expressions with an implied Unit type.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "strictFunctionTypes": {
              "description": "When assigning functions, check to ensure parameters and return values are subtype-compatible.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "strictOptionalChecks": {
              "description": "Strict checking of optional properties and parameters.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "noMissingCasesInMatch": {
              "description": "Require exhaustive pattern matching in match expressions.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "exactOptionalPropertyTypes": {
              "description": "Interpret optional property types as written, rather than adding undefined.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "noUnusedLocals": {
              "description": "Enable error reporting when local variables aren't read.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "noUnusedParameters": {
              "description": "Raise an error when a function parameter isn't read.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "noImplicitReturns": {
              "description": "Enable error reporting for codepaths that do not explicitly return in a function.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "allowUnreachableCode": {
              "description": "Disable error reporting for unreachable code.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "allowUnusedLabels": {
              "description": "Disable error reporting for unused labels.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "forceConsistentCasingInFileNames": {
              "description": "Ensure that casing is correct in imports.",
              "type": [
                "boolean",
                "null"
              ],
              "default": true
            },
            "allowArbitraryExtensions": {
              "description": "Enable importing files with any extension, provided a declaration file is present.",
              "type": [
                "boolean",
                "null"
              ],
              "default": true
            },
            "skipLibCheck": {
              "description": "Skip type checking all library files.",
              "type": [
                "boolean",
                "null"
              ],
              "default": true
            },
            "noEmit": {
              "description": "Disable emitting files from a compilation.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "noEmitOnError": {
              "description": "Disable emitting files if any type checking errors are reported.",
              "type": [
                "boolean",
                "null"
              ],
              "default": true
            },
            "removeComments": {
              "description": "Disable emitting comments.",
              "type": [
                "boolean",
                "null"
              ],
              "default": true
            },
            "composite": {
              "description": "Enable constraints that allow a Musi project to be used with project references.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "incremental": {
              "description": "Enable incremental compilation.",
              "type": [
                "boolean",
                "null"
              ],
              "default": false
            },
            "tsBuildInfoFile": {
              "description": "Specify the path to .msbuildinfo incremental compilation file.",
              "type": [
                "string",
                "null"
              ],
              "default": ".msbuildinfo"
            }
          }
        }
      }
    },
    "referencesDefinition": {
      "properties": {
        "references": {
          "type": "array",
          "uniqueItems": true,
          "description": "Referenced projects for multi-project builds.",
          "items": {
            "type": "object",
            "description": "Project reference.",
            "properties": {
              "path": {
                "type": "string",
                "description": "Path to referenced msconfig or to folder containing msconfig."
              }
            }
          }
        }
      }
    }
  }
}
