{
	"name": "musi-lang-www",
	"private": true,
	"type": "module",
	"scripts": {
		"generate:content": "bun run scripts/generate-content.ts",
		"dev": "bun run generate:content && ASTRO_TELEMETRY_DISABLED=1 astro dev",
		"dev:prod": "bun run build:prod && bun run preview:prod",
		"build": "bun run generate:content && ASTRO_TELEMETRY_DISABLED=1 astro build",
		"build:prod": "bun run build",
		"docs:studio": "bun run scripts/docs-studio.ts",
		"verify:lang": "bun run build:prod && bun run scripts/verify-lang.ts",
		"preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
		"preview:prod": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0",
		"biome:check": "bunx biome check . --max-diagnostics 16384",
		"biome:format": "bunx biome format . --write --max-diagnostics 16384",
		"biome:lint": "bunx biome lint . --max-diagnostics 16384"
	},
	"dependencies": {
		"@astrojs/preact": "^5.1.1",
		"astro": "^6.1.7",
		"preact": "^10.29.1",
		"preact-render-to-string": "^6.6.7"
	},
	"devDependencies": {
		"marked": "^18.0.0",
		"sass": "^1.99.0",
		"shiki": "^4.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4",
		"wrangler": "^4.83.0"
	}
}
