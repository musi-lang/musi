; Musi Language - Formal Grammar
; RFC 5234 ABNF. Maximal munch. Pratt + recursive descent.
; §0  Terminal pseudo-rules
any     = <any Unicode scalar value>

newline = %x0A  ; LINE FEED
; §1  Lexical grammar
; §1.1  Character classes
letter = %x41-5A  ; A-Z / a-z
         / %x61-7A

digit  = %x30-39  ; 0-9

xdigit = digit  ; 0-9 / A-F / a-f
         / %x41-46
         / %x61-66
; §1.2  Identifiers
ident         = plain-ident
                / escaped-ident

plain-ident   = letter *(letter / digit / "_")

escaped-ident = %x60 *(<any except backtick>) %x60  ; `...`

ty-ident      = "'" letter *(letter / digit / "_")

op-ident      = "(" op-chars ")"

op-chars      = "+"
                / "-"
                / "*"
                / "/"
                / "%"
                / "="
                / "/="
                / "<"
                / ">"
                / "<="
                / ">="
                / "::"
; §1.3  Literals
lit         = lit-int
              / lit-float
              / lit-string
              / lit-fstring
              / lit-rune

lit-int     = dec-int
              / hex-int
              / oct-int
              / bin-int

dec-int     = digit *(digit / "_")

hex-int     = "0x" xdigit *(xdigit / "_")

oct-int     = "0o" (%x30-37) *(%x30-37 / "_")  ; 0-7

bin-int     = "0b" ("0" / "1") *(("0" / "1") / "_")

lit-float   = *digit "." 1*digit [("e" / "E") ["+" / "-"] 1*digit]

lit-string  = DQUOTE *(str-char) DQUOTE

lit-fstring = %s"f" DQUOTE *(fstr-part) DQUOTE

lit-rune    = "'" rune-char "'"

fstr-part   = "{" ast-expr "}"
              / str-char

str-char    = "\" any
              / <any except DQUOTE>

rune-char   = "\" any
              / <any except single-quote>
; §1.4  Comments
comment = "//" *(<any except newline>)  ; line
          / "///" *(<any except newline>)  ; doc - documents next item
          / "//!" *(<any except newline>)  ; module doc - documents enclosing module
          / "/*" *(<any except "*/">) "*/"  ; block - does not nest
; §1.5  Keywords (28)
keyword = "and"
          / "as"
          / "choice"
          / "class"
          / "derives"
          / "effect"
          / "export"
          / "fatal"
          / "foreign"
          / "handle"
          / "if"
          / "import"
          / "instance"
          / "law"
          / "let"
          / "match"
          / "mut"
          / "need"
          / "not"
          / "of"
          / "or"
          / "record"
          / "resume"
          / "return"
          / "via"
          / "where"
          / "with"
          / "xor"
; §1.6  Compound tokens - maximal munch
compound-token = ":="
                 / "<-"
                 / "->"
                 / "~>"
                 / "=>"
                 / "/="
                 / "<="
                 / ">="
                 / "?."
                 / "!."
                 / ".["
                 / ".{"
                 / "??"
                 / ".."
                 / "..<"
                 / "..."
                 / "::"
                 / "<:"
                 / ":?"
                 / ":?>"
                 / "|>"
                 / "#["
; §2  Program structure
ast-root = *(ast-stmt)

ast-stmt = ast-expr ";"
; §3  Expressions - Pratt parser
; §3.1  Binding power table
;
;   BP   Operator(s)                 Assoc    Category
;   --   -----------                 -----    --------
;    2   <-                          right    assignment
;    4   ??                          right    nil-coalesce
;    6   |>                          left     pipeline
;    8   or                          left     disjunction
;   10   xor                        left     exclusive-or
;   12   and                        left     conjunction
;   14   = /= < > <= >=             none     comparison
;   16   .. ..<                     none     range
;   17   ::                         right    cons
;   18   + -                        left     additive
;   20   * / %                      left     multiplicative
;   22   - not                      prefix   unary (nud)
;   24   () .[] .{} . ?. !. ? ! ... postfix  postfix (led)
;
;   and/or/xor/not are type-directed: boolean on Bool (short-circuiting), bitwise on integers.
;   Even-numbered BPs leave gaps for future insertion.
; §3.2  Expression core
ast-expr     = prefix-expr *(infix-op prefix-expr)

prefix-expr  = prefix-op prefix-expr
               / postfix-expr

postfix-expr = ast-expr-atom *(postfix-op)
; §3.3  Operator sets
prefix-op = "-"
            / "not"

infix-op  = "<-"  ; assignment
            / "??"  ; nil-coalesce
            / "|>"  ; pipeline
            / "or"
            / "xor"
            / "and"  ; logic
            / "="
            / "/="
            / "<"
            / ">"
            / "<="
            / ">="  ; comparison
            / ".."
            / "..<"  ; range
            / "+"
            / "-"  ; additive
            / "*"
            / "/"
            / "%"  ; multiplicative
            / "::"  ; cons (right-assoc)
; §3.4  Postfix operations
postfix-op = "(" [arg-list] ")"  ; call
             / ".[" [expr-list] "]"  ; index
             / ".{" [rec-lit-fields] "}"  ; record update
             / "." field-target  ; field access
             / "?." field-target  ; optional chain
             / "!." field-target  ; forced unwrap access
             / "?"  ; propagate
             / "!"  ; force unwrap
             / ":?" ast-ty-named ["as" ident]  ; type test
             / ":?>" ast-ty-named  ; type cast
; §4  Atom forms - nud dispatch
; §4.1  Atom dispatch table
;   Each alternative has a unique FIRST token.
;   The parser dispatches on token kind.
ast-expr-atom = lit  ; INT / FLOAT / STRING / FSTRING / RUNE
                / ident  ; IDENT
                / ast-paren  ; LPAREN
                / ast-array  ; LBRACKET
                / ast-rec-lit  ; DOT_LBRACE
                / ast-dot-pfx  ; DOT
                / ast-match  ; KW_MATCH
                / ast-let  ; KW_LET
                / ast-return  ; KW_RETURN
                / ast-resume  ; KW_RESUME
                / ast-import  ; KW_IMPORT
                / ast-choice  ; KW_CHOICE
                / ast-record  ; KW_RECORD
                / ast-need  ; KW_NEED
                / ast-handle  ; KW_WITH
                / ast-foreign-expr  ; KW_FOREIGN
                / ast-with-attrs  ; HASH_LBRACKET
; §4.2  Parenthesised forms
;
;   ()       unit          (,)  empty tuple     (;)  empty sequence -> ()
;   (a)      grouped       (a,) 1-tuple         (a, b) tuple
;   (a; b)   sequence -> b (a; b;) sequence -> ()
;   (e if g | e if _)  piecewise
;   (params) => body    lambda (paren contents reinterpreted as params)
ast-paren  = "(" paren-body ")" [fn-tail]

fn-tail    = [":" ast-ty] "=>" ast-expr

paren-body = <empty>  ; unit: ()
             / ","  ; empty tuple: (,)
             / ";"  ; empty sequence: (;)
             / ast-expr paren-cont

paren-cont = <empty>  ; parenthesised expr
             / "," [expr-list] [","]  ; tuple
             / ";" [seq-tail]  ; sequence
             / "if" pw-guard *("|" pw-arm)  ; piecewise

seq-tail   = <empty>  ; trailing ;, returns ()
             / ast-expr seq-cont

seq-cont   = <empty>  ; returns last expr
             / ";" [seq-tail]  ; continue sequence
; §4.3  Piecewise - sole conditional form
pw-arm   = ast-expr "if" pw-guard

pw-guard = "_"
           / ast-expr
; §4.4  Match
ast-match = "match" ast-expr "(" match-arm *("|" match-arm) ")"

match-arm = [attrs] ast-pat ["if" ast-expr] "=>" ast-expr
; §4.5  Arrays
ast-array   = "[" [array-items] "]"

array-items = array-item *("," array-item)

array-item  = spread
              / ast-expr
; §4.6  Record literals
ast-rec-lit    = ".{" [rec-lit-fields] "}"

rec-lit-fields = rec-lit-field *("," rec-lit-field)

rec-lit-field  = ident [":=" ast-expr]
                 / spread
; §4.7  Bindings
ast-let        = "let" ["mut"] ast-pat [bracket-params] [where-clause] [with-clause] [ty-annot] ":=" ast-expr

bracket-params = "[" ty-ident *("," ty-ident) "]"

with-clause    = "with" effect-set
; §4.8  Type definitions
ast-choice     = "choice" "{" ast-ty "}"

ast-record     = "record" "{" rec-def-fields "}"

rec-def-fields = rec-def-field *(";" rec-def-field)

rec-def-field  = ident ":" ast-ty [":=" ast-expr]
; §4.9  Simple atoms
ast-dot-pfx      = "." ident ["(" [expr-list] ")"]

ast-return       = "return" [ast-expr]

ast-resume       = "resume" [ast-expr]

ast-import       = "import" lit-string ["as" ident]

ast-foreign-expr = "foreign" [lit-string] "import" lit-string

ast-need         = "need" postfix-expr

ast-handle       = "with" ast-ty-named "{" *(fn-decl [";"]) "}" "handle" ast-expr
; §5  Types
; §5.1  Type precedence
;   arrow (right) > sum (left) > product (left) > base
ast-ty       = ast-ty-arrow

ast-ty-arrow = ast-ty-sum [("->" / "~>") ast-ty-arrow]

ast-ty-sum   = ast-ty-prod *("+" ast-ty-prod)

ast-ty-prod  = ast-ty-base *("*" ast-ty-base)
; §5.2  Base types
ast-ty-base = ty-ident  ; 'T
              / "?" ast-ty-base  ; ?T - option sugar
              / ident ["of" ty-arg-list]  ; Named, Named of T
              / "(" ident ":" ast-ty ")" "->" ast-ty  ; pi type
              / "(" ast-ty ")"  ; grouped type
              / "[" [lit-int] "]" ast-ty  ; array type
; §5.3  Named types and arguments
ty-arg-list  = ast-ty *("," ast-ty)

ty-annot     = ":" ast-ty

ast-ty-named = ident ["of" ty-arg-list]
; §5.4  Effects and constraints
effect-set   = "{" effect-list "}"

effect-list  = effect-item *("," effect-item)

effect-item  = ident ["of" ast-ty]
               / ty-ident

where-clause = "where" constraint *("," constraint)

constraint   = ty-ident "<:" ast-ty-named
               / ty-ident ":" ast-ty-named
; §6  Patterns
ast-pat         = ast-pat-primary ["or" ast-pat-primary *("or" ast-pat-primary)]

ast-pat-primary = "_"  ; wildcard
                  / lit  ; literal
                  / ident [pat-suffix]  ; bind, destructor, or named record
                  / ident "as" ast-pat-primary  ; as-pattern
                  / "." ident ["(" [pat-list] ")"]  ; variant
                  / ".{" [rec-pat-fields] "}"  ; record pattern
                  / "(" [pat-list] ")"  ; tuple / grouped
                  / "[" [pat-list] "]"  ; array

pat-suffix      = "(" [pat-list] ")"
                  / "{" [rec-pat-fields] "}"

rec-pat-fields  = rec-pat-field *("," rec-pat-field)

rec-pat-field   = ["mut"] ident [":" ast-pat]

pat-list        = ast-pat *("," ast-pat)
; §7  Declarations
; §7.1  Attributes
attrs                  = 1*attr

attr                   = "#[" attr-body *("," attr-body) "]"

attr-body              = ident [":=" attr-value / "(" attr-params ")"]

attr-params            = attr-named-fields
                         / attr-positional-params

attr-positional-params = lit *("," lit)

attr-value             = lit
                         / "(" lit *("," lit) ")"

attr-named-fields      = attr-named-field *("," attr-named-field)

attr-named-field       = ident ":=" lit
; §7.2  Declaration dispatch
ast-with-attrs = attrs ast-decl

ast-decl       = "export" export-tail
                 / ast-let
                 / ast-class-decl
                 / ast-instance-decl
                 / ast-effect-decl
                 / ast-foreign-decl
; §7.3  Exports
export-tail = ast-let
              / ast-foreign-decl
              / ast-class-decl
              / ast-instance-decl
              / ast-effect-decl
; §7.4  Classes and instances
ast-class-decl    = "class" ident [bracket-params] [where-clause] "{" *(class-member) "}"

ast-instance-decl = "instance" [bracket-params] [where-clause] ast-ty-named instance-body

instance-body     = "{" *(class-member) "}"
                    / "via" ast-ty-named
                    / "derives" ident *("," ident)
; §7.5  Effects
ast-effect-decl = "effect" ident [bracket-params] [where-clause] "{" *(effect-member [";"]) "}"

effect-member   = ["fatal"] fn-decl
                  / law-decl
; §7.6  Foreign
ast-foreign-decl = "foreign" [lit-string] ("let" foreign-binding / "(" *(("let" foreign-binding) ";") ")" / "import" lit-string)

foreign-binding  = [attrs] ident [bracket-params] ["as" lit-string] [where-clause] [":" ast-ty]
; §7.7  Members
class-member = (fn-decl / law-decl) [";"]

fn-decl      = "let" op-or-ident [params] [ty-annot] [":=" ast-expr]

law-decl     = "law" ident [params] ":=" ast-expr

op-or-ident  = ident
               / op-ident
; §8  Shared helpers
spread       = "..." ast-expr

field-target = ident
               / lit-int

expr-list    = ast-expr *("," ast-expr)

arg-list     = arg *("," arg)

arg          = spread
               / ast-expr

params       = "(" [param-list] ")"

param-list   = param *("," param)

param        = ["mut"] ident [ty-annot] [":=" ast-expr]
