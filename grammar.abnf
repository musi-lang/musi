; Musi Language - Formal Grammar (v2)
; RFC 5234 ABNF. Maximal munch. Pratt + recursive descent.
; Array-processor model. Everything bound via `let`.
; §0  Terminal pseudo-rules
any     = <any Unicode scalar value>

newline = %x0A
; §1  Lexical grammar
; §1.1  Character classes
letter = %x41-5A
         / %x61-7A  ; A-Z / a-z

digit  = %x30-39  ; 0-9

xdigit = digit
         / %x41-46
         / %x61-66  ; 0-9 / A-F / a-f
; §1.2  Identifiers
ident         = plain-ident
                / escaped-ident

plain-ident   = letter *(letter / digit / "_")

escaped-ident = %x60 *(<any except backtick>) %x60  ; `...`

op-ident      = "(" op-chars ")"

op-chars      = "+"
                / "-"
                / "*"
                / "/"
                / "%"
                / "="
                / "/="
                / "<"
                / ">"
                / "<="
                / ">="
                / "::"
; §1.3  Literals
lit         = lit-int
              / lit-float
              / lit-string
              / lit-fstring
              / lit-rune

lit-int     = dec-int
              / hex-int
              / oct-int
              / bin-int

dec-int     = digit *(digit / "_")

hex-int     = "0x" xdigit *(xdigit / "_")

oct-int     = "0o" (%x30-37) *(%x30-37 / "_")

bin-int     = "0b" ("0" / "1") *(("0" / "1") / "_")

lit-float   = *digit "." 1*digit [("e" / "E") ["+" / "-"] 1*digit]

lit-string  = DQUOTE *(str-char) DQUOTE

lit-fstring = %s"f" DQUOTE *(fstr-part) DQUOTE

lit-rune    = "'" rune-char "'"

fstr-part   = "{" ast-expr "}"
              / str-char

str-char    = "\" any
              / <any except DQUOTE>

rune-char   = "\" any
              / <any except single-quote>
; §1.4  Comments
comment = "///" *(<any except newline>)  ; line doc (doc=true)
          / "//" *(<any except newline>)  ; line (doc=false)
          / "/**" *(<any except "*/">) "*/"  ; block doc (doc=true)
          / "/*" *(<any except "*/">) "*/"  ; block (doc=false)
; §1.5  Keywords (28)
keyword = "and"
          / "as"
          / "case"
          / "class"
          / "data"
          / "effect"
          / "export"
          / "foreign"
          / "handle"
          / "if"
          / "import"
          / "in"
          / "instance"
          / "law"
          / "let"
          / "mut"
          / "need"
          / "not"
          / "of"
          / "opaque"
          / "or"
          / "quote"
          / "resume"
          / "return"
          / "via"
          / "where"
          / "with"
          / "xor"
; §1.6  Compound tokens - maximal munch
compound-token = ":="
                 / "<-"
                 / "->"
                 / "~>"
                 / "=>"
                 / "/="
                 / "<="
                 / ">="
                 / "<:"
                 / "?."
                 / "!."
                 / "??"
                 / ".."
                 / "..<"
                 / "..."
                 / ".{"
                 / ".["
                 / ":?"
                 / ":?>"
                 / "|>"
                 / "::"
; §1.7  Special prefixes
attr-prefix   = "@"

splice-prefix = "#"
; §2  Program structure
ast-root = *(ast-stmt)

ast-stmt = ast-expr ";"
; §3  Expressions - Pratt parser
; §3.1  Binding power table
;
;   BP   Operator(s)                Assoc    Category
;   --   -----------                -----    --------
;    2   <-                         right    assignment
;    4   ??                         right    nil-coalesce
;    6   |>                         left     pipeline
;    8   or                         left     disjunction
;   10   xor                        left     exclusive-or
;   12   and                        left     conjunction
;   14   = /= < > <= >=             none     comparison
;   16   .. ..<                     none     range
;   17   ::                         right    cons
;   18   + -                        left     additive
;   20   * / %                      left     multiplicative
;   22   - not mut                  prefix   unary (nud)
;   24   () .[] .{} . ?. !. ? ! ... postfix  postfix (led)
;
;   and/or/xor/not are type-directed:
;     Bool → logical (short-circuit)
;     Int  → bitwise
; §3.2  Expression core
ast-expr     = prefix-expr *(infix-op prefix-expr)

prefix-expr  = prefix-op prefix-expr
               / postfix-expr

postfix-expr = ast-expr-atom *(postfix-op)
; §3.3  Operator sets
prefix-op = "-"
            / "not"
            / "mut"

infix-op  = "<-"  ; assignment
            / "??"  ; nil-coalesce
            / "|>"  ; pipeline
            / "or"
            / "xor"
            / "and"  ; logic/bitwise
            / "="
            / "/="
            / "<"
            / ">"
            / "<="
            / ">="  ; comparison
            / ".."
            / "..<"  ; range
            / "::"  ; cons (right-assoc)
            / "+"
            / "-"  ; additive
            / "*"
            / "/"
            / "%"  ; multiplicative
; §3.4  Postfix operations
postfix-op = "(" [arg-list] ")"  ; call
             / ".[" [expr-list] "]"  ; index
             / ".{" [rec-lit-fields] "}"  ; record update
             / "." field-target  ; field access
             / "?." field-target  ; optional chain
             / "!." field-target  ; forced unwrap access
             / "?"  ; propagate
             / "!"  ; force unwrap
             / ":?" ast-ty-named ["as" ident]  ; type test
             / ":?>" ast-ty-named  ; type cast
; §4  Atom forms - nud dispatch
;   Each alternative has a unique FIRST token.
;   The parser dispatches on token kind.
ast-expr-atom = lit  ; INT / FLOAT / STRING / FSTRING / RUNE
                / splice  ; $ (splice - only valid inside quote)
                / ident  ; IDENT
                / ast-paren  ; LPAREN
                / ast-array  ; LBRACKET
                / ast-rec-lit  ; DOT_LBRACE
                / ast-dot-pfx  ; DOT
                / ast-case  ; KW_CASE
                / ast-let  ; KW_LET
                / ast-return  ; KW_RETURN
                / ast-resume  ; KW_RESUME
                / ast-import  ; KW_IMPORT
                / ast-data  ; KW_DATA
                / ast-effect  ; KW_EFFECT
                / ast-class  ; KW_CLASS
                / ast-need  ; KW_NEED
                / ast-handle  ; KW_WITH
                / ast-foreign-expr  ; KW_FOREIGN
                / ast-quote  ; KW_QUOTE
                / ast-with-attrs  ; AT
; §4.1  Parenthesised forms
;
;   ()       unit          (,)  empty tuple     (;)  empty sequence → ()
;   (a)      grouped       (a,) 1-tuple         (a, b) tuple
;   (a; b)   sequence → b  (a; b;) sequence → ()
;   (e if g | e if _)  piecewise
;   (params) => body    lambda (paren contents reinterpreted as params)
ast-paren  = "(" paren-body ")" [fn-tail]

fn-tail    = [":" ast-ty] "=>" ast-expr

paren-body = <empty>  ; unit: ()
             / ","  ; empty tuple: (,)
             / ";"  ; empty sequence: (;)
             / "|" pw-arm *("|" pw-arm) ["|"]  ; piecewise with leading |
             / ast-expr paren-cont

paren-cont = <empty>  ; parenthesised expr
             / "," [expr-list] [","]  ; tuple
             / ";" [seq-tail]  ; sequence
             / "if" pw-guard *("|" pw-arm) ["|"]  ; piecewise (trailing | allowed)

seq-tail   = <empty>  ; trailing ;, returns ()
             / ast-expr seq-cont

seq-cont   = <empty>  ; returns last expr
             / ";" [seq-tail]  ; continue sequence
; §4.2  Piecewise - sole conditional form
pw-arm   = ast-expr "if" pw-guard

pw-guard = "_"
           / ast-expr
; §4.3  Case
ast-case = "case" ast-expr "of" "(" ["|"] case-arm *("|" case-arm) ["|"] ")"  ; leading/trailing | allowed

case-arm = [attrs] ast-pat ["if" ast-expr] "=>" ast-expr
; §4.4  Arrays, matrices, comprehensions
;
;   [a, b, c]            array
;   [a, b; c, d]         matrix (;=row separator)
;   [expr | pat in expr] comprehension
ast-array      = "[" [array-body] "]"

array-body     = ast-expr array-dispatch

array-dispatch = <empty>  ; single-element array
                 / "," [array-items]  ; array continuation
                 / ";" array-row *(";" array-row)  ; matrix
                 / "|" comp-clause *("," comp-clause) [","]  ; comprehension (trailing , allowed)

array-items    = array-item *("," array-item)

array-item     = spread
                 / ast-expr

array-row      = ast-expr *("," ast-expr)

comp-clause    = ast-pat "in" ast-expr  ; generator (in is keyword)
                 / ast-expr  ; filter
; §4.5  Record literals
ast-rec-lit    = ".{" [rec-lit-fields] "}"

rec-lit-fields = rec-lit-field *("," rec-lit-field)

rec-lit-field  = ident [":=" ast-expr]
                 / spread
; §4.6  Bindings
;
;   let pat := expr                   simple binding
;   let mut pat := expr               mutable binding
;   let f (params) := body            function definition
;   let f (params) : Ret := body      function with return type
;   let f [T] (params) := body        generic function
ast-let        = "let" ["mut"] ast-pat [params] [bracket-params] [where-clause] [with-clause] [ty-annot] ":=" ast-expr

bracket-params = "[" ident *("," ident) [","] "]"  ; trailing , allowed

with-clause    = "with" effect-set
; §4.7  Type definitions (anonymous - always bound via let)
ast-data       = "data" "{" data-body "}"

data-body      = variant-list  ; sum type
                 / rec-def-fields  ; product type
                 / "|"  ; empty sum (Never)
                 / ";"  ; empty product (Unit)

variant-list   = ["|"] variant *("|" variant) ["|"]  ; leading/trailing | allowed

variant        = [attrs] ident [":" ast-ty] [":=" ast-expr]

rec-def-fields = [";"] rec-def-field *(";" rec-def-field) [";"]  ; leading/trailing ; allowed

rec-def-field  = ident ":" ast-ty [":=" ast-expr]
; §4.8  Effects (anonymous - always bound via let)
ast-effect    = "effect" "{" *(effect-member [";"]) "}"

effect-member = fn-decl
                / law-decl
; §4.9  Classes (anonymous - always bound via let)
ast-class    = "class" [where-clause] "{" *(class-member) "}"

class-member = (fn-decl / law-decl) [";"]
; §4.10  Simple atoms
ast-dot-pfx      = "." ident ["(" [expr-list] ")"]

ast-return       = "return" [ast-expr]

ast-resume       = "resume" [ast-expr]

ast-import       = "import" lit-string ["as" (ident / "_" / ident ".{" ident-list [","] "}")]  ; trailing , in selective

ast-foreign-expr = "foreign" [lit-string] ("import" lit-string / "let" foreign-binding / "(" *(foreign-binding ";") ")")

ast-need         = "need" postfix-expr

ast-handle       = "with" ast-ty-named "{" *(fn-decl [";"]) "}" "handle" ast-expr
; §4.11  Quote and splice - metaprogramming
ast-quote = "quote" ("(" ast-expr ")" / "{" *(ast-stmt) "}")

splice    = "#" ident  ; splice identifier
            / "#(" ast-expr ")"  ; splice expression
            / "#[" expr-list "]"  ; splice array (splat)
; §5  Types
; §5.1  Type precedence
;   arrow (right) > sum/+ (left) > product/* (left) > base
ast-ty         = ast-ty-arrow

ast-ty-arrow   = ast-ty-sum [("->" / "~>") ast-ty-arrow]

ast-ty-sum     = ast-ty-product *("+" ast-ty-product)

ast-ty-product = ast-ty-base *("*" ast-ty-base)
; §5.2  Base types
ast-ty-base = "mut" ast-ty-base  ; mut T - mutable type (mut T <: T)
              / ident ["of" ty-arg-list]  ; Named, Named of T
              / "?" ast-ty-base  ; ?T - option sugar
              / "(" ident ":" ast-ty ")" "->" ast-ty  ; pi type
              / "(" [ast-ty *("," ast-ty)] ")"  ; grouped or tuple type
              / "[" [dim-list] "]" ast-ty  ; array type
; §5.3  Named types, arguments, dimensions
ty-arg-list  = ast-ty *("," ast-ty) [","]  ; trailing , allowed

ty-annot     = ":" ast-ty

ast-ty-named = ident ["of" ty-arg-list]

dim-list     = dim *("," dim)

dim          = lit-int
               / ident
               / "_"  ; static / variable / inferred
; §5.4  Effects and constraints
effect-set   = "{" effect-list "}"

effect-list  = effect-item *("," effect-item)

effect-item  = ident ["of" ast-ty]
               / ident

where-clause = "where" constraint *("," constraint) [","]  ; trailing , allowed

constraint   = ident "<:" ast-ty-named  ; subtype
               / ident ":" ast-ty-named  ; implements class
; §6  Patterns
ast-pat         = ast-pat-primary ["or" ast-pat-primary *("or" ast-pat-primary)]

ast-pat-primary = "_"  ; wildcard
                  / lit  ; literal
                  / ident ["as" ast-pat-primary]  ; bind or as-pattern
                  / "." ident ["(" [pat-list] ")"]  ; variant
                  / ".{" [rec-pat-fields] "}"  ; record pattern
                  / "(" [pat-list] ")"  ; tuple / grouped
                  / "[" [pat-list] "]"  ; array

rec-pat-fields  = rec-pat-field *("," rec-pat-field)

rec-pat-field   = ["mut"] ident [":" ast-pat]

pat-list        = ast-pat *("," ast-pat)
; §7  Declarations
; §7.1  Attributes
attrs     = 1*attr

attr      = "@" ident ["(" attr-args ")"]

attr-args = attr-arg *("," attr-arg)

attr-arg  = ident ":=" ast-expr  ; named argument
            / ast-expr  ; positional argument
; §7.2  Declaration dispatch
ast-with-attrs = attrs ast-decl

ast-decl       = "export" export-tail
                 / ast-let
                 / ast-instance-decl
; §7.3  Exports
export-tail = ["opaque"] ["foreign" [lit-string]] ("let" let-rest / "(" *(foreign-binding ";") ")")
              / ast-instance-decl

let-rest    = ["mut"] ast-pat [params] [bracket-params] [where-clause] [with-clause] [ty-annot] [":=" ast-expr]
; §7.4  Instances
ast-instance-decl = "instance" [bracket-params] [where-clause] ast-ty-named instance-body

instance-body     = "{" *(class-member) "}"
                    / "via" ast-ty-named
; §7.5  Foreign
foreign-binding = [attrs] ident [bracket-params] ["as" lit-string] [where-clause] [":" ast-ty]
; §7.6  Members
fn-decl     = "let" op-or-ident [params] [ty-annot] [":=" ast-expr]

law-decl    = "law" ident [params] ":=" ast-expr

op-or-ident = ident
              / op-ident
; §8  Shared helpers
spread       = "..." ast-expr

field-target = ident
               / lit-int

expr-list    = ast-expr *("," ast-expr)

ident-list   = ident *("," ident)

arg-list     = arg *("," arg)

arg          = spread
               / ast-expr

params       = "(" [param-list] ")"

param-list   = param *("," param)

param        = ["mut"] ident [ty-annot] [":=" ast-expr]
