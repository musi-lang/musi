{
	"name": "musi-website-workspace",
	"private": true,
	"packageManager": "bun@1.3.12",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"generate:content": "bun run --cwd apps/www generate:content",
		"dev": "bun run --cwd apps/www dev",
		"build": "bun run --cwd apps/www build",
		"check": "bun run generate:content && bun run typecheck && bun run biome:check",
		"test": "bun run generate:content && bun run test:run",
		"test:run": "bunx vitest run",
		"typecheck": "bunx tsc -p apps/www/tsconfig.json --noEmit",
		"preview": "bun run --cwd apps/www preview",
		"biome:check": "bunx biome check . --max-diagnostics 16384",
		"biome:format": "bunx biome format . --write --max-diagnostics 16384",
		"biome:lint": "bunx biome lint . --max-diagnostics 16384"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@types/bun": "1.3.12",
		"@types/node": "25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"bun-types": "1.3.12",
		"jsdom": "29.0.2",
		"typescript": "6.0.2",
		"vitest": "4.1.4"
	}
}
