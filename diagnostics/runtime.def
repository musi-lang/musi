catalog runtime musi_rt RuntimeDiagKind crates/musi_rt/src/diag_catalog_gen.rs

diag RootModuleRequired 6000
  message "runtime root module required"
  primary "runtime root module required"

diag MissingModuleSource 6001
  message "missing runtime module source `{spec}`"
  primary "missing runtime module source `{spec}`"

diag InvalidSyntaxValue 6002
  message "syntax value expected, found `{found}`"
  primary "syntax value expected here"

diag SessionFailed 6003
  message "runtime session `{phase}` failed (`{detail}`)"
  primary "runtime session `{phase}` failed"

diag VmExecutionFailed 6004
  message "VM execution failed (`{source}`)"
  primary "VM execution failed"

map runtime_error_kind crate::RuntimeErrorKind required
  case "RootModuleRequired" RootModuleRequired
  case "MissingModuleSource { .. }" MissingModuleSource
  case "InvalidSyntaxValue { .. }" InvalidSyntaxValue
  case "SessionFailed { .. }" SessionFailed
  case "VmExecutionFailed(_)" VmExecutionFailed
end
