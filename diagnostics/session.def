catalog session music_session SessionDiagKind crates/music_session/src/diag_catalog_gen.rs

diag ModuleNotRegistered 5200
  message "module `{key}` not registered"

diag SourceMapUpdateFailed 5201
  message "source map update failed (`{kind}`)"
  primary "source map update failed"

diag ModuleParseFailed 5202
  message "module `{module}` parse failed"

diag ModuleResolveFailed 5203
  message "module `{module}` resolve failed"

diag ModuleSemanticCheckFailed 5204
  message "module `{module}` semantic check failed"

diag ModuleLoweringFailed 5205
  message "module `{module}` lowering failed"

diag ModuleEmissionFailed 5206
  message "module `{module}` emission failed"

diag LawSuiteSynthesisFailed 5207
  message "module `{module}` law-suite synthesis failed (`{reason}`)"
  primary "module `{module}` law-suite synthesis failed"

diag ArtifactTransportFailed 5208
  message "artifact transport failed (`{source}`)"
  primary "artifact transport failed"

diag SourceRegistryOverflow 5209
  message "source registry overflow"

diag SourceTooLarge 5210
  message "source text `{len}` bytes exceeds limit"

map session_error_kind crate::SessionError required
  case "ModuleNotRegistered { .. }" ModuleNotRegistered
  case "SourceMapUpdateFailed { .. }" SourceMapUpdateFailed
  case "ModuleParseFailed { .. }" ModuleParseFailed
  case "ModuleResolveFailed { .. }" ModuleResolveFailed
  case "ModuleSemanticCheckFailed { .. }" ModuleSemanticCheckFailed
  case "ModuleLoweringFailed { .. }" ModuleLoweringFailed
  case "ModuleEmissionFailed { .. }" ModuleEmissionFailed
  case "LawSuiteSynthesisFailed { .. }" LawSuiteSynthesisFailed
  case "ArtifactTransportFailed(_)" ArtifactTransportFailed
end

map session_source_map_error_kind crate::SessionSourceMapError required
  case "SourceRegistryOverflow" SourceRegistryOverflow
  case "SourceTooLarge { .. }" SourceTooLarge
end
