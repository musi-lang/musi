catalog syntax music_syntax SyntaxDiagKind crates/music_syntax/src/diag_catalog_gen.rs

diag InvalidChar 1200
  message "character `{ch}` invalid"
  primary "character `{ch}` not valid here"

diag UnterminatedStringLiteral 1201
  message "missing closing `\"` in string literal"
  primary "string starts here"

diag UnterminatedRuneLiteral 1202
  message "missing closing `'` in rune literal"
  primary "rune starts here"

diag EmptyRuneLiteral 1203
  message "rune literal needs unicode scalar"
  primary "rune literal needs unicode scalar"

diag RuneLiteralTooLong 1204
  message "rune literal contains multiple unicode scalars"
  primary "rune literal payload too long"

diag UnterminatedBlockComment 1205
  message "missing closing `-/` in block comment"
  primary "comment starts here"

diag UnterminatedTemplateLiteral 1206
  message "missing closing ``` in template literal"
  primary "template starts here"

diag MissingDigitsAfterBasePrefix 1207
  message "missing digits after base `{base}` prefix"
  primary "base `{base}` prefix needs digits"

diag InvalidDigitForBase 1208
  message "digit `{ch}` invalid in base `{base}` literal"
  primary "digit `{ch}` not valid for base `{base}`"

diag UnexpectedUnderscoreInNumberLiteral 1209
  message "number literal `_` unexpected"
  primary "underscore cannot appear here"

diag MissingDigitAfterUnderscoreInNumberLiteral 1210
  message "missing digit after `_` in number literal"
  primary "missing digit after `_`"

diag MissingExponentDigits 1211
  message "missing exponent digits"
  primary "exponent marker needs digits"

diag MissingEscapeCode 1212
  message "missing escape code"
  primary "missing escape code after `\\`"

diag UnexpectedEscape 1213
  message "unexpected escape `\\{ch}`"

diag MissingHexDigitsInByteEscape 1214
  message "missing hex digits in `\\x` escape"
  primary "missing hex digits after `\\x`"

diag InvalidHexDigitInByteEscape 1215
  message "invalid hex digit `{ch}` in `\\x` escape"
  primary "hex digit `{ch}` not valid here"

diag MissingHexDigitsInUnicodeEscape 1216
  message "missing hex digits in `\\u` escape"
  primary "missing hex digits after `\\u`"

diag InvalidHexDigitInUnicodeEscape 1217
  message "invalid hex digit `{ch}` in `\\u` escape"
  primary "hex digit `{ch}` not valid here"

diag ExpectedFourOrSixHexDigitsInUnicodeEscape 1218
  message "`\\u` escape needs 4 or 6 hex digits"
  primary "`\\u` escape length must be 4 or 6 hex digits"

diag InvalidUnicodeScalar 1219
  message "unicode scalar `U+{value}` invalid"
  primary "unicode scalar `U+{value}` not valid"

diag ExpectedToken 1300
  message "token expected {expected}, found {found}"
  primary "found {found} here"

diag ExpectedExpression 1301
  message "expression expected, found {found}"
  primary "found {found} here"

diag ExpectedPattern 1302
  message "pattern expected, found {found}"
  primary "found {found} here"

diag ExpectedMember 1303
  message "member expected, found {found}"
  primary "found {found} here"

diag ExpectedIdentifier 1304
  message "identifier expected, found {found}"
  primary "found {found} here"

diag ExpectedSpliceTarget 1305
  message "splice target expected, found {found}"
  primary "found {found} here"

diag ExpectedOperatorMemberName 1306
  message "operator member name expected, found {found}"
  primary "found {found} here"

diag ExpectedFieldTarget 1307
  message "field name or tuple index expected, found {found}"
  primary "found {found} here"

diag ExpectedConstraintOperator 1308
  message "constraint operator `<:` or `:` expected, found {found}"
  primary "found {found} here"

diag ExpectedAttrValue 1309
  message "attribute value expected, found {found}"
  primary "found {found} here"

diag SpliceOutsideQuote 1310
  message "splice only valid inside quote"
  primary "splice appears outside quote"

diag NonAssociativeChain 1311
  message "comparison chain needs grouping"
  primary "chain continues here"
  help "parenthesize comparison"

diag ReservedKeywordIdentifier 1312
  message "reserved keyword {keyword} cannot name identifier"
  primary "{keyword} found where identifier required"
  help "choose non-keyword identifier"

map lex_error_kind copy:super::LexErrorKind required
  case "InvalidChar { .. }" InvalidChar
  case "UnterminatedStringLiteral" UnterminatedStringLiteral
  case "UnterminatedRuneLiteral" UnterminatedRuneLiteral
  case "EmptyRuneLiteral" EmptyRuneLiteral
  case "RuneLiteralTooLong" RuneLiteralTooLong
  case "UnterminatedBlockComment" UnterminatedBlockComment
  case "UnterminatedTemplateLiteral" UnterminatedTemplateLiteral
  case "MissingDigitsAfterBasePrefix { .. }" MissingDigitsAfterBasePrefix
  case "InvalidDigitForBase { .. }" InvalidDigitForBase
  case "UnexpectedUnderscoreInNumberLiteral" UnexpectedUnderscoreInNumberLiteral
  case "MissingDigitAfterUnderscoreInNumberLiteral" MissingDigitAfterUnderscoreInNumberLiteral
  case "MissingExponentDigits" MissingExponentDigits
  case "MissingEscapeCode" MissingEscapeCode
  case "UnexpectedEscape { .. }" UnexpectedEscape
  case "MissingHexDigitsInByteEscape" MissingHexDigitsInByteEscape
  case "InvalidHexDigitInByteEscape { .. }" InvalidHexDigitInByteEscape
  case "MissingHexDigitsInUnicodeEscape" MissingHexDigitsInUnicodeEscape
  case "InvalidHexDigitInUnicodeEscape { .. }" InvalidHexDigitInUnicodeEscape
  case "ExpectedFourOrSixHexDigitsInUnicodeEscape" ExpectedFourOrSixHexDigitsInUnicodeEscape
  case "InvalidUnicodeScalar { .. }" InvalidUnicodeScalar
end

map parse_error_kind copy:super::ParseErrorKind required
  case "ExpectedToken { .. }" ExpectedToken
  case "ExpectedExpression { .. }" ExpectedExpression
  case "ExpectedPattern { .. }" ExpectedPattern
  case "ExpectedMember { .. }" ExpectedMember
  case "ExpectedIdentifier { .. }" ExpectedIdentifier
  case "ReservedKeywordIdentifier { .. }" ReservedKeywordIdentifier
  case "ExpectedSpliceTarget { .. }" ExpectedSpliceTarget
  case "ExpectedOperatorMemberName { .. }" ExpectedOperatorMemberName
  case "ExpectedFieldTarget { .. }" ExpectedFieldTarget
  case "ExpectedConstraintOperator { .. }" ExpectedConstraintOperator
  case "ExpectedAttrValue { .. }" ExpectedAttrValue
  case "SpliceOutsideQuote" SpliceOutsideQuote
  case "NonAssociativeChain" NonAssociativeChain
end
