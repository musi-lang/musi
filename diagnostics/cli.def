catalog cli musi CliDiagKind crates/musi/src/diag_catalog_gen.rs

diag MissingCurrentDirectory 5300
  message "current directory unavailable"
  primary "current directory unavailable"

diag TaskFailed 5301
  message "task `{name}` failed"
  primary "task `{name}` failed"

diag UnsupportedRunArgs 5302
  message "unsupported musi run argument `{argument}`"
  primary "unsupported musi run argument `{argument}`"

diag PackageAlreadyInitialized 5303
  message "package path `{path}` already initialized"
  primary "package path `{path}` already initialized"

diag MissingPackageName 5304
  message "package name unavailable for `{path}`"
  primary "package name unavailable for `{path}`"

diag UnknownTarget 5305
  message "missing target `{target}` in project"
  primary "missing target `{target}`"

diag CheckCommandFailed 5306
  message "musi check command failed"
  primary "musi check command failed"

diag CommandUnavailable 5307
  message "command `{command}` unavailable because `{feature}` not implemented"
  primary "command `{command}` unavailable"

diag LspServerFailed 5308
  message "LSP server failed (`{message}`)"
  primary "LSP server failed"

diag IncompatibleCommandArgs 5309
  message "incompatible command arguments `{left}` and `{right}`"
  primary "incompatible command arguments `{left}` and `{right}`"

map cli_error_kind crate::MusiError option
  case "ProjectModelFailed(_)" none
  case "SessionCompilationFailed(_)" none
  case "RuntimeExecutionFailed(_)" none
  case "ToolingIoFailed(_)" none
  case "FormattingFailed(_)" none
  case "JsonSerializationFailed(_)" none
  case "MissingCurrentDirectory" MissingCurrentDirectory
  case "TaskFailed { .. }" TaskFailed
  case "UnsupportedRunArgs { .. }" UnsupportedRunArgs
  case "PackageAlreadyInitialized { .. }" PackageAlreadyInitialized
  case "MissingPackageName { .. }" MissingPackageName
  case "UnknownTarget { .. }" UnknownTarget
  case "CheckCommandFailed" CheckCommandFailed
  case "CommandUnavailable { .. }" CommandUnavailable
  case "LspServerFailed { .. }" LspServerFailed
  case "IncompatibleCommandArgs { .. }" IncompatibleCommandArgs
end
