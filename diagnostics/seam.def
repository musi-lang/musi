map assembly_error_kind crate::AssemblyError required
  case "ArtifactValidationFailed(_)" ArtifactValidationFailed
  case "InvalidBinaryHeader" InvalidBinaryHeader
  case "UnsupportedBinaryVersion(_)" UnsupportedBinaryVersion
  case "UnknownSectionTag(_)" UnknownSectionTag
  case "BinaryPayloadTruncated" BinaryPayloadTruncated
  case "UnknownOpcode(_)" UnknownOpcode
  case "TextParseFailed(_)" TextParseFailed
end

map artifact_error_kind crate::ArtifactError required
  case "InvalidReference { .. }" InvalidReference
  case "DuplicateLabel { .. }" DuplicateLabel
  case "MissingLabel { .. }" MissingLabel
  case "InvalidEffectOp" InvalidEffectOp
  case "OperandShapeMismatch { .. }" OperandShapeMismatch
end

map hil_verify_error_kind crate::HilVerifyError required
  case "MissingEntryBlock { .. }" HilMissingEntryBlock
  case "DuplicateBlock { .. }" HilDuplicateBlock
  case "DuplicateValue { .. }" HilDuplicateValue
  case "UndefinedValue { .. }" HilUndefinedValue
  case "TypeMismatch { .. }" HilTypeMismatch
  case "MissingBlockTarget { .. }" HilMissingBlockTarget
  case "ReturnTypeMismatch { .. }" HilReturnTypeMismatch
  case "ReturnValueMissing { .. }" HilReturnValueMissing
  case "ReturnValueUnexpected" HilReturnValueUnexpected
  case "CapabilityRequired { .. }" HilCapabilityRequired
end
