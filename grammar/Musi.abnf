; Musi Language - Surface Syntax (RFC 5234 ABNF)
;
; Canonical, tool-supported grammar:
;   `grammar/MusiLexer.g4` and `grammar/MusiParser.g4` (ANTLR4)
;
; This file is a strict RFC 5234 ABNF specification of the Musi surface syntax.
; It is kept aligned with the ANTLR grammar pair, but does not attempt to model
; lexer implementation details (priority / maximal munch) inside ABNF.
;
; Notes:
; - The grammar is specified over UTF-8 octets (`octet`).
; - Trivia (whitespace / newline / comments) is defined for reference. Grammar
;   productions are written as if trivia is already skipped.
;
; ---------------------------------------------------------------------------
; 0. Core terminals (octets)
; ---------------------------------------------------------------------------
octet                              = %x00-FF

lf                                 = %x0A

cr                                 = %x0D

htab                               = %x09

sp                                 = %x20

dquote                             = %x22

squote                             = %x27

backslash                          = %x5C

backtick                           = %x60

dollar                             = %x24

alpha                              = %x41-5A
                                     / %x61-7A

digit                              = %x30-39

hexdig                             = digit
                                     / %x41-46
                                     / %x61-66

underscore                         = %x5F

not-lf                             = %x00-09
                                     / %x0B-FF

not-cr-or-lf                       = %x00-09
                                     / %x0B-0C
                                     / %x0E-FF

not-star                           = %x00-29
                                     / %x2B-FF  ; OCTET except "*"

not-slash                          = %x00-2E
                                     / %x30-FF  ; OCTET except "/"

not-minus                          = %x00-2C
                                     / %x2E-FF  ; OCTET except "-"

not-dquote-or-backslash            = %x00-21
                                     / %x23-5B
                                     / %x5D-FF

not-squote-or-backslash            = %x00-26
                                     / %x28-5B
                                     / %x5D-FF

not-dquote-or-backslash-or-newline = %x00-09
                                     / %x0B-0C
                                     / %x0E-21
                                     / %x23-5B
                                     / %x5D-FF

not-squote-or-backslash-or-newline = %x00-09
                                     / %x0B-0C
                                     / %x0E-26
                                     / %x28-5B
                                     / %x5D-FF

not-backtick-or-backslash          = %x00-5B
                                     / %x5D-5F
                                     / %x61-FF
; ---------------------------------------------------------------------------
; 1. Terminals
; ---------------------------------------------------------------------------
; --- Keywords (case-sensitive; encoded as %x sequences) ---
; Form keywords construct syntax forms; they are never callable identifiers.
kw-and      = %x61.6E.64

kw-answer   = %x61.6E.73.77.65.72

kw-as       = %x61.73

kw-ask      = %x61.73.6B

kw-any      = %x61.6E.79

kw-catch    = %x63.61.74.63.68

kw-match    = %x6D.61.74.63.68

kw-comptime = %x63.6F.6D.70.74.69.6D.65

kw-data     = %x64.61.74.61

kw-effect   = %x65.66.66.65.63.74

kw-export   = %x65.78.70.6F.72.74

kw-given    = %x67.69.76.65.6E

kw-native   = %x6E.61.74.69.76.65

kw-partial  = %x70.61.72.74.69.61.6C

kw-handle   = %x68.61.6E.64.6C.65

kw-if       = %x69.66

kw-import   = %x69.6D.70.6F.72.74

kw-in       = %x69.6E

kw-known    = %x6B.6E.6F.77.6E

kw-law      = %x6C.61.77

kw-let      = %x6C.65.74

kw-mut      = %x6D.75.74

kw-rec      = %x72.65.63

kw-not      = %x6E.6F.74

kw-or       = %x6F.72

kw-require  = %x72.65.71.75.69.72.65

kw-pin      = %x70.69.6E

kw-unsafe   = %x75.6E.73.61.66.65

kw-quote    = %x71.75.6F.74.65

kw-resume   = %x72.65.73.75.6D.65

kw-shape    = %x73.68.61.70.65

kw-shl      = %x73.68.6C

kw-shr      = %x73.68.72

kw-some     = %x73.6F.6D.65

kw-where    = %x77.68.65.72.65

kw-xor      = %x78.6F.72
; --- Fixed multi-octet tokens ---
colon-eq          = ":="

colon-question-gt = ":?>"

dot-dot-dot       = "..."

dot-lbracket      = ".["

dot-lparen        = ".("

question-dot      = "?."

bang-dot          = "!."

question-question = "??"

eq-gt             = "=>"

minus-gt          = "->"

slash-eq          = "/="

lt-eq             = "<="

lt-colon          = "<:"

lt-dot-dot-lt     = "<..<"

lt-dot-dot        = "<.."

dot-dot-lt        = "..<"

dot-dot           = ".."

gt-eq             = ">="

pipe-gt           = "|>"

tilde-gt          = "~>"

tilde-eq          = "~="

colon-question    = ":?"
; --- Prefixes ---
at     = "@"

hash   = "#"

bslash = %x5C
; --- Delimiters / separators ---
lbrace    = "{"

rbrace    = "}"

lbracket  = "["

rbracket  = "]"

lparen    = "("

rparen    = ")"

comma     = ","

semicolon = ";"
; --- Single-char operators / punctuation ---
dot     = "."

colon   = ":"

pipe    = "|"

plus    = "+"

minus   = "-"

star    = "*"

slash   = "/"

percent = "%"

eq      = "="

lt      = "<"

gt      = ">"
; --- Literals ---
dec-digits         = digit *(digit / (underscore digit))

hex-digits         = hexdig *(hexdig / (underscore hexdig))

oct-digit          = %x30-37

oct-digits         = oct-digit *(oct-digit / (underscore oct-digit))

bin-digit          = %x30
                     / %x31  ; "0" / "1"

bin-digits         = bin-digit *(bin-digit / (underscore bin-digit))

exp-part           = (%x65 / %x45) [plus / minus] dec-digits

int-lit            = %x30.78 hex-digits  ; "0x"
                     / %x30.6F oct-digits  ; "0o"
                     / %x30.62 bin-digits  ; "0b"
                     / dec-digits

float-lit          = dec-digits dot dec-digits [exp-part]
                     / dot dec-digits [exp-part]
                     / dec-digits exp-part

esc-simple         = squote
                     / dquote
                     / backtick
                     / backslash
                     / dollar
                     / %x6E
                     / %x72
                     / %x74
                     / %x30

esc-hex            = %x78 2hexdig

esc-uni            = %x75 4hexdig [2hexdig]

esc-seq            = backslash (esc-simple / esc-hex / esc-uni)

string-body-char   = esc-seq
                     / not-dquote-or-backslash-or-newline

rune-body-char     = esc-seq
                     / not-squote-or-backslash-or-newline

string-lit         = dquote *(string-body-char) dquote

template-body-char = esc-seq
                     / not-backtick-or-backslash

template-no-subst  = backtick *(template-body-char) backtick

template-head      = backtick *(template-body-char) "${"

template-middle    = "}" *(template-body-char) "${"

template-tail      = "}" *(template-body-char) backtick

template-lit       = template-no-subst
                     / (template-head expr *(template-middle expr)
                       template-tail)
;
; Template literals are lexically stateful in the canonical ANTLR grammar:
; - Template text may contain raw newlines.
; - Interpolation ends at the `}` that closes the `${` (i.e. when brace depth returns to 0).
; - This ABNF specifies the surface spelling only; it does not model brace-nesting or lexer modes.
rune-lit = squote *(rune-body-char) squote

literal  = int-lit
           / float-lit
           / string-lit
           / rune-lit
; --- Idents ---
plain-ident = alpha *(alpha / digit / underscore)

ident       = plain-ident

sym-char    = star
              / plus
              / minus
              / slash
              / percent
              / eq
              / lt
              / gt

symbolic-op = 2*sym-char

op-single   = plus
              / minus
              / star
              / slash
              / percent
              / eq
              / slash-eq
              / lt
              / lt-eq
              / gt
              / gt-eq

word-op     = kw-and
              / kw-catch
              / kw-in
              / kw-not
              / kw-or
              / kw-shl
              / kw-shr
              / kw-xor

op-name     = op-single
              / symbolic-op
              / word-op

op-ident    = lparen op-name rparen
; --- Trivia (skipped) ---
newline                  = lf

ws                       = 1*(sp / htab / cr)

line-module-doc-comment  = "--!" *(not-cr-or-lf)

line-doc-comment         = "---" *(not-cr-or-lf)

line-comment             = "--" *(not-cr-or-lf)

block-open               = "/-"

block-doc-open           = "/--"

block-module-doc-open    = "/-!"

block-close              = "-/"

block-content            = *(block-comment / block-doc-comment /
                           block-module-doc-comment / not-block-delim)

not-block-delim          = not-slash
                           / (slash not-minus)
                           / (minus not-slash)

block-module-doc-comment = block-module-doc-open block-content block-close

block-doc-comment        = block-doc-open block-content block-close

block-comment            = block-open block-content block-close

trivia                   = ws
                           / newline
                           / line-module-doc-comment
                           / line-doc-comment
                           / line-comment
                           / block-module-doc-comment
                           / block-doc-comment
                           / block-comment
; ---------------------------------------------------------------------------
; 2. Parser grammar (over the token stream, trivia-skipped)
; ---------------------------------------------------------------------------
root      = *(root-stmt)

root-stmt = declaration semicolon
            / stmt
; Bodyless `let` declarations require semantic permission such as `@axiom`.
declaration = law-decl
              / fn-decl

stmt        = expr semicolon
; --- Expressions (semantic precedence; parse as flat infix chain) ---
expr             = infix-expr

infix-op         = colon-eq
                   / pipe-gt
                   / minus-gt
                   / tilde-gt
                   / tilde-eq
                   / question-question
                   / kw-or
                   / kw-catch
                   / kw-xor
                   / kw-and
                   / eq
                   / slash-eq
                   / lt
                   / gt
                   / lt-eq
                   / gt-eq
                   / lt-dot-dot
                   / lt-dot-dot-lt
                   / dot-dot
                   / dot-dot-lt
                   / kw-in
                   / kw-shl
                   / kw-shr
                   / plus
                   / minus
                   / star
                   / slash
                   / percent

infix-expr       = prefix-expr *(infix-op prefix-expr)

prefix-op        = minus
                   / kw-any
                   / kw-comptime
                   / kw-known
                   / kw-not
                   / kw-mut
                   / kw-some
                   / dot-dot
                   / dot-dot-lt

prefix-expr      = prefix-op prefix-expr
                   / postfix-expr

postfix-expr     = atom *(postfix-op)

postfix-op       = call-op
                   / bracket-apply-op
                   / access-op
                   / dot-dot
                   / lt-dot-dot
                   / type-test-op
                   / type-cast-op

call-op          = lparen [arg-list] rparen

bracket-apply-op = lbracket [expr-list] rbracket
; `?.[` and `?.(` are parsed as the optional access edge plus a selector, not as
; separate lexer tokens. Plain operator selection uses `.` plus `(` as `dot-lparen`.
access-op       = dot field-target
                  / dot-lbracket [expr-list] rbracket
                  / dot-lparen op-name rparen
                  / question-dot access-selector
                  / bang-dot access-selector

access-selector = field-target
                  / lbracket [expr-list] rbracket
                  / lparen op-name rparen
; `as` aliases an already matched/refined value. It is not import/type/module
; alias syntax.
type-test-op = colon-question expr [kw-as ident]

type-cast-op = colon-question-gt expr

field-target = ident
               / int-lit
; --- Atoms ---
atom                  = literal
                        / template-lit
                        / splice
                        / ident
                        / op-ident
                        / lambda-expr
                        / paren-expr
                        / array-expr
                        / record-literal-expr
                        / dot-prefix-expr
                        / match-expr
                        / let-expr
                        / resume-expr
                        / import-expr
                        / data-expr
                        / effect-expr
                        / shape-expr
                        / given-expr
                        / ask-expr
                        / answer-lit-expr
                        / unsafe-expr
                        / pin-expr
                        / handle-expr
                        / quote-expr
                        / with-mods-expr

lambda-expr           = bslash params [colon expr] eq-gt expr

paren-expr            = lparen rparen
                        / lparen comma rparen
                        / lparen semicolon rparen
                        / lparen grouped-or-tuple-body rparen
                        / lparen sequence-body rparen

grouped-or-tuple-body = expr [comma [expr-list] [comma]]

sequence-body         = expr *(semicolon expr) [semicolon]

match-expr            = kw-match expr lparen [pipe] match-arm *(pipe match-arm)
                        [pipe] rparen

match-arm             = [attrs] pattern [kw-if expr] eq-gt expr

array-expr            = lbracket comma-pad [array-items] comma-pad rbracket

array-items           = array-item *(comma array-item)

array-item            = spread
                        / expr

record-literal-expr   = lbrace [record-fields] rbrace

record-fields         = comma-pad [record-field *(comma record-field)] comma-pad

record-field          = ident [colon-eq expr]
                        / spread

spread                = dot-dot-dot expr

dot-prefix-expr       = dot ident [lparen [variant-arg-list] rparen]

variant-arg-list      = variant-arg *(comma variant-arg) [comma]

variant-arg           = ident colon-eq expr
                        / expr

resume-expr           = kw-resume [expr]

import-expr           = kw-import ((lparen [import-block-items] rparen) / expr)

import-block-items    = expr *(semicolon expr) [semicolon]

let-modifier          = kw-rec

let-expr              = kw-let [let-modifier] let-head [bracket-params] [params]
                        [type-annot] [where-clause] [require-clause] colon-eq
                        expr

let-head              = receiver-method-head
                        / pattern

receiver-method-head  = lparen ident type-annot rparen dot ident

bracket-params        = lbracket bracket-param *(comma bracket-param) [comma]
                        rbracket

bracket-param         = ident [type-annot]

require-clause        = kw-require effect-set

data-expr             = kw-data lbrace data-body rbrace

data-body             = variant-list
                        / rec-def-fields
                        / pipe
                        / semicolon

variant-list          = [pipe] variant *(pipe variant) [pipe]

variant               = [attrs] ident [variant-payload-defs] [minus-gt expr]
                        [colon-eq expr]

variant-payload-defs  = lparen variant-payload-def *(comma variant-payload-def)
                        [comma] rparen

variant-payload-def   = ident colon expr
                        / expr

rec-def-fields        = [semicolon] rec-def-field *(semicolon rec-def-field)
                        [semicolon]

rec-def-field         = ident colon expr [colon-eq expr]

effect-expr           = kw-effect lbrace structural-members rbrace

effect-member         = fn-decl

shape-expr            = kw-shape [where-clause] lbrace structural-members rbrace

given-expr            = kw-given [bracket-params] expr [where-clause] lbrace
                        structural-members rbrace

ask-expr              = kw-ask expr

unsafe-expr           = kw-unsafe lbrace *stmt rbrace

pin-expr              = kw-pin expr kw-as ident kw-in expr

answer-lit-expr       = kw-answer prefix-expr lbrace structural-fn-members
                        rbrace

handle-expr           = kw-handle expr kw-answer prefix-expr

native-let-group      = lparen 1*(kw-let native-binding semicolon) rparen
; `quote` creates hygienic syntax objects. Splices use `#` and are valid only
; under quote.
quote-expr      = kw-quote (lparen expr rparen / lbrace *(stmt) rbrace)

splice          = hash ident
                  / hash lparen expr rparen
                  / hash lbracket [expr-list] rbracket

with-attrs-expr = with-mods-expr
; `export` is a modifier that applies to an expression (like attributes), not an
; expression form itself.
export-mod     = kw-export [kw-native [string-lit]]

native-mod     = kw-native [string-lit]

partial-mod    = kw-partial

modifier       = attr
                 / export-mod
                 / native-mod
                 / partial-mod

with-mods-expr = 1*modifier (expr / native-let-group / let-expr)

let-rest       = [let-modifier] pattern [bracket-params] [params] [type-annot]
                 [where-clause] [require-clause] [colon-eq expr]

native-binding = [attrs] ident [bracket-params] [params] [where-clause] [colon
                 expr]

fn-decl        = [attrs] kw-let op-or-ident [bracket-params] [params]
                 [type-annot] [colon-eq expr]

op-or-ident    = ident
                 / op-ident

law-decl       = [attrs] kw-law op-or-ident [bracket-params] params colon-eq
                 expr
; Structural member lists accept leading and trailing separators, matching `{ ; x; }`.
structural-members    = *(semicolon) [structural-member *(1*semicolon
                        structural-member) *(semicolon)]

structural-member     = fn-decl
                        / law-decl

structural-fn-members = *(semicolon) [fn-decl *(1*semicolon fn-decl)
                        *(semicolon)]
; --- Unified annotation / constraint helpers ---
type-annot     = colon expr

effect-set     = lbrace comma-pad [effect-entries] comma-pad rbrace

effect-entries = effect-list [comma effect-rest]
                 / effect-rest

effect-rest    = dot-dot-dot ident

effect-list    = effect-item *(comma effect-item)

effect-item    = ident [lbracket expr rbracket]

where-clause   = kw-where constraint *(comma constraint) [comma]

constraint     = ident lt-colon expr
                 / ident colon expr
                 / ident tilde-eq expr
; --- Patterns ---
pattern = pattern-as *(kw-or pattern-as)
; Pattern `as` binds the matched value under an additional name.
pattern-as           = pattern-primary [kw-as ident]

pattern-primary      = underscore
                       / literal
                       / ident
                       / dot ident [lparen [variant-pat-arg-list] rparen]
                       / lbrace [rec-pat-fields] rbrace
                       / lparen [pat-list] rparen
                       / lbracket [pat-list] rbracket

variant-pat-arg-list = variant-pat-arg *(comma variant-pat-arg) [comma]

variant-pat-arg      = ident colon-eq pattern
                       / pattern

rec-pat-fields       = rec-pat-field *(comma rec-pat-field)

rec-pat-field        = ident [colon pattern]

pat-list             = pattern *(comma pattern)
; --- Attributes ---
attrs              = 1*(attr)

attr               = at attr-path [lparen [attr-args] rparen]

attr-path          = ident *(dot ident)

attr-args          = attr-arg *(comma attr-arg)

attr-arg           = ident colon-eq attr-value
                     / attr-value

attr-value         = string-lit
                     / int-lit
                     / rune-lit
                     / attr-variant
                     / attr-array
                     / attr-record

attr-variant       = dot ident [lparen [attr-value-list] rparen]

attr-array         = lbracket [attr-value-list] rbracket

attr-record        = lbrace [attr-record-fields] rbrace

attr-record-fields = attr-record-field *(comma attr-record-field) comma-pad

attr-record-field  = ident colon-eq attr-value

attr-value-list    = attr-value *(comma attr-value) comma-pad
; --- Shared helpers ---
expr-list  = expr *(comma expr)

arg-list   = arg *(comma arg)

arg        = spread
             / expr

params     = lparen [param-list] rparen

param-list = param *(comma param)

param      = [kw-comptime] ident [type-annot] [colon-eq expr]

ident-list = comma-pad ident *(comma ident) comma-pad

comma-pad  = *(comma)
